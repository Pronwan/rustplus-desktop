<UserControl x:Class="RustPlusDesk.Views.PatchNotesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Foreground="{DynamicResource TextPrimary}">

    <!--
        Pure content (no ScrollViewer) — the parent slide-in panel wraps this
        in its own ScrollViewer. UserControls can swallow the height constraint
        flowing down from the panel's Grid.Row="*" cell, leaving an inner
        ScrollViewer measured with infinite height and unable to overflow.
        Hosting the ScrollViewer one level up sidesteps that.
    -->
    <StackPanel Margin="0,0,12,12">
        <!-- UPDATE VERSION NUMBER HERE -->
        <TextBlock Text="Current Version: 1.0.0-Ryyott (forked from Pronwan v4.3.1)"
                   Foreground="{DynamicResource Accent}" FontSize="11" Margin="0,0,0,12"/>

        <!-- ============================================== -->
        <!-- RYYOTT FORK — v1.0.0 -->
        <!-- ============================================== -->
        <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="v1.0.0-Ryyott  |  Tracker, Team-sync, Modern UI"
                           FontWeight="SemiBold" FontSize="16" Margin="0,0,0,4"
                           Foreground="{DynamicResource Accent}"/>

                <TextBlock TextWrapping="Wrap" Margin="0,0,0,12">
                    <Span Foreground="{DynamicResource TextSubtle}">First release of the Ryyott fork. Built on top of </Span>
                    <Hyperlink NavigateUri="https://github.com/Pronwan/rustplus-desktop" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource Accent}">Pronwan/rustplus-desktop</Hyperlink>
                    <Span Foreground="{DynamicResource TextSubtle}"> v4.3.1 — all credit for the underlying Rust+ Desktop app goes to Pronwan.</Span>
                </TextBlock>

                <TextBlock Text="• Tracker tab" FontWeight="Bold" Margin="0,0,0,4" Foreground="{DynamicResource Accent}"/>
                <TextBlock Text="New top-level tab with Online / Tracked / Groups sub-tabs powered by BattleMetrics. Track players across sessions, group them (H1, H3, …), and pin each group's base on the map with a hover tooltip."
                           TextWrapping="Wrap" Margin="0,0,0,8"/>

                <TextBlock Text="• Activity Intelligence Report" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBlock Text="Slide-in panel over the map with a 90-day BattleMetrics session backfill: 12-week activity heatmap, 24h forecast, &quot;most likely to play&quot; prediction, total tracked time, average session length and last-seen relative time. Available as a Report button on every tracked / online / group-member row."
                           TextWrapping="Wrap" Margin="0,0,0,8"/>

                <TextBlock Text="• Tracker Expand overlay" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBlock Text="Click ⛶ Expand on the Tracker top bar to pop the whole tab into a 750 px-wide slide-in over the map. Press Esc or click ✕ to close — the tab content is reparented in / out so x:Names, bindings and event handlers all survive."
                           TextWrapping="Wrap" Margin="0,0,0,8"/>

                <TextBlock Text="• Team-sync" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBlock Text="Opt-in via Settings — share tracked players + groups (incl. map pins) across teammates within ~30 seconds. Reuses Pronwan's existing overlay-sync server with HMAC-signed payloads, last-write-wins per row, and tombstones so deletes propagate."
                           TextWrapping="Wrap" Margin="0,0,0,8"/>

                <TextBlock Text="• Inline team chat" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBlock Text="Replaced the standalone chat popup with an inline panel in the Team tab. Click any teammate tile to open their Steam profile in your default browser. Chat input + Send disable themselves when not connected so messages never get optimistically rendered and silently dropped."
                           TextWrapping="Wrap" Margin="0,0,0,8"/>

                <TextBlock Text="• shadcn-flavoured theme" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBlock Text="Full zinc palette swap (zinc-950 bg, zinc-900 surfaces, zinc-800 borders), restyled button variants (Ghost / Primary / Secondary / Destructive), modernised inputs, cards, tabs, scrollbars and dialogs. Maps Pronwan's underlying tokens so the rest of the app picks the new look up automatically."
                           TextWrapping="Wrap" Margin="0,0,0,8"/>

                <TextBlock Text="• Modal modernisation" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBlock Text="Custom shadcn-themed TextInputModal + ConfirmModal replace Microsoft.VisualBasic.Interaction.InputBox and stock MessageBox.Show prompts. Used for camera add, group create / rename / delete, reset connection, and the update-checker. Hotkeys window restyled to match."
                           TextWrapping="Wrap" Margin="0,0,0,8"/>

                <TextBlock Text="• Patch Notes &amp; Update flows as slide-ins" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBlock Text="The patch-notes window is gone — opens as a slide-in over the map (this very panel). The update-checker uses ConfirmModal for &quot;new version available&quot; and ShowInfo for the up-to-date / error paths."
                           TextWrapping="Wrap" Margin="0,0,0,8"/>

                <TextBlock Text="• Sidebar restructure" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBlock Text="Server stats (Players / Queue / Server Time) inlined into the Connection card. Reset Connection moved to the top toolbar next to Settings. Footer slimmed; Tracker / map controls reclaim the height."
                           TextWrapping="Wrap" Margin="0,0,0,8"/>

                <TextBlock Text="• Map overlay polish" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBlock Text="Drawing toolbox repositioned below the EventDock, matched chrome (border / radius / padding), shrink-to-fit on shorter windows. Tool popovers (size / colour / icon picker) open to the left as shadcn-style menus on left-click — no more right-click hunt."
                           TextWrapping="Wrap" Margin="0,0,0,8"/>

                <TextBlock Text="• Bug fixes" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBlock Text="• Chat duplicate-render bug — outgoing messages no longer rendered twice • Steam display name now flows from team data into the chat instead of always saying &quot;you&quot; • WebView2 airspace fix — slide-in panels (Patch Notes / Tracker / Report) now respond to mouse-wheel and middle-click drag from cold start, no longer dead until you connect to a server • Multiple white-on-white button text fixes (Connect / Send / + Add / + New / Camera). • Cherry-picked Pronwan's 1535a17 (player centering, MonumentWatcher thread-safety, DPI-aware sizing, auto-reconnect, heli crash sites, Deep Sea timing)."
                           TextWrapping="Wrap" Margin="0,0,0,4"/>
            </StackPanel>
        </Border>

                <!-- ============================================== -->
                <!-- UPSTREAM (Pronwan) PATCH NOTES — preserved verbatim -->
                <!-- ============================================== -->
                <TextBlock Text="Upstream history (Pronwan)"
                           FontWeight="SemiBold" FontSize="14"
                           Foreground="{DynamicResource TextSubtle}"
                           Margin="0,8,0,8"/>

                <!-- ============================================== -->
                <!-- NEW v4.2 PATCH NOTES -->
                <!-- ============================================== -->
                <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="v4.2  |  Cargo Ship Overhaul" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,4" Foreground="{DynamicResource Accent}"/>

                        <Image Source="pack://application:,,,/Screenshots/Cargo_notification_settings.png" Stretch="Uniform" MaxHeight="280" Margin="0,0,0,8"/>
                        <Image Source="pack://application:,,,/Screenshots/Cargo_docked_countdown.png" Stretch="Uniform" MaxHeight="280" Margin="0,0,0,8"/>
                        <Image Source="pack://application:,,,/Screenshots/Cargo_remaining-on-map.png" Stretch="Uniform" MaxHeight="180" Margin="0,0,0,12"/>

                        <TextBlock Text="• Smart Cargo Route Learning" FontWeight="Bold" Margin="0,0,0,4" Foreground="{DynamicResource Accent}"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                            The app now silently learns the Cargo Ship's route on your server. After the first full run, it knows the exact docking harbors, how long it stays, and where it triggers 5 minutes before arrival.
                        </TextBlock>

                        <TextBlock Text="• Live Countdown Timers" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                            A docking countdown appears directly below the Cargo Ship while it's at harbor, and a remaining-on-map timer is shown in the Event Dock. When connecting mid-event the timer shows ??:?? to indicate the duration is known but elapsed time is not.
                        </TextBlock>

                        <TextBlock Text="• Granular Cargo Chat Notifications" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                            Three new notification types are now available in Chat Alerts: Harbor Docking, Departure Warning (5 min before leaving), and Arrival Warning (5 min before docking). All are individually toggleable via right-click on the Chat Alerts button.
                        </TextBlock>

                        <TextBlock Text="• Oil Rig Crate Trigger Detection" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                            The app detects when a Chinook hovers over an Oil Rig and synthetically triggers the crate countdown — even though the Rust+ API provides no native event for this. A countdown appears on the map and chat notifications fire at trigger, 10 min, and 5 min remaining.
                        </TextBlock>

                        <Border Background="#1A4A7A" BorderBrush="#2A6AAA" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,4,0,0">
                            <TextBlock TextWrapping="Wrap" Foreground="#90C8FF">
                                <Run FontWeight="Bold">Action Required for existing users:</Run>
                                <Run> Open Chat Alerts (right-click) and reset your notifications once using the master toggle to activate the new cargo alert types.</Run>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ============================================== -->
                <!-- v4.1.4 PATCH NOTES -->
                <!-- ============================================== -->
                <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="v4.1.4  |  Granular Chat Notifications" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,4" Foreground="{DynamicResource Accent}"/>
                        <Image Source="pack://application:,,,/Screenshots/Notifications.png" Stretch="Uniform" MaxHeight="350" Margin="0,0,0,12"/>
                        <TextBlock Text="• Granular Notification Management" FontWeight="Bold" Margin="0,0,0,4" Foreground="{DynamicResource Accent}"/>
                        <TextBlock Text="Right-click 'Chat Alerts' to access a detailed management menu. You can now individually toggle notifications for cargo, helicopters, players, and more. Even Item Alerts and Shop settings can now be managed directly from this menu." TextWrapping="Wrap" Margin="0,0,0,8"/>

                        <TextBlock Text="• Improved Map Rendering &amp; Scaling" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="Adjusted the render size of the Cargo Ship and optimized map rendering performance when zoomed in deeply. The interface remains snappy and readable even at extreme zoom levels." TextWrapping="Wrap" Margin="0,0,0,8"/>
                    </StackPanel>
                </Border>

                <!-- ============================================== -->
                <!-- v4.1.2 PATCH NOTES -->
                <!-- ============================================== -->
                <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="v4.1.2  |  Custom Crosshair Editor" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,4" Foreground="{DynamicResource Accent}"/>
                        <Image Source="pack://application:,,,/Screenshots/v4_5.png" Stretch="Uniform" MaxHeight="350" Margin="0,0,0,12"/>

                        <TextBlock Text="• Fully Featured Crosshair Editor (Rightclick Crosshair Icon to Access)" FontWeight="Bold" Margin="0,0,0,4" Foreground="{DynamicResource Accent}"/>
                        <TextBlock Text="Draw your own custom crosshairs with an intuitive pixel-art style editor. Supports drawing tools (Pen, Pixel, Line, Square, Circle), custom colors, adjustable thickness and opacity, and full Undo/Redo support." TextWrapping="Wrap" Margin="0,0,0,8"/>

                        <TextBlock Text="• PNG Uploads &amp; Management" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="Upload existing PNG images to use as crosshairs. The editor automatically scales them to fit the pixel grid. You can also right-click to erase individual pixels and easily rename or delete your creations." TextWrapping="Wrap" Margin="0,0,0,8"/>
                    </StackPanel>
                </Border>

                <!-- ============================================== -->
                <!-- v4.0.0 PATCH NOTES -->
                <!-- ============================================== -->
                <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="v4.0.0  |  The Map &amp; Stability Overhaul (Major Release)" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,4" />

                        <TextBlock Margin="0,0,0,10" TextWrapping="Wrap">
                            <Span Foreground="{DynamicResource TextSubtle}">This massive milestone update is entirely thanks to </Span>
                            <Hyperlink NavigateUri="https://github.com/JawadYzbk" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource Accent}">JawadYzbk</Hyperlink>
                            <Span Foreground="{DynamicResource TextSubtle}">! He rebuilt the core architecture of the app to be faster, smarter, and infinitely more stable.</Span>
                        </TextBlock>

                        <Image Source="pack://application:,,,/Screenshots/v4_map_overhaul.png" Stretch="Uniform" MaxHeight="350" Margin="0,0,0,6"/>
                        <Image Source="pack://application:,,,/Screenshots/v4_shop_hover.png" Stretch="Uniform" MaxHeight="350" Margin="0,0,0,12"/>

                        <TextBlock Text="• 'Dead Reckoning' &amp; Connection Resilience" FontWeight="Bold" Margin="0,0,0,4" Foreground="{DynamicResource Accent}"/>
                        <TextBlock Text="Say goodbye to flickering markers! If a high-pop server (like Rustoria) delays data, the app now uses predictive interpolation to keep players and events moving smoothly. Shops will no longer disappear during brief connection drops." TextWrapping="Wrap" Margin="0,0,0,8"/>

                        <TextBlock Text="• Interactive Event Dock &amp; Auto-Follow" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="A brand new Event Dock tracks active map events (Patrol Heli, Cargo Ship, Chinook, Travelling Vendor, Deep Sea). Click an event to instantly lock the camera onto it and track it automatically across the map." TextWrapping="Wrap" Margin="0,0,0,8"/>

                        <TextBlock Text="• Smart Shop Clustering" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="Multiple vending machines in a single base are now clustered into one clean map icon. Hovering over the cluster reveals a beautifully redesigned, scrollable popup showing all items sold at that location." TextWrapping="Wrap" Margin="0,0,0,8"/>

                        <TextBlock Text="• Modern Shop Search &amp; Advanced Trades" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="The Shop Search is now an ultra-fast, modern embedded interface. The 'Profit Trades' (Arbitrage) and 'Buy X for Y' tools have been moved to their own dedicated windows. The app also introduces 'Suspicious Shop' detection to warn you about bait bases." TextWrapping="Wrap" Margin="0,0,0,8"/>

                        <TextBlock Text="• 60 FPS Animations &amp; Offline Icon Caching" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="Map zooming and panning now feature butter-smooth animations and a cinematic 'overview dip'. Item icons are securely cached offline using SHA1 hashes, making map loading near-instant and saving bandwidth." TextWrapping="Wrap" Margin="0,0,0,8"/>
                    </StackPanel>
                </Border>

                <!-- ============================================== -->
                <!-- OLDER PATCH NOTES -->
                <!-- ============================================== -->
                <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="v3.5.4  |  Player Management &amp; Optimization" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,4"/>
                        <Image Source="https://github.com/user-attachments/assets/d6fad211-efb2-4c15-9ec3-29e65cb6c8dd" Stretch="Uniform" MaxHeight="350" Margin="0,0,0,6"/>
                        <Image Source="https://github.com/user-attachments/assets/ba63c2ec-1ee6-4d12-9da1-d06df26bcd7a" Stretch="Uniform" MaxHeight="350" Margin="0,0,0,6"/>
                        <Image Source="https://github.com/user-attachments/assets/9544f75e-d98b-4e6a-b9e1-9ef6d6ee00f6" Stretch="Uniform" MaxHeight="350" Margin="0,0,0,6"/>

                        <TextBlock Text="• Manual Player Tracking &amp; Renaming" FontWeight="Bold" Margin="0,0,0,4" Foreground="{DynamicResource Accent}"/>
                        <TextBlock Text="Manually add players to your trackers list using their BattleMetrics ID. The app fetches their last seen status and allows you to rename them for better organization." TextWrapping="Wrap" Margin="0,0,0,8"/>

                        <TextBlock Text="• Optimized Item Icon Downloads" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="Icons are now fetched from RustClash CDN in 40x40 size, reducing download size by 12.9x (totaling 151KB). Existing high-res icons remain cached; only missing ones are fetched in the new optimized format." TextWrapping="Wrap" Margin="0,0,0,8"/>

                        <TextBlock Text="• Progress Tracking" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="Added a download progress bar to show visual status when the app is fetching item icons or updates." TextWrapping="Wrap" Margin="0,0,0,8"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="v3.5.3  |  The Intelligence Update" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,4"/>

                        <TextBlock Margin="0,0,0,10" TextWrapping="Wrap">
                            <Span Foreground="{DynamicResource TextSubtle}">Special thanks to </Span>
                            <Hyperlink NavigateUri="https://github.com/JawadYzbk" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource Accent}">JawadYzbk</Hyperlink>
                            <Span Foreground="{DynamicResource TextSubtle}"> for this massive contribution!</Span>
                        </TextBlock>

                        <TextBlock Text="• Advanced Activity Intelligence" FontWeight="Bold" Margin="0,0,0,4"/>
                        <Image Source="pack://application:,,,/Screenshots/3_5A.png" Stretch="Uniform" MaxHeight="350" Margin="0,0,0,6"/>
                        <TextBlock Text="Full player tracking system with 12-week heatmaps and 24h forecasts. Predict when players are active or sleeping based on historical connection data." TextWrapping="Wrap" Margin="0,0,0,8"/>

                        <TextBlock Text="• Manual IP &amp; Protocol Support" FontWeight="Bold" Margin="0,0,0,4" Foreground="{DynamicResource Accent}"/>
                        <TextBlock Text="Added support for rustplus:// links! You can now manually add servers using 'rustplus://IP:PORT'—a workaround for some servers where the pairing button is disabled." TextWrapping="Wrap" Margin="0,0,0,8"/>

                        <TextBlock Text="• Centralized Settings &amp; Auto-Connect" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="New Settings Modal: Toggle Auto-Start with Windows, Minimize to Tray, and Auto-Connect to your last server on startup." TextWrapping="Wrap" Margin="0,0,0,8"/>

                        <TextBlock Text="• System Tray &amp; Background Ops" FontWeight="Bold" Margin="0,0,0,4"/>
                        <Image Source="pack://application:,,,/Screenshots/3_5B.png" Stretch="Uniform" MaxHeight="150" Margin="0,0,0,6"/>
                        <TextBlock Text="The app can now reside in your system tray to collect data 24/7. Improved single-instance handling ensures the window pops up when you need it." TextWrapping="Wrap" Margin="0,0,0,8"/>

                        <TextBlock Text="• Fixed: Battlemetrics Server Lookup" FontWeight="Bold" Margin="0,0,0,4" Foreground="{DynamicResource Accent}"/>
                        <TextBlock Text="Overhauled server identification. Searching is now strictly IP-based for 100% accuracy, fixing issues with shared IP ranges (e.g., Rustoria)." TextWrapping="Wrap" Margin="0,0,0,4"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="v3.4.0  |  Hierarchical Grouping &amp; Advanced Alarms" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,8"/>
                        <TextBlock Text="• Hierarchical Device Grouping" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="Organize smart devices into nested groups! Drag one onto another to create folders and toggle entire groups with one click." TextWrapping="Wrap" Margin="0,0,0,8"/>
                        <TextBlock Text="• Persistent Smart Alarm Settings" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="Enable/disable popups and audio independently. Support for custom .wav/.mp3 alarm files via right-click." TextWrapping="Wrap" Margin="0,0,0,8"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="v3.3.1  |  Stability &amp; Event Awareness" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,8"/>
                        <TextBlock Text="• Deep Sea Event Notifications ~3 minutes ahead of actual Deep Sea Spawn" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="Team chat notifications for Deep Sea events (direction always West, not actual direction)." TextWrapping="Wrap" Margin="0,0,0,8"/>
                        <TextBlock Text="• Chat Deduplication" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="Robust 100-message window check to prevent duplicate notifications during reconnects." TextWrapping="Wrap" Margin="0,0,0,8"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="v3.3.0  |  Oilrig Timer &amp; !leader Command" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,8"/>
                        <Image Source="pack://application:,,,/Screenshots/3.3.0_1.png" Stretch="Uniform" MaxHeight="250" Margin="0,0,0,4"/>
                        <TextBlock Text="Live countdown for Oilrig crates directly on the map. Teammates can use !leader in chat to request promotion." TextWrapping="Wrap" Margin="0,0,0,8"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Core Features &amp; Older Updates" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,6"/>
                        <TextBlock Text="• v3.2.0: Smart Device Import/Export for teams." Margin="0,0,0,2"/>
                        <TextBlock Text="• v3.1.0: Full Storage Monitor &amp; Upkeep integration." Margin="0,0,0,2"/>
                        <TextBlock Text="• v3.0.0: Massive Shop Analytics overhaul &amp; Custom Map Overlays." Margin="0,0,0,2"/>
                        <TextBlock Text="• Camera monitoring, Team management, Death markers, and more." Margin="0,4,0,0" FontStyle="Italic"/>
                    </StackPanel>
                </Border>
    </StackPanel>
</UserControl>
