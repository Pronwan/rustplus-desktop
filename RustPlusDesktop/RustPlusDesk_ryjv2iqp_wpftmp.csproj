  </Target>
  <Target Name="EmbedMapParserRuntime" BeforeTargets="AssignTargetPaths" DependsOnTargets="BuildMapParserRuntime" Condition="Exists('$(MapParserPublishedExe)') And !$([System.String]::Copy('$(MSBuildProjectName)').Contains('_wpftmp'))">
