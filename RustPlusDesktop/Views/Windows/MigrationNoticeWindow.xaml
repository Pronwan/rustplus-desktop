<Window x:Class="RustPlusDesk.Views.MigrationNoticeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rust+ Desktop — v5.2.0 Update"
        Width="490" Height="540"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#0F1215"
        Foreground="White"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#E8611A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="24,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF7A2E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#C4500F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#1E2329"/>
            <Setter Property="Foreground" Value="#A0ADB8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="24,9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2E3740"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#252C35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Draggable outer border -->
    <Border Background="#0F1215" BorderBrush="#2A3040" BorderThickness="1" CornerRadius="12"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#161B22" CornerRadius="12,12,0,0" Padding="20,14">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#E8611A" CornerRadius="5" Padding="6,3" Margin="0,0,10,0">
                        <TextBlock Text="v5.2.0" FontSize="11" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <TextBlock Text="Streamer-Mode &amp; Mini Map Overhaul" FontSize="15" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="22,18,22,10">

                <TextBlock Text="Feature Summary &amp; Adjustments" FontSize="13" FontWeight="SemiBold"
                           Foreground="#E8611A" Margin="0,0,0,10"/>

                <!-- Feature list -->
                <Border Background="#161B22" BorderBrush="#2A3040" BorderThickness="1" CornerRadius="8" Padding="14,12" Margin="0,0,0,14">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="🎥" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock TextWrapping="Wrap">
                                <Run FontWeight="SemiBold" Foreground="White">Streamer Mode</Run>
                                <Run Foreground="#8090A0"> — Abbreviates names, hides server list and console</Run>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="🔎" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock TextWrapping="Wrap">
                                <Run FontWeight="SemiBold" Foreground="White">Player Marker Scaling</Run>
                                <Run Foreground="#8090A0"> — Adjust the size of player markers on your map</Run>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎨" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock TextWrapping="Wrap">
                                <Run FontWeight="SemiBold" Foreground="White">Mini Map Polish</Run>
                                <Run Foreground="#8090A0"> — Even better alignment and customizability</Run>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Info box -->
                <Border Background="#0D2137" BorderBrush="#1A4A7A" BorderThickness="1" CornerRadius="8" Padding="12,10" Margin="0,0,0,10">
                    <TextBlock TextWrapping="Wrap" Foreground="#90C8FF" FontSize="12" LineHeight="18">
                        <Run FontWeight="Bold">⚠️ Action Required:</Run>
                        <Run>You can enable </Run>
                        <Run FontWeight="Bold" Foreground="White">Streamer Mode</Run>
                        <Run> via Settings or the new toggle in the Team tab. For a detailed list of all changes, please open the </Run>
                        <Run FontWeight="Bold" Foreground="White">Patch Notes</Run>
                        <Run> at the top. Happy surviving!</Run>
                    </TextBlock>
                </Border>

                <!-- Tracking warning box -->
                <Border Background="#331414" BorderBrush="#8A2323" BorderThickness="1" CornerRadius="8" Padding="12,10">
                    <TextBlock TextWrapping="Wrap" Foreground="#FFCCCC" FontSize="12" LineHeight="18">
                        <Run FontWeight="Bold" Foreground="#FF5555">⚠️ BattleMetrics Removal:</Run>
                        <Run>We have completely removed the BattleMetrics integration from Rust+ Desk. BattleMetrics does not want us as a partner, and we want to protect the users of our app at all costs. Player tracking is now exclusively handled natively via direct UDP queries.</Run>
                    </TextBlock>
                </Border>
            </StackPanel>

            <!-- Buttons -->
            <Border Grid.Row="2" Background="#161B22" CornerRadius="0,0,12,12" Padding="20,12">
                <Grid>
                    <CheckBox x:Name="ChkDontShow" Content="Don't show this again" 
                              VerticalAlignment="Center" HorizontalAlignment="Left"
                              Foreground="#8090A0" IsChecked="True"/>
                    
                    <Button x:Name="BtnOk" Style="{StaticResource PrimaryBtn}"
                            Content="Awesome, let's go!"
                            HorizontalAlignment="Right"
                            Click="BtnOk_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
