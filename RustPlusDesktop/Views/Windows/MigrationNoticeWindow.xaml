<Window x:Class="RustPlusDesk.Views.MigrationNoticeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:p="clr-namespace:RustPlusDesk.Properties"
        Title="{x:Static p:Resources.UpkeepMinimapTrackingUpdate}" 
        Width="580" Height="500"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBg}"
        Foreground="{DynamicResource TextPrimary}"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize">

    <Border Background="{DynamicResource Surface}" 
            BorderBrush="{DynamicResource CardBorder}" 
            BorderThickness="1" 
            CornerRadius="16" 
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" Opacity="0.4" ShadowDepth="0" Color="Black"/>
        </Border.Effect>
        
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="🚀" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="{x:Static p:Resources.FeatureSummaryAdjustments}" 
                           FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                <StackPanel>
                    <Border Background="{DynamicResource SurfaceAlt}" CornerRadius="10" Padding="15" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="{x:Static p:Resources.Snapshot}" FontWeight="Bold" Foreground="{DynamicResource Accent}" Margin="0,0,0,5"/>
                            <TextBlock Text="The devices list now shows a persistent item count and upkeep summary for storage monitors, even when offline." 
                                       TextWrapping="Wrap" FontSize="13" Opacity="0.9"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource SurfaceAlt}" CornerRadius="10" Padding="15" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Interactive Minimap" FontWeight="Bold" Foreground="{DynamicResource Accent}" Margin="0,0,0,5"/>
                            <TextBlock Text="The map toolbar now has a 'Mini' button. It opens a small, always-on-top window of your position." 
                                       TextWrapping="Wrap" FontSize="13" Opacity="0.9"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource SurfaceAlt}" CornerRadius="10" Padding="15" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Live Online Status" FontWeight="Bold" Foreground="{DynamicResource Accent}" Margin="0,0,0,5"/>
                            <TextBlock Text="The 'Players' tab now separates Online and Tracked players. You can search BattleMetrics directly." 
                                       TextWrapping="Wrap" FontSize="13" Opacity="0.9"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource SurfaceAlt}" CornerRadius="10" Padding="15" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Social &amp; Updates" FontWeight="Bold" Foreground="{DynamicResource Accent}" Margin="0,0,0,5"/>
                            <TextBlock Text="Added Discord and Patch-Notes buttons to the top header for easier community access." 
                                       TextWrapping="Wrap" FontSize="13" Opacity="0.9"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Margin="0,20,0,0" Padding="0,15,0,0" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource CardBorder}">
                <Grid>
                    <CheckBox x:Name="ChkDontShow" 
                              Content="{x:Static p:Resources.DontShowAgain}" 
                              VerticalAlignment="Center" 
                              Foreground="{DynamicResource TextSubtle}"/>
                    
                    <Button Content="{x:Static p:Resources.AwesomeLetsGo}" 
                            Padding="25,10" 
                            Background="{DynamicResource Accent}" 
                            Foreground="Black" 
                            FontWeight="Bold" 
                            BorderThickness="0"
                            HorizontalAlignment="Right"
                            Click="BtnOk_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
