<Window x:Class="RustPlusDesk.Views.MigrationNoticeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rust+ Desktop — v4.4 Update"
        Width="480" Height="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#0F1215"
        Foreground="White"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#E8611A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="24,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF7A2E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#C4500F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#1E2329"/>
            <Setter Property="Foreground" Value="#A0ADB8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="24,9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2E3740"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#252C35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Draggable outer border -->
    <Border Background="#0F1215" BorderBrush="#2A3040" BorderThickness="1" CornerRadius="12"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#161B22" CornerRadius="12,12,0,0" Padding="20,14">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#E8611A" CornerRadius="5" Padding="6,3" Margin="0,0,10,0">
                        <TextBlock Text="v4.4.0" FontSize="11" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <TextBlock Text="Chat Commands &amp; Map Intel" FontSize="15" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text=" — Update Notice" FontSize="15" Foreground="#5A6A7A" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="22,18,22,10">

                <TextBlock Text="Chat Commands &amp; API Optimizations" FontSize="13" FontWeight="SemiBold"
                           Foreground="#E8611A" Margin="0,0,0,10"/>

                <!-- Feature list -->
                <Border Background="#161B22" BorderBrush="#2A3040" BorderThickness="1" CornerRadius="8" Padding="14,12" Margin="0,0,0,14">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="💬" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock TextWrapping="Wrap">
                                <Run FontWeight="SemiBold" Foreground="White">Team Chat Commands</Run>
                                <Run Foreground="#8090A0"> — !pop, !time, and switch toggling</Run>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="⚙️" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock TextWrapping="Wrap">
                                <Run FontWeight="SemiBold" Foreground="White">API Optimizations</Run>
                                <Run Foreground="#8090A0"> — Faster loading &amp; improved stability</Run>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🌗" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock TextWrapping="Wrap">
                                <Run FontWeight="SemiBold" Foreground="White">Day/Night Map Intel</Run>
                                <Run Foreground="#8090A0"> — Live countdowns &amp; phase detection</Run>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Info box -->
                <Border Background="#0D2137" BorderBrush="#1A4A7A" BorderThickness="1" CornerRadius="8" Padding="12,10">
                    <TextBlock TextWrapping="Wrap" Foreground="#90C8FF" FontSize="12" LineHeight="18">
                        <Run FontWeight="SemiBold">What's new:</Run>
                        <Run> Chat Notifications are now integrated into the Team Chat window. API queries have been optimized for better performance. Happy Farming!</Run>
                    </TextBlock>
                </Border>
            </StackPanel>

            <!-- Buttons -->
            <Border Grid.Row="2" Background="#161B22" CornerRadius="0,0,12,12" Padding="20,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnReset" Style="{StaticResource PrimaryBtn}"
                            Content="Awesome, let's go!"
                            Click="BtnReset_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
