<Window x:Class="RustPlusDesk.Views.PatchNotesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:p="clr-namespace:RustPlusDesk.Properties"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:views="clr-namespace:RustPlusDesk.Views"
        Title="{DynamicResource PatchNotes}"
        Width="720" Height="620"
        Background="{DynamicResource AppBg}"
        Foreground="{DynamicResource TextPrimary}"
        WindowStartupLocation="CenterOwner">

    <Border Background="{DynamicResource Surface}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="{DynamicResource Radius}" Padding="14" Margin="8">
        <Grid>
            <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource PatchNotesHeader}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,2"/>
                        <!-- UPDATE VERSION NUMBER HERE -->
                        <TextBlock Text="{Binding CurrentVersionFormatted, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="{DynamicResource Accent}" FontSize="11" Margin="0,0,0,4"/>
                    </StackPanel>

                    <Button x:Name="BtnTranslate" HorizontalAlignment="Right" VerticalAlignment="Top" Padding="12,4" Click="BtnTranslate_Click">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Translate24" Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource TranslateViaGoogle}" VerticalAlignment="Center" x:Name="TxtTranslate"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="PatchNotesContent" Margin="0,0,0,12">
                    <Border Background="#331414" BorderBrush="#8A2323" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock FontWeight="Bold" Foreground="#FF5555" FontSize="14" Margin="0,0,0,4">
                                <Run Text="⚠️ " /><Run Text="{DynamicResource PlayerTrackingOverhaulTitle}" />
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="#FFCCCC" Margin="0,0,0,6">
                                The player tracking system has been changed completely. Please review the changes before continuing.
                            </TextBlock>
                            <TextBlock>
                                <Hyperlink Click="TrackingLink_Click" Foreground="#90C8FF" FontWeight="Bold">
                                    <Run Text="{DynamicResource HowPlayerTrackingWorks}"/>
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- ============================================== -->
                    <!-- NEW v5.4.0 PATCH NOTES -->
                    <!-- ============================================== -->
                    <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="v5.4.0 | Localization, UI Modernization &amp; Storage Upkeep Update" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,4" Foreground="{DynamicResource Accent}"/>
                            
                            <TextBlock Text="&#x2022; Global Localization &amp; Multi-Language Overhaul" FontWeight="Bold" Margin="0,0,0,4" Foreground="{DynamicResource Accent}"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                                The entire user interface has been fully internationalized and translated into 30+ languages! Change your language on the fly in the Settings menu without dropping active connections. Emojis have been fully safeguarded across translations, and non-English system locales are now fully supported.
                            </TextBlock>
                            
                            <TextBlock Text="&#x2022; Standalone App &amp; Minimap Settings Overlays" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                                No more annoying pop-up windows! The main application settings and mini-map settings have been completely refactored into gorgeous, standalone sidebar overlays with elegant slim scrollbars and WPF UI-styled switches.
                            </TextBlock>
                            
                            <TextBlock Text="&#x2022; Isolated Chat Alerts &amp; Commands" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                                Navigating is cleaner than ever. Modifying chat alerts now opens the full configure menu directly, and accessing chat commands loads them in isolation without cluttering the screen with team chat logs.
                            </TextBlock>
                            
                            <TextBlock Text="&#x2022; Robust Storage Monitors &amp; TC Upkeep" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,12">
                                Fixed the issue where storage monitors and Tool Cupboards showed "0 items" or failed to refresh on startup and soft-connection. Upkeep snapshots are queried directly from the API and synced immediately in the UI.
                            </TextBlock>

                            <TextBlock Text="&#x2022; Smart Alarm Audio Alert Looping" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,12">
                                You can now configure your Smart Alarms to loop their notification audio continuously! If an audio alert is looping, In-App popups are mandatory and cannot be turned off. Closing an In-App alert will automatically serve as the stop trigger for all running audio alerts.
                            </TextBlock>

                            <!-- v5.4.0 Dynamic Image Gallery -->
                            <views:ImageGallery>
                                <views:GalleryItem ImagePath="pack://application:,,,/Assets/Images/5.3.0/NewSettingOverlayOnLeftPanel.png" Description="Premium sidebar overlay integrating the main application settings."/>
                                <views:GalleryItem ImagePath="pack://application:,,,/Assets/Images/5.3.0/NewLanguageSelector.png" Description="On-the-fly multi-language selection supporting 30+ dynamic locales."/>
                                <views:GalleryItem ImagePath="pack://application:,,,/Assets/Images/5.3.0/ChatCommandsUI-1.png" Description="Isolated Chat Commands view, keeping team chat logs clean and structured."/>
                                <views:GalleryItem ImagePath="pack://application:,,,/Assets/Images/5.3.0/ChatCommandsUI-2.png" Description="Dynamic configure menu for custom in-game chat commands and smart alerts."/>
                                <views:GalleryItem ImagePath="pack://application:,,,/Assets/Images/5.3.0/newTeamChatUI.png" Description="Polished, isolated Team Chat layout with real-time refresh snap controls."/>
                                <views:GalleryItem ImagePath="pack://application:,,,/Assets/Images/5.3.0/LoopAudio_StopLogic.png" Description="Audio Alert Looping + Stop Button"/>
                            </views:ImageGallery>
                        </StackPanel>
                    </Border>

                    <!-- ============================================== -->
                    <!-- OLD v5.2.0 PATCH NOTES -->
                    <!-- ============================================== -->
                    <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource StreamerModeMiniMapOverhaul}" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,4" Foreground="{DynamicResource Accent}"/>
                            
                            <TextBlock Text="{DynamicResource StreamerModeTitle}" FontWeight="Bold" Margin="0,0,0,4" Foreground="{DynamicResource Accent}"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                                Protect your identity while streaming! The new Streamer Mode setting automatically collapses the server list and hides the console. It abbreviates player names and Steam IDs everywhere—including on the map, in the team tab, and even in chat alerts. You can easily toggle it via Settings or directly from the Team tab.
                            </TextBlock>
                            
                            <TextBlock Text="{DynamicResource PlayerMarkerScalingTitle}" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                                Customize your map experience further! Added a new scale slider in the Team tab to freely adjust the size of player markers and names (or abbreviated names if Streamer Mode is active).
                            </TextBlock>
                            
                            <Image Source="pack://application:,,,/Assets/Screenshots/5.2.png" Stretch="Uniform" MaxHeight="350" Margin="0,4,0,12" />
                        </StackPanel>
                    </Border>

                    <!-- ============================================== -->
                    <!-- OLD v5.1.0 PATCH NOTES -->
                    <!-- ============================================== -->
                    <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="v5.1.0 |  Upkeep, Minimap &amp; Tracking Update" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,4" Foreground="{DynamicResource Accent}"/>
                            
                            <TextBlock Text="&#x2022; Embedded Shop Mechanics &amp; Profit Trades" FontWeight="Bold" Margin="0,0,0,4" Foreground="{DynamicResource Accent}"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                                No more annoying popups! The Profit Trades (Arbitrage) and "Buy X" features are now fully integrated directly into the main window's shop detail panel for a seamless, unified trading workflow.
                            </TextBlock>
                            <Image Source="pack://application:,,,/Assets/Screenshots/beta-5.1_1.png" Stretch="Uniform" MaxHeight="350" Margin="0,4,0,12" />

                            <TextBlock Text="&#x2022; Live Event Timers &amp; Chat Commands" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                                All map events (Patrol Heli, Cargo Ship, Chinook, Oil Rig, and Deep Sea) now feature precise, live countdown timers inside the Event Dock. Additionally, you can now query the state and time remaining for all active events instantly using direct chat commands in your team chat.
                            </TextBlock>
                            <Image Source="pack://application:,,,/Assets/Screenshots/beta-5.1_2.png" Stretch="Uniform" MaxHeight="250" Margin="0,4,0,4" />
                            <Image Source="pack://application:,,,/Assets/Screenshots/beta-5.1_4.png" Stretch="Uniform" MaxHeight="250" Margin="0,0,0,12" />

                            <TextBlock Text="&#x2022; Minimap Upgrade: Layouts, Opacity &amp; Clock" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                                The Minimap has received a major polish! You can now choose between multiple shape layouts (Circle, Square, and 16:9 Rectangle), dynamically adjust the overlay opacity, and toggle a real-time server clock to keep track of wipe cycles.
                            </TextBlock>
                            <Image Source="pack://application:,,,/Assets/Screenshots/beta-5.1_3.png" Stretch="Uniform" MaxHeight="280" Margin="0,4,0,12" />

                            <TextBlock Text="&#x2022; Advanced TC Upkeep &amp; Detail Reports" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                                Builder heaven! You can now query the upkeep status of multiple Tool Cupboards simultaneously in a compact overview. Plus, we've introduced the new <Run FontWeight="Bold">!upkeepdetail</Run> command which outputs granular upkeep reports for all Storage Monitors in separate chat messages (with a configurable delay) and projects resources calculated for a full 24-hour cycle.
                            </TextBlock>
                            <Image Source="pack://application:,,,/Assets/Screenshots/beta-5.1_6.png" Stretch="Uniform" MaxHeight="350" Margin="0,4,0,12" />

                            <TextBlock Text="&#x2022; Expanded Smart Alerts Options" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                                Smart Alerts have become much more powerful. Beyond local sounds and popups, you can now toggle a beautiful In-App visual popup alert, or have the alarm event printed directly to your team chat as a team message when a smart alarm is triggered.
                            </TextBlock>
                            <Image Source="pack://application:,,,/Assets/Screenshots/beta-5.1_7.png" Stretch="Uniform" MaxHeight="350" Margin="0,4,0,12" />

                            <TextBlock Text="&#x2022; Connection Resilience &amp; Alert Fixes" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                                <Run FontWeight="Bold">&#x2022; Chat Alert Delay:</Run> Slightly increased the delay between sequential chat alerts to prevent duplicate or spam notifications on laggy API servers.<LineBreak/>
                                <Run FontWeight="Bold">&#x2022; Handshake Timeout:</Run> Increased the connection/handshake timeout limit from 5 seconds to 15 seconds, ensuring a successful map download even on highly congested or high-ping connections.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- ============================================== -->
                    <!-- OLD v5.0.0 PATCH NOTES -->
                    <!-- ============================================== -->
                    <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="v5.0.0 |  The Game Changer Update (May 15, 2026)" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,4" Foreground="{DynamicResource Accent}"/>
                            
                            <!-- Thumbnail -->
                            <Image Source="pack://application:,,,/Assets/Images/RustPlus_V5_Thumbnail.jpg" Stretch="Uniform" MaxHeight="380" Margin="0,4,0,12" />

                            <!-- Features -->
                            <TextBlock Text="&#x2022; Integrated Auto-Update System &amp; Runtime Management" FontWeight="Bold" Margin="0,0,0,4" Foreground="{DynamicResource Accent}"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                                Never worry about manual updates again. The app now features a background update checker with a detailed progress UI (speed, size, percentage). Runtime management has been centralized for better reliability and easier installation of background components like Node.js.
                            </TextBlock>

                            <TextBlock Text="&#x2022; Modernized 'Edge-to-Edge' Interface &amp; Map Fixes" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                                We've removed the thick outer margins and squared off the window corners for a truly modern, flush design. This update also includes <Run FontWeight="Bold">interpolated map movements</Run> for smoother tracking and a fix for the "Center on Map" functionality for team members.
                            </TextBlock>

                            <TextBlock Text="&#x2022; Smart Home Automation: Storage Monitors &amp; !Upkeep" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                                Complete overhaul of device detection. The app now <Run FontWeight="Bold">automatically recognizes Storage Monitors</Run> alongside Smart Switches and TCs for chat commands. Use the <Run FontWeight="Bold">!Upkeep</Run> command in team chat to get a live report from any number of connected Tool Cupboards.
                            </TextBlock>

                            <TextBlock Text="&#x2022; Advanced Player Tracking &amp; Grouping" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                                The player list has been completely rebuilt for better performance and styling. You can now track custom Group Names and Colors for players. Added a context menu to player cards, along with "Is Online" and "Play Time" indicators.
                            </TextBlock>

                            <TextBlock Text="&#x2022; Expanded Alert System &amp; Smart Alarm Fixes" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                                Added new chat alert options for <Run FontWeight="Bold">monuments, player status, and shop changes</Run>. Audio Smart Alarm alerts now work properly again, and we've added a warning if your pairing is about to expire via a new sidebar InfoBar.
                            </TextBlock>

                            <TextBlock Text="&#x2022; Enhanced Background Stability &amp; FCM Hardening" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                                Major architectural hardening to prevent crashes and UI freezes. We've modernized how the app talks to the background Node.js process, ensuring 100% responsiveness even during complex connection transitions. Auto-reconnect will now start a new connection and dispose the old one. This should also prevent you from being kicked from the API after some hours.
                            </TextBlock>

                            <TextBlock Text="&#x2022; UI Polish &amp; Overhauled Settings" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                                The Settings window and "Chat Alerts" interaction have been redesigned for better accessibility. We've removed legacy UI artifacts like green selection highlights and upgraded the BattleMetrics button to a sleek icon on the server card.
                            </TextBlock>

                            <TextBlock Text="&#x2022; Steam Identity Integration (Preview)" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                                Added a new Steam Identity section to the sidebar, paving the way for future account-linked features like profile pictures and easy login.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- ============================================== -->
                    <!-- v4.5.0 PATCH NOTES -->
                    <!-- ============================================== -->
                    <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="v4.5.3  |  Audio Smart Alert Hotfix (May 14, 2026)" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,4" Foreground="{DynamicResource Accent}"/>

                            <!-- Screenshots -->
                            <Image Source="pack://application:,,,/Assets/Screenshots/4.5.0.png" Stretch="Uniform" MaxHeight="350" Margin="0,0,0,12"/>

                            <!-- Features -->
                            <TextBlock Text="&#x2022; Smart Map Follow &amp; Player Tracking" FontWeight="Bold" Margin="0,0,0,4" Foreground="{DynamicResource Accent}"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                                Stay centered! A brand new "Follow" mode allows you to lock the map camera onto yourself or any teammate. The camera smoothly tracks movement in real-time, perfect for second-monitor monitoring during raids or roaming.
                            </TextBlock>

                            <TextBlock Text="&#x2022; Remote Switch Control via Chat Commands" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                                Complete home automation from the battlefield. You can now assign aliases to your Smart Switches and toggle them directly via Team Chat commands. Setup is now integrated directly into the Team Chat Overlay for maximum convenience.
                            </TextBlock>

                            <TextBlock Text="&#x2022; Enhanced Connection &amp; Reconnect Stability" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                                Massive under-the-hood overhaul of the connection logic. Stale entity mappings are now cleared on disconnect, and device probes feature an early-exit logic to prevent UI hangs when multiple devices are missing or the server lags.
                            </TextBlock>

                            <TextBlock Text="&#x2022; Smart Timer &amp; Event Intelligence" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                                Improved trajectory and hover detection for Chinooks ensures Oil Rig crate timers are more reliable than ever. Cargo Ship route learning has been refined to handle mid-event connections without triggering false alerts.
                            </TextBlock>

                            <TextBlock Text="&#x2022; Customizable Chat Alerts &amp; UI Polish" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                                Right-click the Chat Alerts button to individually customize icons and notification types. The UI has been polished with better-aligned dropdowns, modern dark-themed components, and improved hover feedback for Storage Monitors.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- ============================================== -->
                    <!-- v4.3.1 PATCH NOTES -->
                    <!-- ============================================== -->
                    <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="v4.3.1  |  Bugfixes &amp; Improvements" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,4" Foreground="{DynamicResource Accent}"/>

                            <!-- Features -->
                            <TextBlock Text="&#x2022; Corrected Player Tracking &amp; Map Alignment" FontWeight="Bold" Margin="0,0,0,4" Foreground="{DynamicResource Accent}"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                                Fixed a coordinate mismatch between pixels and DIPs that caused markers to "drift" when zooming. The Mini-Map is now perfectly centered on the player at all zoom levels.
                            </TextBlock>

                            <TextBlock Text="&#x2022; Patrol Helicopter Crash Detection" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                                The app now intelligently distinguishes between a helicopter flying off-map and a crash. When a crash is detected, an explosion icon remains on the map for 10 minutes with a "minutes ago" timer.
                            </TextBlock>

                            <TextBlock Text="&#x2022; Deep Sea Timer Improvements" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                                Added "spawned ago" timers to the Event Dock and map icons. Integrated a "First Poll" guard to prevent false "Deep Sea started!" alerts upon initial server connection.
                            </TextBlock>

                            <TextBlock Text="&#x2022; Background Stability &amp; Reset Logic" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                                Hardened the connection logic to prevent "frozen" background states and ensured all event timers and markers are correctly reset when switching servers.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- ============================================== -->
                    <!-- v4.2 PATCH NOTES -->
                    <!-- ============================================== -->
                    <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="v4.2  |  Cargo Ship Overhaul" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,4" Foreground="{DynamicResource Accent}"/>

                            <!-- Screenshots -->
                            <Image Source="pack://application:,,,/Assets/Screenshots/Cargo_notification_settings.png" Stretch="Uniform" MaxHeight="280" Margin="0,0,0,8"/>
                            <Image Source="pack://application:,,,/Assets/Screenshots/Cargo_docked_countdown.png" Stretch="Uniform" MaxHeight="280" Margin="0,0,0,8"/>
                            <Image Source="pack://application:,,,/Assets/Screenshots/Cargo_remaining-on-map.png" Stretch="Uniform" MaxHeight="180" Margin="0,0,0,12"/>

                            <!-- Features -->
                            <TextBlock Text="&#x2022; Smart Cargo Route Learning" FontWeight="Bold" Margin="0,0,0,4" Foreground="{DynamicResource Accent}"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                                The app now silently learns the Cargo Ship's route on your server. After the first full run, it knows the exact docking harbors, how long it stays, and where it triggers 5 minutes before arrival.
                            </TextBlock>

                            <TextBlock Text="&#x2022; Live Countdown Timers" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                                A docking countdown appears directly below the Cargo Ship while it's at harbor, and a remaining-on-map timer is shown in the Event Dock. When connecting mid-event the timer shows ??:?? to indicate the duration is known but elapsed time is not.
                            </TextBlock>

                            <TextBlock Text="&#x2022; Granular Cargo Chat Notifications" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                                Three new notification types are now available in Chat Alerts: Harbor Docking, Departure Warning (5 min before leaving), and Arrival Warning (5 min before docking). All are individually toggleable via right-click on the Chat Alerts button.
                            </TextBlock>

                            <TextBlock Text="&#x2022; Oil Rig Crate Trigger Detection" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                                The app detects when a Chinook hovers over an Oil Rig and synthetically triggers the crate countdown &#x2014; even though the Rust+ API provides no native event for this. A countdown appears on the map and chat notifications fire at trigger, 10 min, and 5 min remaining.
                            </TextBlock>

                            <Border Background="#1A4A7A" BorderBrush="#2A6AAA" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,4,0,0">
                                <TextBlock TextWrapping="Wrap" Foreground="#90C8FF">
                                    <Run FontWeight="Bold">Action Required for existing users:</Run>
                                    <Run> Open Chat Alerts (right-click) and reset your notifications once using the master toggle to activate the new cargo alert types.</Run>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ============================================== -->
                    <!-- v4.1.4 PATCH NOTES -->
                    <!-- ============================================== -->
                    <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="v4.1.4  |  Granular Chat Notifications" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,4" Foreground="{DynamicResource Accent}"/>

                            <!-- Screenshots -->
                            <Image Source="pack://application:,,,/Assets/Screenshots/Notifications.png" Stretch="Uniform" MaxHeight="350" Margin="0,0,0,12"/>

                            <!-- Features -->
                            <TextBlock Text="&#x2022; Granular Notification Management" FontWeight="Bold" Margin="0,0,0,4" Foreground="{DynamicResource Accent}"/>
                            <TextBlock Text="Right-click 'Chat Alerts' to access a detailed management menu. You can now individually toggle notifications for cargo, helicopters, players, and more. Even Item Alerts and Shop settings can now be managed directly from this menu." TextWrapping="Wrap" Margin="0,0,0,8"/>

                            <TextBlock Text="&#x2022; Improved Map Rendering &amp; Scaling" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="Adjusted the render size of the Cargo Ship and optimized map rendering performance when zoomed in deeply. The interface remains snappy and readable even at extreme zoom levels." TextWrapping="Wrap" Margin="0,0,0,8"/>
                        </StackPanel>
                    </Border>

                    <!-- ============================================== -->
                    <!-- v4.1.2 PATCH NOTES -->
                    <!-- ============================================== -->
                    <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
