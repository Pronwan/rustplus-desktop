<UserControl x:Class="RustPlusDesk.Views.Windows.CustomAlertsEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Background="Transparent">
    <StackPanel>
        <TextBlock Text="{DynamicResource CustomAlertsDesc}"
                   Foreground="{DynamicResource TextSubtle}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,16"/>

        <ItemsControl x:Name="AlertsItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource SurfaceAlt}"
                                        BorderBrush="{DynamicResource CardBorder}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="14,12"
                                        Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Text Fields and Variable details -->
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource TextPrimary}" />
                                            <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{DynamicResource TextSubtle}" Margin="0,2,0,8" TextWrapping="Wrap"/>
                                            
                                            <ui:TextBox Text="{Binding CurrentText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                        Background="#11FFFFFF" 
                                                        Foreground="{DynamicResource TextPrimary}"
                                                        BorderBrush="{DynamicResource CardBorder}"
                                                        BorderThickness="1" 
                                                        Padding="8,6" 
                                                        FontSize="12" 
                                                        TextWrapping="Wrap" 
                                                        AcceptsReturn="False"
                                                        AutomationProperties.Name="{Binding Name}"/>

                                            <TextBlock Text="{Binding Variables}" FontSize="10" Foreground="{DynamicResource TextSubtle}" Margin="2,6,0,0" />
                                        </StackPanel>

                                        <!-- Actions Row -->
                                        <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center">
                                            <!-- Save Button -->
                                            <ui:Button Click="BtnSave_Click" Appearance="Primary" Padding="8" Margin="0,0,0,8" ToolTip="{DynamicResource Save}" AutomationProperties.Name="{DynamicResource Save}">
                                                <ui:Button.Icon>
                                                    <ui:SymbolIcon Symbol="Save24" />
                                                </ui:Button.Icon>
                                            </ui:Button>

                                            <!-- Reset Button -->
                                            <ui:Button Click="BtnReset_Click" Appearance="Secondary" Padding="8" ToolTip="{DynamicResource Reset}" AutomationProperties.Name="{DynamicResource Reset}">
                                                <ui:Button.Icon>
                                                    <ui:SymbolIcon Symbol="ArrowUndo24" />
                                                </ui:Button.Icon>
                                            </ui:Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>
