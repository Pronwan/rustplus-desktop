<Window x:Class="RustPlusDesk.Views.Windows.PremiumInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:p="clr-namespace:RustPlusDesk.Properties"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="{x:Static p:Resources.PremiumFeatures}"
        Width="400" Height="220"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        Foreground="White"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border Background="{DynamicResource Surface}" 
            BorderBrush="{DynamicResource CardBorder}" 
            BorderThickness="1" 
            CornerRadius="16" 
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" Opacity="0.4" ShadowDepth="0" Color="Black"/>
        </Border.Effect>
        
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,15">
                <ui:SymbolIcon Symbol="Star24" Foreground="#FF3B30" FontSize="24" Margin="0,0,10,0"/>
                <TextBlock Text="{x:Static p:Resources.PremiumFeatures}" FontSize="18" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock x:Name="TxtDescription"
                       Grid.Row="1"
                       TextWrapping="Wrap" 
                       FontSize="14" 
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                       LineHeight="22" />

            <ui:Button Grid.Row="2" 
                       Content="OK" 
                       Appearance="Primary" 
                       HorizontalAlignment="Right" 
                       Width="100" 
                       Click="BtnOk_Click" />
        </Grid>
    </Border>
</Window>
