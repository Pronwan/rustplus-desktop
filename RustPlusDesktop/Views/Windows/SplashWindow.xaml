<Window x:Class="RustPlusDesk.Views.Windows.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RustPlusDesk"
        Width="600" Height="340"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Topmost="True">

    <Window.Resources>
        <!-- Shimmer animation for the loading bar -->
        <Storyboard x:Key="ShimmerStory" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="ShimmerRect"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="-220" To="620" Duration="0:0:1.4" />
        </Storyboard>

        <!-- Fade-in animation for the entire window content -->
        <Storyboard x:Key="FadeInStory">
            <DoubleAnimation Storyboard.TargetName="RootBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" />
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource FadeInStory}" />
            <BeginStoryboard Storyboard="{StaticResource ShimmerStory}" />
        </EventTrigger>
    </Window.Triggers>

    <!-- Root border with rounded corners and drop shadow -->
    <Border x:Name="RootBorder" CornerRadius="12" Opacity="0" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="32" ShadowDepth="8" Opacity="0.7" Direction="270" />
        </Border.Effect>

        <Grid>
            <!-- Background image (TitleScreen) -->
            <Image Source="pack://application:,,,/Assets/TitleScreen-rust-plus-desktop.png"
                   Stretch="UniformToFill" />

            <!-- Dark overlay gradient for legibility -->
            <Border>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#55000000" Offset="0" />
                        <GradientStop Color="#CC0D0D0D" Offset="0.6" />
                        <GradientStop Color="#F00D0D0D" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Content stack -->
            <Grid VerticalAlignment="Bottom" Margin="36,0,36,28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- App name -->
                <TextBlock Grid.Row="0"
                           Text="Rust+ Desk"
                           FontFamily="Segoe UI"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#FFFFFFFF"
                           HorizontalAlignment="Left">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="2" Opacity="0.9" />
                    </TextBlock.Effect>
                </TextBlock>

                <!-- Tagline / status -->
                <TextBlock x:Name="StatusText"
                           Grid.Row="2"
                           Text="Loading…"
                           FontFamily="Segoe UI"
                           FontSize="13"
                           Foreground="#BBFFFFFF"
                           HorizontalAlignment="Left" />

                <!-- Loading bar track -->
                <Border Grid.Row="4"
                        Height="5"
                        CornerRadius="3"
                        Background="#33FFFFFF"
                        ClipToBounds="True">
                    <!-- Shimmer highlight -->
                    <Rectangle x:Name="ShimmerRect"
                               Width="200" Height="5"
                               HorizontalAlignment="Left"
                               RenderTransformOrigin="0.5,0.5">
                        <Rectangle.RenderTransform>
                            <TranslateTransform X="-220" />
                        </Rectangle.RenderTransform>
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#00CE4022" Offset="0" />
                                <GradientStop Color="#FFCE4022" Offset="0.4" />
                                <GradientStop Color="#FFFF6B3D" Offset="0.5" />
                                <GradientStop Color="#FFCE4022" Offset="0.6" />
                                <GradientStop Color="#00CE4022" Offset="1" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                </Border>

                <!-- Version -->
                <TextBlock x:Name="VersionText"
                           Grid.Row="6"
                           Text="v7.3.3"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           Foreground="#66FFFFFF"
                           HorizontalAlignment="Right" />
            </Grid>
        </Grid>
    </Border>
</Window>
