<Window x:Class="RustPlusDesk.Views.Windows.Dialogs.FcmConsentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Offline Alerts Setup" Height="400" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource ApplicationBackgroundBrush}"
        Foreground="{DynamicResource TextPrimary}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="0" CornerRadius="8" GlassFrameThickness="0" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Custom TitleBar -->
        <Border Grid.Row="0" Background="{DynamicResource SolidBackgroundFillColorBaseBrush}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <ui:SymbolIcon Symbol="CloudArrowUp24" Foreground="{DynamicResource Accent}" Margin="0,0,8,0"/>
                    <TextBlock Text="Offline Alerts Setup" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextPrimary}" />
                </StackPanel>
                <Button HorizontalAlignment="Right" Width="46" Background="Transparent" BorderThickness="0" Foreground="White" Click="BtnClose_Click">
                    <ui:SymbolIcon Symbol="Dismiss24" FontSize="12" />
                </Button>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,24,24,12">
                <!-- Header -->
                <TextBlock Text="Sync your Rust+ Connection" 
                           FontSize="20" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" Margin="0,0,0,16"/>

                <TextBlock TextWrapping="Wrap" Foreground="#DDDDDD" FontSize="14" LineHeight="20" Margin="0,0,0,24">
                    By enabling Offline Alerts, you allow the Rust+ Desktop cloud worker to securely store your FCM credentials. This enables features like Discord Raid Alerts, Alexa Integration, and Telegram Calls to work even when your PC is completely turned off.
                </TextBlock>

                <!-- Info Box -->
                <Border Background="#1E1E1E" CornerRadius="6" Padding="16" BorderBrush="#333333" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="What happens next:" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,12"/>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <ui:SymbolIcon Symbol="Checkmark24" Foreground="#4CAF50" FontSize="16" Margin="0,0,12,0"/>
                            <TextBlock Text="Your FCM connection token is uploaded securely." Foreground="#DDDDDD" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <ui:SymbolIcon Symbol="Checkmark24" Foreground="#4CAF50" FontSize="16" Margin="0,0,12,0"/>
                            <TextBlock Text="The cloud worker listens for incoming alarms." Foreground="#DDDDDD" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="LockClosed24" Foreground="#4CAF50" FontSize="16" Margin="0,0,12,0"/>
                            <TextBlock Text="You can revoke this access at any time." Foreground="#DDDDDD" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{DynamicResource SolidBackgroundFillColorTertiaryBrush}" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <ui:Button Grid.Column="1" Content="Cancel" Margin="0,0,8,0" Click="BtnClose_Click" />
                <ui:Button Grid.Column="2" Content="Accept &amp; Sync" Appearance="Primary" Click="BtnAccept_Click" />
            </Grid>
        </Border>
    </Grid>
</Window>
