<Window x:Class="RustPlusDesk.Views.SettingsModal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:properties="clr-namespace:RustPlusDesk.Properties"
        Title="{DynamicResource AppSettingsTitle}" 
        Width="500" Height="480"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="True" 
        WindowStyle="None"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True">
    
    <Border Background="{DynamicResource SurfaceAlt}" 
            BorderBrush="{DynamicResource CardBorder}" 
            BorderThickness="2" 
            CornerRadius="12">
        <DockPanel Margin="20">
            <!-- Header -->
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,20">
                <DockPanel>
                    <TextBlock Text="{DynamicResource Settings}" 
                               Foreground="White" 
                               FontSize="22" 
                               FontWeight="Bold" 
                               VerticalAlignment="Center"/>
                    <Button Content="✕" 
                            HorizontalAlignment="Right" 
                            Width="30" Height="30"
                            Style="{StaticResource GhostButton}"
                            Click="BtnClose_Click"
                            Cursor="Hand"
                            FontSize="18"
                            Foreground="{DynamicResource TextSubtle}"/>
                </DockPanel>
                <Separator Background="{DynamicResource CardBorder}" Margin="0,10,0,0"/>
            </StackPanel>

            <!-- Footer -->
            <Button DockPanel.Dock="Bottom" 
                    Content="{DynamicResource Close}" 
                    Width="100" 
                    Height="35"
                    HorizontalAlignment="Right"
                    Style="{StaticResource PrimaryButton}"
                    Click="BtnClose_Click"
                    Margin="0,15,0,0"/>

            <!-- Content -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{StaticResource {x:Type ScrollViewer}}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource General}" Foreground="{DynamicResource Accent}" FontWeight="Bold" Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="{DynamicResource Language}" VerticalAlignment="Center" Width="100" Foreground="{DynamicResource TextPrimary}"/>
                        <ComboBox x:Name="CmbLanguage" Width="150" 
                                  DisplayMemberPath="Name" SelectedValuePath="Code"
                                  SelectionChanged="CmbLanguage_SelectionChanged"/>
                    </StackPanel>
                    
                    <CheckBox x:Name="ChkAutoStart" 
                               Content="{DynamicResource LaunchWithWindows}" 
                               Margin="0,0,0,12" 
                               Style="{StaticResource DotCheckBox}"
                               Checked="OnSettingChanged" Unchecked="OnSettingChanged"/>

                    <CheckBox x:Name="ChkStartMinimized" 
                               Content="{DynamicResource StartMinimizedAlways}" 
                               Margin="0,0,0,12" 
                               Style="{StaticResource DotCheckBox}"
                               Checked="OnSettingChanged" Unchecked="OnSettingChanged"/>

                    <CheckBox x:Name="ChkAutoConnect" 
                               Content="{DynamicResource AutoConnectLastServer}" 
                               Margin="0,0,0,12" 
                               Style="{StaticResource DotCheckBox}"
                               Checked="OnSettingChanged" Unchecked="OnSettingChanged"
                               ToolTip="{DynamicResource AutoConnectToolTip}"/>

                    <TextBlock Text="{DynamicResource Behavior}" Foreground="{DynamicResource Accent}" FontWeight="Bold" Margin="0,10,0,10"/>

                    <CheckBox x:Name="ChkCloseToTray" 
                               Content="{DynamicResource MinimizeToTray}" 
                               Margin="0,0,0,12" 
                               Style="{StaticResource DotCheckBox}"
                               Checked="OnSettingChanged" Unchecked="OnSettingChanged"/>

                    <CheckBox x:Name="ChkStreamerMode" 
                               Content="{DynamicResource EnableStreamerMode}" 
                               Margin="0,0,0,12" 
                               Style="{StaticResource DotCheckBox}"
                               Checked="OnSettingChanged" Unchecked="OnSettingChanged"
                               ToolTip="{DynamicResource StreamerModeToolTip}"/>

                    <CheckBox x:Name="ChkBackgroundTracking" 
                               Content="{DynamicResource BackgroundTracking}" 
                               Margin="0,0,0,12" 
                               Style="{StaticResource DotCheckBox}"
                               Checked="OnSettingChanged" Unchecked="OnSettingChanged"
                               ToolTip="{DynamicResource BackgroundTrackingToolTip}"/>

                    <CheckBox x:Name="ChkHideConsole" 
                               Content="{DynamicResource HideSystemConsole}" 
                               Margin="0,0,0,12" 
                               Style="{StaticResource DotCheckBox}"
                               Checked="OnSettingChanged" Unchecked="OnSettingChanged"
                               ToolTip="{DynamicResource HideConsoleToolTip}"/>

                    <TextBlock Text="{DynamicResource MapSettings}" Foreground="{DynamicResource Accent}" FontWeight="Bold" Margin="0,10,0,10"/>
                    
                    <CheckBox x:Name="ChkAutoLoadShops" 
                               Content="{DynamicResource AutoLoadShops}" 
                               Margin="0,0,0,12" 
                               Style="{StaticResource DotCheckBox}"
                               Checked="OnSettingChanged" Unchecked="OnSettingChanged"
                               ToolTip="{DynamicResource AutoLoadShopsToolTip}"/>

                    <!-- Chat Section -->
                    <TextBlock Text="{DynamicResource Chat}" Foreground="{DynamicResource Accent}" FontWeight="Bold" Margin="0,10,0,10"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="{DynamicResource ModifyChatAlerts}" 
                                Style="{StaticResource PrimaryButton}"
                                Background="#3D5A80"
                                Height="36"
                                Padding="32,0"
                                Click="BtnModifyChatAlerts_Click"/>
                        <Button Content="{DynamicResource ChatCommands}" 
                                Style="{StaticResource PrimaryButton}"
                                Background="#3D5A80"
                                Height="36"
                                Margin="12,0,0,0"
                                Padding="32,0"
                                Click="BtnChatCommands_Click"/>
                    </StackPanel>

                    <TextBlock Text="{DynamicResource SteamAccount}" Foreground="{DynamicResource Accent}" FontWeight="Bold" Margin="0,10,0,10"/>
                    <TextBlock Text="{DynamicResource ManageSteamAccountInfo}" 
                               Foreground="{DynamicResource TextSubtle}" 
                               FontSize="12" 
                               FontStyle="Italic"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
