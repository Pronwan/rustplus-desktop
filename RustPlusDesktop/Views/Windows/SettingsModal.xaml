<Window x:Class="RustPlusDesk.Views.SettingsModal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:properties="clr-namespace:RustPlusDesk.Properties"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="{DynamicResource AppSettingsTitle}" 
        Width="500" Height="520"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="True" 
        WindowStyle="None"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True">
    
    <Window.Resources>
        <!-- ========= Ultra-Slim Scrollbars ========= -->
        <SolidColorBrush x:Key="ScrollbarTrackBrush" Color="#141820"/>
        <SolidColorBrush x:Key="ScrollbarThumbBrush" Color="#2C3548"/>
        <SolidColorBrush x:Key="ScrollbarThumbBrushHover" Color="#3A4663"/>
        <SolidColorBrush x:Key="ScrollbarThumbBrushActive" Color="#4C5A7A"/>

        <Style x:Key="SlimThumb" TargetType="{x:Type Thumb}">
            <Setter Property="Background" Value="{StaticResource ScrollbarThumbBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="B" Background="{TemplateBinding Background}" CornerRadius="2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="{StaticResource ScrollbarThumbBrushHover}"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="B" Property="Background" Value="{StaticResource ScrollbarThumbBrushActive}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid SnapsToDevicePixels="True">
                            <Border Background="{StaticResource ScrollbarTrackBrush}" CornerRadius="2"/>
                            <Track x:Name="PART_Track"
                                   Orientation="{TemplateBinding Orientation}"
                                   IsDirectionReversed="True" Focusable="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Opacity="0" IsHitTestVisible="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Opacity="0" IsHitTestVisible="False"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SlimThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="4"/>
                    <Setter Property="Margin" Value="0,2,2,2"/>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="4"/>
                    <Setter Property="Margin" Value="2,0,2,2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Border Background="{DynamicResource Surface}" 
            BorderBrush="{DynamicResource CardBorder}" 
            BorderThickness="1" 
            CornerRadius="12">
        <DockPanel Margin="20">
            <!-- Header -->
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,15">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:SymbolIcon Symbol="Settings24" Margin="0,0,8,0" Foreground="{DynamicResource Accent}" VerticalAlignment="Center" FontSize="20"/>
                        <TextBlock Text="{DynamicResource Settings}" 
                                   Foreground="{DynamicResource TextPrimary}" 
                                   FontSize="18" 
                                   FontWeight="SemiBold" 
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <ui:Button HorizontalAlignment="Right" 
                               VerticalAlignment="Center" 
                               Padding="4"
                               Appearance="Transparent"
                               Click="BtnClose_Click"
                               Icon="{ui:SymbolIcon Symbol=Dismiss24}"/>
                </Grid>
                <Separator Background="{DynamicResource CardBorder}" Margin="0,10,0,0"/>
            </StackPanel>

            <!-- Footer -->
            <ui:Button DockPanel.Dock="Bottom" 
                       Content="{DynamicResource Close}" 
                       Width="100" 
                       Height="32"
                       HorizontalAlignment="Right"
                       Appearance="Primary"
                       Click="BtnClose_Click"
                       Margin="0,15,0,0"/>

            <!-- Content -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{StaticResource {x:Type ScrollViewer}}">
                <StackPanel>
                    <!-- General Section -->
                    <TextBlock Text="{DynamicResource General}" Style="{StaticResource SectionTitle}" Foreground="{DynamicResource Accent}"/>
                    <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource Language}" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}"/>
                                <ComboBox Grid.Column="1" x:Name="CmbLanguage" Width="150" 
                                          DisplayMemberPath="Name" SelectedValuePath="Code"
                                          SelectionChanged="CmbLanguage_SelectionChanged"/>
                            </Grid>
                            
                            <CheckBox x:Name="ChkAutoStart" 
                                      Content="{DynamicResource LaunchWithWindows}" 
                                      Margin="0,0,0,10" 
                                      Style="{StaticResource DotCheckBox}"
                                      Checked="OnSettingChanged" Unchecked="OnSettingChanged"/>

                            <CheckBox x:Name="ChkStartMinimized" 
                                      Content="{DynamicResource StartMinimizedAlways}" 
                                      Margin="0,0,0,10" 
                                      Style="{StaticResource DotCheckBox}"
                                      Checked="OnSettingChanged" Unchecked="OnSettingChanged"/>

                            <CheckBox x:Name="ChkAutoConnect" 
                                      Content="{DynamicResource AutoConnectLastServer}" 
                                      Style="{StaticResource DotCheckBox}"
                                      Checked="OnSettingChanged" Unchecked="OnSettingChanged"
                                      ToolTip="{DynamicResource AutoConnectToolTip}"/>
                        </StackPanel>
                    </Border>

                    <!-- Behavior Section -->
                    <TextBlock Text="{DynamicResource Behavior}" Style="{StaticResource SectionTitle}" Foreground="{DynamicResource Accent}"/>
                    <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                        <StackPanel>
                            <CheckBox x:Name="ChkCloseToTray" 
                                      Content="{DynamicResource MinimizeToTray}" 
                                      Margin="0,0,0,10" 
                                      Style="{StaticResource DotCheckBox}"
                                      Checked="OnSettingChanged" Unchecked="OnSettingChanged"/>

                            <CheckBox x:Name="ChkStreamerMode" 
                                      Content="{DynamicResource EnableStreamerMode}" 
                                      Margin="0,0,0,10" 
                                      Style="{StaticResource DotCheckBox}"
                                      Checked="OnSettingChanged" Unchecked="OnSettingChanged"
                                      ToolTip="{DynamicResource StreamerModeToolTip}"/>

                            <CheckBox x:Name="ChkBackgroundTracking" 
                                      Content="{DynamicResource BackgroundTracking}" 
                                      Margin="0,0,0,10" 
                                      Style="{StaticResource DotCheckBox}"
                                      Checked="OnSettingChanged" Unchecked="OnSettingChanged"
                                      ToolTip="{DynamicResource BackgroundTrackingToolTip}"/>

                            <CheckBox x:Name="ChkHideConsole" 
                                      Content="{DynamicResource HideSystemConsole}" 
                                      Style="{StaticResource DotCheckBox}"
                                      Checked="OnSettingChanged" Unchecked="OnSettingChanged"
                                      ToolTip="{DynamicResource HideConsoleToolTip}"/>
                        </StackPanel>
                    </Border>

                    <!-- Map Section -->
                    <TextBlock Text="{DynamicResource MapSettings}" Style="{StaticResource SectionTitle}" Foreground="{DynamicResource Accent}"/>
                    <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                        <CheckBox x:Name="ChkAutoLoadShops" 
                                  Content="{DynamicResource AutoLoadShops}" 
                                  Style="{StaticResource DotCheckBox}"
                                  Checked="OnSettingChanged" Unchecked="OnSettingChanged"
                                  ToolTip="{DynamicResource AutoLoadShopsToolTip}"/>
                    </Border>

                    <!-- Chat Section -->
                    <TextBlock Text="{DynamicResource Chat}" Style="{StaticResource SectionTitle}" Foreground="{DynamicResource Accent}"/>
                    <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:Button x:Name="BtnModifyChatAlerts"
                                       Grid.Column="0"
                                       Content="{DynamicResource ModifyChatAlerts}" 
                                       Icon="{ui:SymbolIcon Symbol=Alert24}"
                                       HorizontalAlignment="Stretch"
                                       Height="36"
                                       Margin="0,0,6,0"
                                       Click="BtnModifyChatAlerts_Click"/>
                            <ui:Button x:Name="BtnChatCommands"
                                       Grid.Column="1"
                                       Content="{DynamicResource ChatCommands}" 
                                       Icon="{ui:SymbolIcon Symbol=Chat24}"
                                       HorizontalAlignment="Stretch"
                                       Height="36"
                                       Margin="6,0,0,0"
                                       Click="BtnChatCommands_Click"/>
                        </Grid>
                    </Border>

                    <!-- Steam Account Section -->
                    <TextBlock Text="{DynamicResource SteamAccount}" Style="{StaticResource SectionTitle}" Foreground="{DynamicResource Accent}"/>
                    <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Person24" Margin="0,0,10,0" Foreground="{DynamicResource TextSubtle}" VerticalAlignment="Center" FontSize="18"/>
                            <TextBlock Text="{DynamicResource ManageSteamAccountInfo}" 
                                       Foreground="{DynamicResource TextSubtle}" 
                                       FontSize="12" 
                                       FontStyle="Italic"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
