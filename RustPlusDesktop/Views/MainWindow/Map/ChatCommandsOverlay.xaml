<UserControl x:Class="RustPlusDesk.Views.ChatCommandsOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="400">
    <Border Visibility="Visible" Background="#F0141F2D" Padding="20" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,15">
                <TextBlock Text="Chat Commands Settings" FontSize="16" FontWeight="SemiBold" Foreground="White" />
                <Button HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Click="BtnClose_Click" Foreground="#888" FontSize="16" Content="✕" />
            </Grid>
            
            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel DataContext="{Binding Selected}">
                    <CheckBox Content="Enable Chat Commands" IsChecked="{Binding ChatCommandsEnabled}" Margin="0,0,0,15" FontWeight="SemiBold" />
                    
                    <TextBlock Text="Standard Commands" Foreground="#8090A0" Margin="0,0,0,5" FontWeight="SemiBold" />
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Population:" VerticalAlignment="Center" Foreground="White" />
                        <TextBlock Grid.Column="1" Text="!" VerticalAlignment="Center" Foreground="#8090A0" FontWeight="Bold" Margin="0,0,4,0" />
                        <TextBox Grid.Column="2" Text="{Binding CmdPop}" Background="#2A2E35" Foreground="White" BorderThickness="0" Padding="5,2" />
                    </Grid>
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Time:" VerticalAlignment="Center" Foreground="White" />
                        <TextBlock Grid.Column="1" Text="!" VerticalAlignment="Center" Foreground="#8090A0" FontWeight="Bold" Margin="0,0,4,0" />
                        <TextBox Grid.Column="2" Text="{Binding CmdTime}" Background="#2A2E35" Foreground="White" BorderThickness="0" Padding="5,2" />
                    </Grid>
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Promote:" VerticalAlignment="Center" Foreground="White" />
                        <TextBlock Grid.Column="1" Text="!" VerticalAlignment="Center" Foreground="#8090A0" FontWeight="Bold" Margin="0,0,4,0" />
                        <TextBox Grid.Column="2" Text="{Binding CmdPromote}" Background="#2A2E35" Foreground="White" BorderThickness="0" Padding="5,2" />
                    </Grid>
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Deep Sea:" VerticalAlignment="Center" Foreground="White" />
                        <TextBlock Grid.Column="1" Text="!" VerticalAlignment="Center" Foreground="#8090A0" FontWeight="Bold" Margin="0,0,4,0" />
                        <TextBox Grid.Column="2" Text="{Binding CmdDeepSea}" Background="#2A2E35" Foreground="White" BorderThickness="0" Padding="5,2" />
                    </Grid>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Cargo Ship:" VerticalAlignment="Center" Foreground="White" />
                        <TextBlock Grid.Column="1" Text="!" VerticalAlignment="Center" Foreground="#8090A0" FontWeight="Bold" Margin="0,0,4,0" />
                        <TextBox Grid.Column="2" Text="{Binding CmdCargo}" Background="#2A2E35" Foreground="White" BorderThickness="0" Padding="5,2" />
                    </Grid>
                    
                    <StackPanel IsEnabled="{Binding HasSmartSwitches}">
                        <TextBlock Text="Smart Switches" Foreground="#8090A0" Margin="0,0,0,5" FontWeight="SemiBold" />
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Switch 1:" VerticalAlignment="Center" Foreground="White" />
                            <TextBlock Grid.Column="1" Text="!" VerticalAlignment="Center" Foreground="#8090A0" FontWeight="Bold" Margin="0,0,4,0" />
                            <TextBox Grid.Column="2" Text="{Binding CmdSwitch1}" Background="#2A2E35" Foreground="White" BorderThickness="0" Padding="5,2" Margin="0,0,10,0" />
                            <ComboBox Grid.Column="3" ItemsSource="{Binding SmartSwitches}" SelectedValue="{Binding BoundSwitchId1}" SelectedValuePath="EntityId" DisplayMemberPath="Name" Style="{StaticResource DarkComboBox}" />
                        </Grid>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Switch 2:" VerticalAlignment="Center" Foreground="White" />
                            <TextBlock Grid.Column="1" Text="!" VerticalAlignment="Center" Foreground="#8090A0" FontWeight="Bold" Margin="0,0,4,0" />
                            <TextBox Grid.Column="2" Text="{Binding CmdSwitch2}" Background="#2A2E35" Foreground="White" BorderThickness="0" Padding="5,2" Margin="0,0,10,0" />
                            <ComboBox Grid.Column="3" ItemsSource="{Binding SmartSwitches}" SelectedValue="{Binding BoundSwitchId2}" SelectedValuePath="EntityId" DisplayMemberPath="Name" Style="{StaticResource DarkComboBox}" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
            
            <!-- Footer -->
            <Button Grid.Row="2" Content="Save &amp; Close" Margin="0,15,0,0" Style="{StaticResource PrimaryButton}" Click="BtnClose_Click" HorizontalAlignment="Right" Width="120" />
        </Grid>
    </Border>
</UserControl>
