<UserControl x:Class="RustPlusDesk.Views.ChatCommandsOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:p="clr-namespace:RustPlusDesk.Properties"
             Background="{DynamicResource AppBg}"
             Foreground="{DynamicResource TextPrimary}">
    <Border Background="{DynamicResource Surface}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="12" Margin="10">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,15">
                <TextBlock Text="{x:Static p:Resources.ChatCommandsSettings}" FontSize="16" FontWeight="SemiBold" Foreground="White" />
                <Button HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Click="BtnClose_Click" Foreground="#888" FontSize="16" Content="✕" />
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Grid Margin="0,0,0,15">
                        <CheckBox Content="{x:Static p:Resources.EnableChatCommands}" IsChecked="{Binding ChatCommandsEnabled}" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="{x:Static p:Resources.Prefix}" Foreground="#8090A0" VerticalAlignment="Center" Margin="0,0,5,0" />
                            <ComboBox x:Name="CmbPrefix" SelectedValue="{Binding ChatCommandPrefix}" Width="60" Background="#2A2E35" Foreground="White" BorderThickness="0">
                                <ComboBoxItem Content="!" />
                                <ComboBoxItem Content="." />
                                <ComboBoxItem Content="," />
                                <ComboBoxItem Content="\" />
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="{x:Static p:Resources.StandardCommands}" Foreground="#8090A0" Margin="0,0,0,5" FontWeight="SemiBold" />
                    <Border Background="#1E2228" CornerRadius="8" Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="30" />
                                <RowDefinition Height="30" />
                                <RowDefinition Height="30" />
                                <RowDefinition Height="30" />
                                <RowDefinition Height="30" />
                                <RowDefinition Height="30" />
                                <RowDefinition Height="30" />
                                <RowDefinition Height="30" />
                                <RowDefinition Height="30" />
                                <RowDefinition Height="30" />
                            </Grid.RowDefinitions>

                            <!-- Population -->
                            <TextBlock Grid.Row="0" Text="{x:Static p:Resources.Population}" VerticalAlignment="Center" Foreground="White" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ChatCommandPrefix}" VerticalAlignment="Center" Foreground="#8090A0" FontWeight="Bold" Margin="0,0,4,0" />
                            <TextBox Grid.Row="0" Grid.Column="2" Text="{Binding CmdPop}" Background="#2A2E35" Foreground="White" BorderThickness="0" Padding="5,2" />

                            <!-- Time -->
                            <TextBlock Grid.Row="1" Text="{x:Static p:Resources.Time}" VerticalAlignment="Center" Foreground="White" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ChatCommandPrefix}" VerticalAlignment="Center" Foreground="#8090A0" FontWeight="Bold" Margin="0,0,4,0" />
                            <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding CmdTime}" Background="#2A2E35" Foreground="White" BorderThickness="0" Padding="5,2" />

                            <!-- Promote -->
                            <TextBlock Grid.Row="2" Text="{x:Static p:Resources.Promote}" VerticalAlignment="Center" Foreground="White" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ChatCommandPrefix}" VerticalAlignment="Center" Foreground="#8090A0" FontWeight="Bold" Margin="0,0,4,0" />
                            <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding CmdPromote}" Background="#2A2E35" Foreground="White" BorderThickness="0" Padding="5,2" />

                            <!-- Deep Sea -->
                            <TextBlock Grid.Row="3" Text="{x:Static p:Resources.DeepSeaCommand}" VerticalAlignment="Center" Foreground="White" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ChatCommandPrefix}" VerticalAlignment="Center" Foreground="#8090A0" FontWeight="Bold" Margin="0,0,4,0" />
                            <TextBox Grid.Row="3" Grid.Column="2" Text="{Binding CmdDeepSea}" Background="#2A2E35" Foreground="White" BorderThickness="0" Padding="5,2" />

                            <!-- Cargo -->
                            <TextBlock Grid.Row="4" Text="{x:Static p:Resources.CargoShipCommand}" VerticalAlignment="Center" Foreground="White" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ChatCommandPrefix}" VerticalAlignment="Center" Foreground="#8090A0" FontWeight="Bold" Margin="0,0,4,0" />
                            <TextBox Grid.Row="4" Grid.Column="2" Text="{Binding CmdCargo}" Background="#2A2E35" Foreground="White" BorderThickness="0" Padding="5,2" />

                            <!-- Oil Rig -->
                            <TextBlock Grid.Row="5" Text="{x:Static p:Resources.OilRigCommand}" VerticalAlignment="Center" Foreground="White" />
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding ChatCommandPrefix}" VerticalAlignment="Center" Foreground="#8090A0" FontWeight="Bold" Margin="0,0,4,0" />
                            <TextBox Grid.Row="5" Grid.Column="2" Text="{Binding CmdOilRig}" Background="#2A2E35" Foreground="White" BorderThickness="0" Padding="5,2" />

                            <!-- Heli -->
                            <TextBlock Grid.Row="6" Text="{x:Static p:Resources.PatrolHeliCommand}" VerticalAlignment="Center" Foreground="White" />
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding ChatCommandPrefix}" VerticalAlignment="Center" Foreground="#8090A0" FontWeight="Bold" Margin="0,0,4,0" />
                            <TextBox Grid.Row="6" Grid.Column="2" Text="{Binding CmdHeli}" Background="#2A2E35" Foreground="White" BorderThickness="0" Padding="5,2" />

                            <!-- Vendor -->
                            <TextBlock Grid.Row="7" Text="{x:Static p:Resources.TravellingVendorCommand}" VerticalAlignment="Center" Foreground="White" />
                            <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding ChatCommandPrefix}" VerticalAlignment="Center" Foreground="#8090A0" FontWeight="Bold" Margin="0,0,4,0" />
                            <TextBox Grid.Row="7" Grid.Column="2" Text="{Binding CmdVendor}" Background="#2A2E35" Foreground="White" BorderThickness="0" Padding="5,2" />

                            <!-- Upkeep Detail -->
                            <TextBlock Grid.Row="8" Text="{x:Static p:Resources.UpkeepDetails}" VerticalAlignment="Center" Foreground="White" />
                            <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding ChatCommandPrefix}" VerticalAlignment="Center" Foreground="#8090A0" FontWeight="Bold" Margin="0,0,4,0" />
                            <TextBox Grid.Row="8" Grid.Column="2" Text="{Binding CmdUpkeepDetail}" Background="#2A2E35" Foreground="White" BorderThickness="0" Padding="5,2" />

                            <!-- Delay -->
                            <TextBlock Grid.Row="9" Text="{x:Static p:Resources.CommandDelay}" VerticalAlignment="Center" Foreground="White" />
                            <ComboBox Grid.Row="9" Grid.Column="2" SelectedValue="{Binding ChatCommandDelay}" Background="#2A2E35" Foreground="White" BorderThickness="0">
                                <ComboBoxItem Content="1" />
                                <ComboBoxItem Content="2" />
                                <ComboBoxItem Content="3" />
                                <ComboBoxItem Content="4" />
                                <ComboBoxItem Content="5" />
                            </ComboBox>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
