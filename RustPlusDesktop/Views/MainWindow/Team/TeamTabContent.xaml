<UserControl
    x:Class="RustPlusDesk.Views.TeamTabContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:RustPlusDesk.Converters">
    <Grid Background="#181A1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.Resources>
            <conv:BoolToVisibilityConverter x:Key="Vis" />
            <conv:BoolToVisibilityConverter x:Key="VisInv" Invert="True" />
            <Style x:Key="Card" TargetType="Border">
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Background" Value="#FF141F2D" />
                <Setter Property="Padding" Value="8" />
                <Setter Property="Margin" Value="6" />
            </Style>
        </Grid.Resources>
        <ListBox
            x:Name="TeamList"
            Grid.Row="0"
            HorizontalContentAlignment="Stretch"
            ItemsSource="{Binding TeamMembers, RelativeSource={RelativeSource AncestorType=Window}}"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.Resources>
                <ContextMenu x:Key="TeamContextMenu" Style="{StaticResource DarkContextMenu}">
                    <MenuItem Click="Team_Center_Click" Header="{DynamicResource CenterOnMap}" />
                    <MenuItem Click="Team_Follow_Click" Header="{DynamicResource FollowOnMap}" />
                    <MenuItem Click="Team_OpenProfile_Click" Header="{DynamicResource OpenSteamProfile}" />
                    <Separator />
                    <MenuItem Click="Team_Promote_Click" Header="{DynamicResource PromoteToLeader}" />
                    <MenuItem Click="Team_Kick_Click" Header="{DynamicResource KickFromTeam}" />
                </ContextMenu>
            </ListBox.Resources>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Width" Value="210" />
                    <Setter Property="Margin" Value="6" />
                    <EventSetter Event="MouseLeftButtonUp" Handler="TeamItem_MouseLeftButtonUp" />
                    <Setter Property="ContextMenu" Value="{StaticResource TeamContextMenu}" />
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="56" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid Width="44" Height="44">
                                <Image
                                    ClipToBounds="True"
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    Source="{Binding Avatar}"
                                    Stretch="UniformToFill" />
                                <Ellipse
                                    Width="12"
                                    Height="12"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Fill="#4CAF50"
                                    Stroke="Black"
                                    Visibility="{Binding IsOnline, Converter={StaticResource Vis}}" />
                                <Ellipse
                                    Width="12"
                                    Height="12"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Fill="#666"
                                    Stroke="Black"
                                    Visibility="{Binding IsOnline, Converter={StaticResource VisInv}}" />
                                <Path
                                    Width="20"
                                    Height="20"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Data="M 10,1 12,7 19,7 13,11 15,18 10,14 5,18 7,11 1,7 8,7 z"
                                    Fill="Gold"
                                    Stroke="Black"
                                    Visibility="{Binding IsLeader, Converter={StaticResource Vis}}" />
                            </Grid>
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock FontSize="14" FontWeight="SemiBold">
                                    <TextBlock.Text>
                                        <Binding Path="DisplayName" />
                                    </TextBlock.Text>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="White" />
                                            <Setter Property="Opacity" Value="1" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDead}" Value="True">
                                                    <Setter Property="Foreground" Value="#EF5350" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                                    <Setter Property="Opacity" Value="0.55" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock
                                    FontSize="11"
                                    Foreground="White"
                                    Opacity="0.65"
                                    Text="{Binding DisplaySteamId}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <Grid Grid.Row="1" Margin="0,10,0,0">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <CheckBox
                    x:Name="ChkProfileMarkers"
                    Margin="0,0,12,0"
                    Checked="ChkProfileMarkers_Toggled"
                    IsChecked="True"
                    Style="{StaticResource DotCheckBox}"
                    Unchecked="ChkProfileMarkers_Toggled">
                    <StackPanel Orientation="Horizontal">
                        <Grid
                            Width="20"
                            Height="20"
                            Margin="0,0,6,0">
                            <Ellipse
                                Width="18"
                                Height="18"
                                Stroke="Black"
                                StrokeThickness="1"
                                Visibility="{Binding IsChecked, ElementName=ChkProfileMarkers, Converter={StaticResource BoolToVisibility}}">
                                <Ellipse.Fill>
                                    <ImageBrush ImageSource="{Binding MyAvatar}" Stretch="UniformToFill" />
                                </Ellipse.Fill>
                            </Ellipse>
                            <Ellipse
                                Width="10"
                                Height="10"
                                Fill="LimeGreen"
                                Stroke="Black"
                                StrokeThickness="1.5"
                                Visibility="{Binding IsChecked, ElementName=ChkProfileMarkers, Converter={StaticResource BoolToVisibilityInv}}" />
                        </Grid>
                        <TextBlock VerticalAlignment="Center" Text="{DynamicResource ProfileMarkers}" />
                    </StackPanel>
                </CheckBox>
                <CheckBox
                    x:Name="ChkDeathMarkers"
                    Margin="0,0,12,0"
                    Checked="ChkDeathMarkers_Toggled"
                    IsChecked="False"
                    Style="{StaticResource DotCheckBox}"
                    Unchecked="ChkDeathMarkers_Toggled">
                    <StackPanel Orientation="Horizontal">
                        <Grid
                            Width="20"
                            Height="20"
                            Margin="0,0,6,0">
                            <Grid Visibility="{Binding IsChecked, ElementName=ChkDeathMarkers, Converter={StaticResource BoolToVisibility}}">
                                <Path
                                    Width="16"
                                    Height="20"
                                    Data="M20,0 C31,0 40,9 40,20 C40,33 20,56 20,56 C20,56 0,33 0,20 C0,9 9,0 20,0 Z"
                                    Fill="IndianRed"
                                    Stretch="Uniform"
                                    Stroke="Black"
                                    StrokeThickness="1" />
                                <Ellipse
                                    Width="10"
                                    Height="10"
                                    Margin="0,0,0,5">
                                    <Ellipse.Fill>
                                        <ImageBrush ImageSource="{Binding MyAvatar}" Stretch="UniformToFill" />
                                    </Ellipse.Fill>
                                </Ellipse>
                            </Grid>
                            <Ellipse
                                Width="10"
                                Height="10"
                                Fill="#444"
                                Stroke="#666"
                                StrokeThickness="1.5"
                                Visibility="{Binding IsChecked, ElementName=ChkDeathMarkers, Converter={StaticResource BoolToVisibilityInv}}" />
                        </Grid>
                        <TextBlock VerticalAlignment="Center" Text="{DynamicResource DeathMarkers}" />
                    </StackPanel>
                </CheckBox>
                <ToggleButton x:Name="BtnAbbreviateNames"
                              Margin="0,0,12,0"
                              Width="24" Height="24"
                              ToolTip="{DynamicResource StreamerMode}"
                              Checked="BtnAbbreviateNames_Toggled"
                              Unchecked="BtnAbbreviateNames_Toggled">
                    <ToggleButton.Style>
                        <Style TargetType="ToggleButton">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="BorderBrush" Value="#444"/>
                            <Setter Property="Foreground" Value="#CCC"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="3">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#222"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Background" Value="#1C4B82"/>
                                    <Setter Property="BorderBrush" Value="#2A6CA6"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ToggleButton.Style>
                    <TextBlock Text="A..." FontSize="10" FontWeight="Bold" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                </ToggleButton>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource ScaleLabel}" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="#AAA" FontSize="10"/>
                    <Slider x:Name="SliderPlayerIconSize" 
                            Width="50" Minimum="0.5" Maximum="1.5" Value="1.0" 
                            TickFrequency="0.05" IsSnapToTickEnabled="True" 
                            ValueChanged="SliderPlayerIconSize_ValueChanged"
                            VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Value, ElementName=SliderPlayerIconSize, StringFormat={}{0:P0}}" 
                               VerticalAlignment="Center" Margin="4,0,0,0" Foreground="#AAA" FontSize="10" Width="30"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
