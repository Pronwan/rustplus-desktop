<UserControl x:Class="RustPlusDesktop.Views.CheaterAnalyticsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:RustPlusDesktop.ViewModels"
             Background="#1A1A2E" Foreground="White" FontFamily="Segoe UI">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- header + summary metrics -->
            <RowDefinition Height="Auto"/>   <!-- add record form -->
            <RowDefinition Height="*"/>      <!-- records list -->
        </Grid.RowDefinitions>

        <!-- ═══ HEADER / METRICS ═══ -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="&#x1F6E1; Server Cheater Analytics"
                       FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/><ColumnDefinition/>
                    <ColumnDefinition/><ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <!-- Active Players -->
                <Border Grid.Column="0" Background="#252540" CornerRadius="6" Margin="2" Padding="8">
                    <StackPanel>
                        <TextBlock Text="Players" FontSize="10" Foreground="#AAAACC"/>
                        <TextBlock Text="{Binding Current.ActivePlayerCount}"
                                   FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Confirmed Cheaters -->
                <Border Grid.Column="1" Background="#2E1515" CornerRadius="6" Margin="2" Padding="8">
                    <StackPanel>
                        <TextBlock Text="Confirmed" FontSize="10" Foreground="#FFAAAA"/>
                        <TextBlock Text="{Binding Current.ConfirmedCheaterCount}"
                                   FontSize="22" FontWeight="Bold" Foreground="#FF6060"/>
                    </StackPanel>
                </Border>

                <!-- Suspected -->
                <Border Grid.Column="2" Background="#2E2515" CornerRadius="6" Margin="2" Padding="8">
                    <StackPanel>
                        <TextBlock Text="Suspected" FontSize="10" Foreground="#FFDDAA"/>
                        <TextBlock Text="{Binding Current.SuspectedFlaggedCount}"
                                   FontSize="22" FontWeight="Bold" Foreground="#FFA040"/>
                    </StackPanel>
                </Border>

                <!-- Ratio % -->
                <Border Grid.Column="3" Background="#1E2E1E" CornerRadius="6" Margin="2" Padding="8">
                    <StackPanel>
                        <TextBlock Text="Risk %" FontSize="10" Foreground="#AACCAA"/>
                        <TextBlock FontSize="22" FontWeight="Bold">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0:F1}%">
                                    <Binding Path="Current.CheaterRatioPercent"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Risk Band pill -->
            <Border CornerRadius="4" Margin="0,6,0,0" Padding="8,4" HorizontalAlignment="Left">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Current.RiskBand}" Value="Low">
                                <Setter Property="Background" Value="#1E5C1E"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Current.RiskBand}" Value="Moderate">
                                <Setter Property="Background" Value="#5C5C1E"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Current.RiskBand}" Value="High">
                                <Setter Property="Background" Value="#5C3A1E"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Current.RiskBand}" Value="Critical">
                                <Setter Property="Background" Value="#5C1E1E"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock>
                    <Run Text="Risk Level: "/>
                    <Run Text="{Binding Current.RiskBand}" FontWeight="Bold"/>
                </TextBlock>
            </Border>
        </StackPanel>

        <!-- ═══ ADD RECORD FORM ═══ -->
        <Expander Grid.Row="1" Header="&#x2795; Flag a Player" Margin="0,0,0,8"
                  Foreground="White" BorderBrush="#444466">
            <Grid Margin="4,8,4,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBox Grid.Row="0" Grid.Column="0" Margin="2"
                         Text="{Binding NewSteamId, UpdateSourceTrigger=PropertyChanged}"
                         Tag="Steam ID (17 digits)" Style="{StaticResource DarkTextBox}"/>
                <TextBox Grid.Row="0" Grid.Column="1" Margin="2"
                         Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}"
                         Tag="Display Name" Style="{StaticResource DarkTextBox}"/>

                <ComboBox Grid.Row="1" Grid.Column="0" Margin="2"
                          ItemsSource="{Binding ConfidenceLevels}"
                          SelectedItem="{Binding NewConfidence}"
                          Style="{StaticResource DarkComboBox}"/>
                <ComboBox Grid.Row="1" Grid.Column="1" Margin="2"
                          ItemsSource="{Binding FlagSources}"
                          SelectedItem="{Binding NewSource}"
                          Style="{StaticResource DarkComboBox}"/>

                <TextBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="2"
                         Text="{Binding NewNotes, UpdateSourceTrigger=PropertyChanged}"
                         Tag="Evidence notes…" MaxLength="500"
                         Style="{StaticResource DarkTextBox}"/>

                <TextBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="1" Margin="2"
                         Text="{Binding NewEvidenceLink, UpdateSourceTrigger=PropertyChanged}"
                         Tag="Evidence link (optional)" Style="{StaticResource DarkTextBox}"/>
                <Button Grid.Row="3" Grid.Column="1" Margin="2" Content="&#x1F50D; Flag + Steam Lookup"
                        Command="{Binding AddRecordCommand}"
                        Style="{StaticResource PrimaryButton}"/>
            </Grid>
        </Expander>

        <!-- ═══ RECORDS LIST ═══ -->
        <ListView Grid.Row="2" ItemsSource="{Binding Records}"
                  Background="Transparent" BorderThickness="0">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="#252540" CornerRadius="5" Margin="0,2" Padding="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock FontWeight="SemiBold">
                                    <Run Text="{Binding DisplayName}"/>
                                    <Run Foreground="#8888AA" FontSize="10"
                                         Text="{Binding SteamId, StringFormat=' ({0})'}"/>
                                </TextBlock>
                                <WrapPanel Margin="0,2">
                                    <!-- Confidence badge -->
                                    <Border CornerRadius="3" Padding="4,1" Margin="0,0,4,0">
                                        <TextBlock Text="{Binding Confidence}" FontSize="10"/>
                                    </Border>
                                    <!-- VAC badge -->
                                    <Border CornerRadius="3" Padding="4,1" Margin="0,0,4,0"
                                            Background="#5C1E1E"
                                            Visibility="{Binding HasVacBan,
                                                Converter={StaticResource BoolToVisible}}">
                                        <TextBlock Text="VAC" FontSize="10" Foreground="#FF8888"/>
                                    </Border>
                                    <!-- Game Ban badge -->
                                    <Border CornerRadius="3" Padding="4,1" Margin="0,0,4,0"
                                            Background="#3C1E1E"
                                            Visibility="{Binding HasGameBan,
                                                Converter={StaticResource BoolToVisible}}">
                                        <TextBlock Text="Game Ban" FontSize="10" Foreground="#FFAAAA"/>
                                    </Border>
                                    <!-- Report count -->
                                    <TextBlock FontSize="10" Foreground="#AAAACC" Margin="4,0">
                                        <Run Text="Reports: "/>
                                        <Run Text="{Binding ReportCount}"/>
                                    </TextBlock>
                                </WrapPanel>
                                <TextBlock Text="{Binding EvidenceNotes}"
                                           FontSize="10" Foreground="#888899"
                                           TextWrapping="Wrap" MaxWidth="280"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0,0,0">
                                <Button Content="&#x2713; Confirm"
                                        Command="{Binding DataContext.ConfirmBanCommand,
                                            RelativeSource={RelativeSource AncestorType=ListView}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource SmallDangerButton}"
                                        Margin="0,0,0,4"/>
                                <Button Content="&#x1F5D1;"
                                        Command="{Binding DataContext.DeleteRecordCommand,
                                            RelativeSource={RelativeSource AncestorType=ListView}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource SmallGhostButton}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
