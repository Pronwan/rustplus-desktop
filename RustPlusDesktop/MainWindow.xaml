                                            <DropShadowEffect BlurRadius="18" Color="Black" Opacity="0.65" ShadowDepth="4" />
                                        </Border.Effect>
                                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,12">
                                                    <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="White" Text="Map layers" />
                                                    <ui:SymbolIcon HorizontalAlignment="Right" Symbol="Filter20" Foreground="{DynamicResource TextSubtle}" />
                                                </Grid>

                                                <TextBlock Margin="0,0,0,8" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource Accent}" Text="MONUMENTS" />
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="160" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" Text="Display" />
                                                    <ComboBox
                                                        x:Name="CmbLayerMonumentStyle"
                                                        Grid.Column="1"
                                                        Height="30"
                                                        SelectionChanged="CmbLayerMonumentStyle_SelectionChanged">
                                                        <ComboBoxItem Content="Icons" />
                                                        <ComboBoxItem Content="Names" />
                                                    </ComboBox>
                                                </Grid>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="70" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="48" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" Text="Scale" />
