                                                FontFamily="Segoe MDL2 Assets"
                                                FontSize="12"
                                                Text="&#xE721;" />
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                Text="{DynamicResource Shops}" />
                                        </StackPanel>
                                    </Button>
                                </Border>
                            </Grid>
                        </Border>

                        <!--  Recycling Calculator Overlay  -->
