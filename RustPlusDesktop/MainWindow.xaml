                            <ui:Button.Content>
                                <TextBlock Margin="8,0,0,0" Text="{DynamicResource FcmInfoToolTip}" />
                            </ui:Button.Content>
                        </ui:Button>

                        <TextBlock
                            Margin="0,20,0,0"
                            FontSize="11"
                            Foreground="{DynamicResource TextCaption}"
                            Text="Uses your Rust+ / Steam login in the browser. Cloud sign-in is not required."
