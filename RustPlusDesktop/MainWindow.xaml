                    Background="#0B3A4A"
                    ClipToBounds="True">
                    <Rectangle x:Name="SplashBgColor" Fill="#0B3A4A" />

                    <Border
                        x:Name="MapPlaceholder"
                        Panel.ZIndex="50"
                        Background="#0B3A4A">
                        <Border
                            Padding="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="#40101518"
                            BorderBrush="#66FFFFFF"
                            BorderThickness="1"
                            CornerRadius="16">
                            <StackPanel MaxWidth="320">
                                <TextBlock
                                    FontSize="20"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Text="Connect to a server to see the map"
                                    TextAlignment="Center"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    Margin="0,10,0,0"
                                    FontSize="13"
                                    Foreground="#D9FFFFFF"
                                    Text="Once connected, the live Rust map will load here."
                                    TextAlignment="Center"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Border>

                    <!--  2) Titelbild als &#x201E;contain&#x201C;, zentriert, unverzerrt  -->
                    <Image
                        x:Name="SplashBg"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        IsHitTestVisible="False"
                        Opacity="0.95"
                        Source="pack://application:,,,/Assets/Images/TitleScreen-rust-plus-desktop.png"
                        Stretch="Uniform"
                        Visibility="Collapsed" />
                    <Image
                        x:Name="ImgMap"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        RenderOptions.BitmapScalingMode="HighQuality"
                        Stretch="None" />

                    <!--  TIME OVERLAY (Top Left)  -->
                    <Border
                        x:Name="TimeOverlay"
                        Margin="15"
                        Padding="8,4"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Panel.ZIndex="1000"
                        Background="#AA16181C"
                        BorderBrush="#40FFFFFF"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Orientation="Horizontal">
                            <!--  Unknown Time Icon (Clock)  -->
                            <TextBlock
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="14"
                                Foreground="#8D98A8"
                                Text="&#xE916;">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ServerTime}" Value="-">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ServerTime}" Value="–">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ServerTime}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ServerTime}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!--  Day Icon  -->
                            <TextBlock
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="14"
                                Foreground="#FFD166"
                                Text="&#xE706;">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDay}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <!--  Hide if unknown  -->
                                            <DataTrigger Binding="{Binding ServerTime}" Value="-">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ServerTime}" Value="–">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!--  Night Icon  -->
                            <TextBlock
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="14"
                                Foreground="#A5B4FC"
                                Text="&#xE708;">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDay}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <!--  Hide if unknown  -->
                                            <DataTrigger Binding="{Binding ServerTime}" Value="-">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ServerTime}" Value="–">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="{Binding ServerTime}" />
                                <TextBlock
                                    Margin="0,-1,0,0"
                                    FontSize="9"
                                    Foreground="#8D98A8"
                                    Text="{Binding TimeUntilNextPhase}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TimeUntilNextPhase}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!--  LIVE EVENT DOCK (Top Right)  -->
                    <StackPanel
                        x:Name="EventDock"
                        Margin="15"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Panel.ZIndex="100"
                        Orientation="Vertical" />

                    <Canvas x:Name="GridLayer" IsHitTestVisible="False" />
                    <Canvas x:Name="Overlay" IsHitTestVisible="True" />

                    <!--  Shop Details Panel (Clamped to Map Container)  -->
                    <Border
                        x:Name="ShopDetailsPopup"
                        Width="340"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Panel.ZIndex="1100"
                        Background="#1E2126"
                        BorderBrush="#60FFFFFF"
                        BorderThickness="1"
                        CornerRadius="12"
                        Visibility="Collapsed">
                        <Border.Effect>
                            <DropShadowEffect
                                BlurRadius="15"
                                Opacity="0.6"
                                ShadowDepth="0"
                                Color="Black" />
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Button
                                x:Name="BtnCloseShopDetails"
                                Width="30"
                                Height="30"
                                HorizontalAlignment="Right"
                                Panel.ZIndex="10"
                                Click="BtnCloseShopDetails_Click"
                                Content="&#x2715;"
                                FontSize="14"
                                Foreground="Gray"
                                Style="{StaticResource GhostButton}" />

                            <ScrollViewer
                                x:Name="ShopDetailsScroll"
                                Grid.Row="1"
                                MaxHeight="600"
                                HorizontalScrollBarVisibility="Disabled"
                                VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="ShopDetailsContent" Margin="12,4,12,12" />
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!--  Integrated Shop Search Overlay (Roll-up)  -->
                    <Border
                        x:Name="ShopSearchPanel"
                        Width="400"
                        Margin="0,0,12,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Panel.ZIndex="1000"
                        Background="Transparent">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border
                                x:Name="ShopSearchContent"
                                Grid.Row="0"
                                Height="540"
                                Background="#16181C"
                                BorderBrush="#40FFFFFF"
                                BorderThickness="1"
                                CornerRadius="12"
                                RenderTransformOrigin="0.5,1"
                                Visibility="Collapsed">
                                <Border.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform x:Name="ShopSearchScale" ScaleY="1" />
                                        <TranslateTransform x:Name="ShopSearchTranslate" Y="0" />
                                    </TransformGroup>
                                </Border.RenderTransform>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="30" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <!--  Header / Drag / Close Area  -->
                                    <Grid Grid.Row="0" Background="#1E2126">
                                        <TextBlock
                                            Margin="12,0,0,0"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            FontSize="10"
                                            FontWeight="Bold"
                                            Foreground="#60FFFFFF"
                                            Text="SHOP SEARCH" />

                                        <Button
                                            x:Name="BtnCloseShopSearch"
                                            Width="26"
                                            Height="26"
                                            Margin="0,0,4,0"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Click="BtnCloseShopSearch_Click"
                                            Content="&#x2715;"
                                            Cursor="Hand"
                                            FontSize="12"
                                            Foreground="#99FFFFFF"
                                            Style="{StaticResource GhostButton}"
                                            ToolTip="Close Search">
                                            <Button.Resources>
                                                <Style BasedOn="{StaticResource GhostButton}" TargetType="Button">
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Foreground" Value="White" />
                                                            <Setter Property="Background" Value="#20FFFFFF" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                    </Grid>

                                    <wv2:WebView2 x:Name="EmbeddedShopSearch" Grid.Row="1" />
                                </Grid>
                            </Border>

                            <Border
                                x:Name="BtnShopToggleBorder"
                                Grid.Row="1"
                                Width="160"
                                Height="26"
                                HorizontalAlignment="Right"
                                Background="#16181C"
                                BorderBrush="#40FFFFFF"
                                BorderThickness="1,1,1,0"
                                CornerRadius="8,8,0,0">
                                <Button
                                    x:Name="BtnShopToggle"
                                    Padding="0"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Click="BtnShopSearch_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border
                                                x:Name="border"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="8,8,0,0">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#30FFFFFF" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock
                                            Margin="0,0,6,0"
                                            VerticalAlignment="Center"
                                            FontFamily="Segoe MDL2 Assets"
                                            FontSize="12"
                                            Text="&#xE721;" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Text="Shop Search" />
                                    </StackPanel>
                                </Button>
                            </Border>
                        </Grid>
                    </Border>

                    <Border
                        x:Name="OverlayToolbox"
                        Grid.Row="1"
                        Margin="8"
                        Padding="6"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Panel.ZIndex="9000"
                        Background="#CC1E1E1E"
                        CornerRadius="6"
                        Visibility="Collapsed">
                        <StackPanel>

                            <!--  Zeichnen  -->
                            <Button
                                x:Name="ToolDrawButton"
                                Width="32"
                                Height="32"
                                Click="ToolDrawButton_Click"
                                PreviewMouseRightButtonDown="ToolDrawButton_RightClick"
                                ToolTip="Draw (Right Click: Size / Color)">
                                <Image Source="pack://application:,,,/Assets/icons/pen.png" />
                            </Button>

                            <!--  Text  -->
                            <Button
                                x:Name="ToolTextButton"
                                Width="32"
                                Height="32"
                                Click="ToolTextButton_Click"
                                PreviewMouseRightButtonDown="ToolTextButton_RightClick"
                                ToolTip="Place Text (Right Click: Color / Size)">
                                <Image Source="pack://application:,,,/Assets/icons/text.png" />
                            </Button>

                            <!--  Icons  -->
                            <Button
                                x:Name="ToolIconButton"
                                Width="32"
                                Height="32"
                                Click="ToolIconButton_Click"
                                PreviewMouseRightButtonDown="ToolIconButton_RightClick"
                                ToolTip="Place Icon (Right Click: Pick Icon)">
                                <Image Source="pack://application:,,,/Assets/icons/pin.png" />
                            </Button>

                            <!--  Radierer  -->
                            <Button
                                x:Name="ToolEraseButton"
                                Width="32"
                                Height="32"
                                Click="ToolEraseButton_Click"
                                PreviewMouseRightButtonDown="ToolEraseButton_RightClick"
                                ToolTip="Eraser (hold or click)">
                                <Image Source="pack://application:,,,/Assets/icons/eraser.png" />
                            </Button>

                            <Separator />

                            <!--  LÃ¶schen  -->
                            <Button
                                x:Name="ToolTrashButton"
                                Width="32"
                                Height="32"
                                Click="ToolTrashButton_Click"
                                ToolTip="Delete own overlay">
                                <Image Source="pack://application:,,,/Assets/icons/trash.png" />
                            </Button>

                            <!--  Upload / Teilen  -->
                            <Button
                                x:Name="ToolUploadButton"
                                Width="32"
                                Height="32"
                                Click="ToolUploadButton_Click"
                                ToolTip="Upload own Overlay / share">
                                <Image Source="pack://application:,,,/Assets/icons/upload.png" />
                            </Button>

                        </StackPanel>
                    </Border>

                    <Border
                        x:Name="OverlayTeamBar"
                        Grid.Row="1"
                        Margin="0,0,0,8"
                        Padding="4"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Panel.ZIndex="9000"
                        Background="#801E1E1E"
                        CornerRadius="6"
                        Visibility="Collapsed">
                        <StackPanel
                            x:Name="OverlayTeamStack"
                            Margin="4"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <!--  Buttons fÃ¼r Team-Mitglieder werden dynamisch in CodeBehind eingefÃ¼gt  -->
                        </StackPanel>
                    </Border>
                </Grid>

                <TextBox
                    x:Name="TxtLog"
                    Grid.Row="2"
                    Height="100"
                    IsReadOnly="True"
                    TextWrapping="Wrap"
                    VerticalScrollBarVisibility="Auto" />
            </Grid>
        </Border>
        <Grid
            Panel.ZIndex="9999"
            Background="#80000000"
            IsHitTestVisible="True"
            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <Border
                Width="320"
                Padding="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#F2FFFFFF"
                CornerRadius="8">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,10"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Text="{Binding BusyText}"
                        TextAlignment="Center" />
                    <ProgressBar Height="6" IsIndeterminate="True" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid
            Panel.ZIndex="9999"
            Background="#80000000"
            IsHitTestVisible="True"
            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <Border
                Width="320"
                Padding="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource AccentDark}"
                CornerRadius="8">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,10"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Text="{Binding BusyText}"
                        TextAlignment="Center" />
                    <ProgressBar Height="6" IsIndeterminate="True" />
                </StackPanel>
            </Border>
        </Grid>


    </Grid>
</Window>
