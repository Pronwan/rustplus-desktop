<ui:FluentWindow
    x:Class="RustPlusDesk.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:RustPlusDesk.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:diag="clr-namespace:System.Diagnostics;assembly=WindowsBase"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:p="clr-namespace:RustPlusDesk.Properties"
    xmlns:services="clr-namespace:RustPlusDesk.Services"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:views="clr-namespace:RustPlusDesk.Views"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    Title="{x:Static p:Resources.AppTitle}"
    Width="1600"
    Height="814"
    MinWidth="1300"
    MinHeight="700"
    Background="{DynamicResource AppBg}"
    ExtendsContentIntoTitleBar="True"
    Foreground="{DynamicResource TextPrimary}"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    mc:Ignorable="d">
    <ui:FluentWindow.Resources>
        <conv:UpkeepBackgroundConverter x:Key="UpkeepBackgroundConverter" />
        <conv:StorageChipConverter x:Key="StorageChipConverter" />
        <conv:KindToStorageVisibilityConverter x:Key="KindToStorageVisibility" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityInv" Invert="True" />
        <conv:LessThanConverter x:Key="LessThanConverter" />
        <BitmapImage x:Key="IconStorageMonitor" UriSource="pack://application:,,,/Assets/icons/storagemonitor.png" />
        <BitmapImage x:Key="IconSmartSwitch" UriSource="pack://application:,,,/Assets/icons/smartswitch.png" />
        <BitmapImage x:Key="IconSmartAlarm" UriSource="pack://application:,,,/Assets/icons/smartalarm.png" />
        <BitmapImage x:Key="IconGroup" UriSource="pack://application:,,,/Assets/icons/cabins.png" />
        <!--  WinUI 3 Design Palette  -->
        <SolidColorBrush x:Key="AppBg" Color="#0F1013" />
        <SolidColorBrush x:Key="Surface" Color="#181B1F" />
        <SolidColorBrush x:Key="SurfaceAlt" Color="#1F2229" />
        <SolidColorBrush x:Key="SurfaceHover" Color="#252A33" />
        <SolidColorBrush x:Key="CardBorder" Color="#28FFFFFF" />
        <SolidColorBrush x:Key="Accent" Color="#60CDFF" />
        <SolidColorBrush x:Key="AccentDark" Color="#1A4D6B" />
        <SolidColorBrush x:Key="AccentGreen" Color="#4EB887" />
        <SolidColorBrush x:Key="AccentRed" Color="#F04747" />

        <SolidColorBrush x:Key="TextPrimary" Color="#F0F3F7" />
        <SolidColorBrush x:Key="TextSubtle" Color="#8C96A8" />
        <SolidColorBrush x:Key="TextCaption" Color="#5A6475" />
        <CornerRadius x:Key="Radius">8</CornerRadius>

        <!--  Card / Tab styles  -->
        <SolidColorBrush x:Key="CardBrush" Color="#181B20" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#1EFFFFFF" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#3B82F6" />
        <SolidColorBrush x:Key="PrimaryBrushMuted" Color="#1D4ED8" />
        <SolidColorBrush x:Key="TextBrush" Color="#E8ECF4" />
        <SolidColorBrush x:Key="TextBrushMuted" Color="#8C96A8" />

        <Style x:Key="PrettyTabControl" TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <Grid KeyboardNavigation.TabNavigation="Local" SnapsToDevicePixels="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!--  Genau EIN ItemsHost (TabPanel), ohne Kinder  -->
                            <TabPanel
                                x:Name="HeaderPanel"
                                Grid.Row="0"
                                Margin="8,8,8,0"
                                Panel.ZIndex="1"
                                IsItemsHost="True" />

                            <!--  Inhalt  -->
                            <Border
                                Grid.Row="1"
                                Margin="8,0,8,8"
                                Padding="12"
                                Background="{StaticResource CardBrush}"
                                BorderBrush="{StaticResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14">
                                <ContentPresenter x:Name="PART_SelectedContentHost" ContentSource="SelectedContent" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!--  HEADER-TEMPLATE: Border + Popup gemeinsam in einem Grid  -->
        <ControlTemplate x:Key="DarkMenuItem_Header" TargetType="MenuItem">
            <Grid>
                <!--  <<< ein gemeinsames Root  -->
                <Border
                    x:Name="Bd"
                    Padding="{TemplateBinding Padding}"
                    Background="{TemplateBinding Background}"
                    CornerRadius="6"
                    SnapsToDevicePixels="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                        </Grid.ColumnDefinitions>

                        <!--  Dot indicator for checkable headers  -->
                        <Ellipse
                            x:Name="CheckedDot"
                            Grid.Column="0"
                            Width="8"
                            Height="8"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Fill="{DynamicResource Accent}"
                            Visibility="Collapsed" />

                        <ContentPresenter
                            Grid.Column="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            ContentSource="Icon" />

                        <ContentPresenter
                            Grid.Column="1"
                            Margin="4,0,6,0"
                            VerticalAlignment="Center"
                            ContentSource="Header"
                            RecognizesAccessKey="True" />

                        <Path
                            Grid.Column="2"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Data="M 0 0 L 4 4 L 0 8"
                            Stroke="{DynamicResource TextSubtle}"
                            StrokeEndLineCap="Round"
                            StrokeStartLineCap="Round"
                            StrokeThickness="1.5" />
                    </Grid>
                </Border>

                <!--  Submenu-Popup  -->
                <Popup
                    x:Name="PART_Popup"
                    AllowsTransparency="True"
                    Focusable="False"
                    HorizontalOffset="0"
                    IsOpen="{TemplateBinding IsSubmenuOpen}"
                    Placement="Right"
                    StaysOpen="False"
                    VerticalOffset="0">
                    <Border
                        Padding="6"
                        Background="{DynamicResource Surface}"
                        BorderBrush="{DynamicResource CardBorder}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource Radius}"
                        SnapsToDevicePixels="True">
                        <ScrollViewer CanContentScroll="True">
                            <StackPanel IsItemsHost="True" />
                        </ScrollViewer>
                    </Border>
                </Popup>
            </Grid>

            <ControlTemplate.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="CheckedDot" Property="Visibility" Value="Visible" />
                    <Setter Property="Foreground" Value="{DynamicResource Accent}" />
                </Trigger>
                <Trigger Property="Tag" Value="Partial">
                    <Setter TargetName="CheckedDot" Property="Visibility" Value="Visible" />
                    <Setter TargetName="CheckedDot" Property="Opacity" Value="0.6" />
                    <Setter TargetName="CheckedDot" Property="Width" Value="5" />
                    <Setter TargetName="CheckedDot" Property="Height" Value="5" />
                </Trigger>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#141A22" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="{DynamicResource TextSubtle}" />
                    <Setter TargetName="Bd" Property="Opacity" Value="0.6" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Pill-shaped Toggle Button for Map Filters -->
        <Style x:Key="PillToggleButton" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextSubtle}" />
            <Setter Property="Background" Value="#1AFFFFFF" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border
                            x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="#2AFFFFFF"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3D4B5C" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Accent}" />
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="12" Color="#60CDFF" Opacity="0.5" ShadowDepth="0" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="{x:Null}">
                                <Setter TargetName="Bd" Property="Background" Value="#4B3D2B" />
                                <Setter Property="Foreground" Value="#FFCA00" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FFB900" />
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="12" Color="#FFB900" Opacity="0.5" ShadowDepth="0" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2AFFFFFF" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#40FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  ITEM-TEMPLATE (Leaf) with Standard Checkboxes  -->
        <ControlTemplate x:Key="DarkMenuItem_Item" TargetType="MenuItem">
            <Border
                x:Name="Bd"
                Padding="{TemplateBinding Padding}"
                Background="{TemplateBinding Background}"
                CornerRadius="6"
                SnapsToDevicePixels="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Checkbox Icon (Segoe MDL2) -->
                    <TextBlock
                        x:Name="CheckIcon"
                        Grid.Column="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="14"
                        Foreground="{DynamicResource TextSubtle}"
                        Text="&#xE739;" />

                    <ContentPresenter
                        Grid.Column="1"
                        Margin="6,0,6,0"
                        VerticalAlignment="Center"
                        ContentSource="Header"
                        RecognizesAccessKey="True" />
                </Grid>
            </Border>

            <ControlTemplate.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="CheckIcon" Property="Text" Value="&#xE73B;" />
                    <Setter TargetName="CheckIcon" Property="Foreground" Value="{DynamicResource Accent}" />
                    <Setter Property="Foreground" Value="{DynamicResource Accent}" />
                </Trigger>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#1AFFFFFF" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="{DynamicResource TextSubtle}" />
                    <Setter TargetName="Bd" Property="Opacity" Value="0.6" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="DarkMenuItem" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template" Value="{StaticResource DarkMenuItem_Item}" />
            <Style.Triggers>
                <Trigger Property="HasItems" Value="True">
                    <Setter Property="Template" Value="{StaticResource DarkMenuItem_Header}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  dunkler Separator  -->
        <Style x:Key="DarkSeparator" TargetType="Separator">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border
                            Height="1"
                            Margin="6,6,6,6"
                            Background="#22FFFFFF" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  dunkles ContextMenu-GehÃ¤use  -->
        <Style x:Key="DarkContextMenu" TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource Surface}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="HasDropShadow" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border
                            Padding="6"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource CardBorder}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource Radius}"
                            SnapsToDevicePixels="True">
                            <StackPanel IsItemsHost="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  TabItem: echte &#x201E;Reiter&#x201C;-Optik mit eckigem FuÃŸ, bÃ¼ndig zur Card  -->
        <Style x:Key="PrettyTabItem" TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0" />
            <!--  kein Abstand zwischen Reitern  -->
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border
                            x:Name="TabHeader"
                            Padding="12,6"
                            Background="#11151B"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1,1,1,0"
                            CornerRadius="10,10,0,0"
                            SnapsToDevicePixels="True">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                ContentSource="Header" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabHeader" Property="Background" Value="#151A22" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Panel.ZIndex" Value="1" />

                                <Setter TargetName="TabHeader" Property="Margin" Value="0,0,0,-1" />
                                <Setter TargetName="TabHeader" Property="Background" Value="{StaticResource CardBrush}" />
                                <Setter TargetName="TabHeader" Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  SekundÃ¤r-Button (unten im Tab)  -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#141821" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="BtnBg"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBg" Property="Background" Value="#1A2130" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBg" Property="Background" Value="#0F1320" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  PrimÃ¤r-Button (CHAT)  -->
        <Style
            x:Key="PrimaryButton"
            BasedOn="{StaticResource GhostButton}"
            TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrushMuted}" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <!--  ========= Ultra-Slim Scrollbars =========  -->
        <SolidColorBrush x:Key="ScrollbarTrackBrush" Color="#141820" />
        <SolidColorBrush x:Key="ScrollbarThumbBrush" Color="#2C3548" />
        <SolidColorBrush x:Key="ScrollbarThumbBrushHover" Color="#3A4663" />
        <SolidColorBrush x:Key="ScrollbarThumbBrushActive" Color="#4C5A7A" />

        <Style x:Key="SlimThumb" TargetType="{x:Type Thumb}">
            <Setter Property="Background" Value="{StaticResource ScrollbarThumbBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border
                            x:Name="B"
                            Background="{TemplateBinding Background}"
                            CornerRadius="2" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="{StaticResource ScrollbarThumbBrushHover}" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="B" Property="Background" Value="{StaticResource ScrollbarThumbBrushActive}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="Transparent" />
            <!--  wichtig, damit schmaler als Systembreite mÃ¶glich  -->
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid SnapsToDevicePixels="True">
                            <Border Background="{StaticResource ScrollbarTrackBrush}" CornerRadius="2" />
                            <Track
                                x:Name="PART_Track"
                                Focusable="False"
                                IsDirectionReversed="True"
                                Orientation="{TemplateBinding Orientation}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton IsHitTestVisible="False" Opacity="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton IsHitTestVisible="False" Opacity="0" />
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SlimThumb}" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <!--  Breite/HÃ¶he hier anpassen: 4 => super schlank; 2 => &#x201E;hairline&#x201C;  -->
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="4" />
                    <Setter Property="Margin" Value="0,2,2,2" />
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="4" />
                    <Setter Property="Margin" Value="2,0,2,2" />
                </Trigger>
            </Style.Triggers>
        </Style>


        <!--  Default-Text  -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        </Style>
        <SolidColorBrush x:Key="CbBg" Color="#202428" />
        <SolidColorBrush x:Key="CbBorder" Color="#5A6672" />
        <SolidColorBrush x:Key="CbHover" Color="#7F8A96" />
        <SolidColorBrush x:Key="CbAccent" Color="#62D38B" />
        <SolidColorBrush x:Key="CbDisabled" Color="#334049" />
        <SolidColorBrush x:Key="CbText" Color="#EAEFF3" />

        <SolidColorBrush x:Key="DonateYellow" Color="#FFD166" />
        <SolidColorBrush x:Key="DonateYellowHover" Color="#FFDE89" />
        <SolidColorBrush x:Key="DonateYellowPressed" Color="#FFBE4C" />
        <SolidColorBrush x:Key="DonateTextDark" Color="#1A1E22" />

        <!--  Runde gelbe Accent-Button  -->
        <Style x:Key="DonateButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource DonateTextDark}" />
            <Setter Property="Background" Value="{StaticResource DonateYellow}" />
            <Setter Property="BorderBrush" Value="#26000000" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10"
                            SnapsToDevicePixels="True">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource DonateYellowHover}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource DonateYellowPressed}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  ðŸ”˜ Runde Checkbox mit Punkt  -->
        <Style x:Key="DotCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource CbText}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!--  Bullet  -->
                            <Grid
                                Width="18"
                                Height="18"
                                Margin="0,0,8,0">
                                <!--  Rahmen-Kreis  -->
                                <Ellipse
                                    x:Name="Circle"
                                    Width="18"
                                    Height="18"
                                    Fill="Transparent"
                                    Stroke="{StaticResource CbBorder}"
                                    StrokeThickness="2" />
                                <!--  Punkt  -->
                                <Ellipse
                                    x:Name="Dot"
                                    Width="10"
                                    Height="10"
                                    Fill="{StaticResource CbAccent}">
                                    <Ellipse.RenderTransform>
                                        <ScaleTransform x:Name="DotScale" CenterX="5" CenterY="5" ScaleX="0" ScaleY="0" />
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                            </Grid>

                            <!--  Text/Content  -->
                            <ContentPresenter
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True" />

                            <!--  Visual States  -->
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="MouseOver">
                                        <Storyboard>
                                            <ColorAnimation
                                                Storyboard.TargetName="Circle"
                                                Storyboard.TargetProperty="(Shape.Stroke).(SolidColorBrush.Color)"
                                                To="#7F8A96"
                                                Duration="0:0:0.08" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <ColorAnimation
                                                Storyboard.TargetName="Circle"
                                                Storyboard.TargetProperty="(Shape.Stroke).(SolidColorBrush.Color)"
                                                To="#334049"
                                                Duration="0:0:0" />
                                            <DoubleAnimation
                                                Storyboard.TargetName="DotScale"
                                                Storyboard.TargetProperty="ScaleX"
                                                To="0"
                                                Duration="0:0:0" />
                                            <DoubleAnimation
                                                Storyboard.TargetName="DotScale"
                                                Storyboard.TargetProperty="ScaleY"
                                                To="0"
                                                Duration="0:0:0" />
                                            <DoubleAnimation
                                                Storyboard.TargetName="Circle"
                                                Storyboard.TargetProperty="Opacity"
                                                To="0.6"
                                                Duration="0:0:0" />
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>

                                <VisualStateGroup x:Name="CheckStates">
                                    <VisualState x:Name="Unchecked" />
                                    <VisualState x:Name="Checked">
                                        <Storyboard>
                                            <ColorAnimation
                                                Storyboard.TargetName="Circle"
                                                Storyboard.TargetProperty="(Shape.Stroke).(SolidColorBrush.Color)"
                                                To="#62D38B"
                                                Duration="0:0:0.08" />
                                            <DoubleAnimation
                                                Storyboard.TargetName="DotScale"
                                                Storyboard.TargetProperty="ScaleX"
                                                To="1"
                                                Duration="0:0:0.10" />
                                            <DoubleAnimation
                                                Storyboard.TargetName="DotScale"
                                                Storyboard.TargetProperty="ScaleY"
                                                To="1"
                                                Duration="0:0:0.10" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Indeterminate">
                                        <Storyboard>
                                            <ColorAnimation
                                                Storyboard.TargetName="Circle"
                                                Storyboard.TargetProperty="(Shape.Stroke).(SolidColorBrush.Color)"
                                                To="#62D38B"
                                                Duration="0:0:0.08" />
                                            <DoubleAnimation
                                                Storyboard.TargetName="DotScale"
                                                Storyboard.TargetProperty="ScaleX"
                                                To="0.5"
                                                Duration="0:0:0.10" />
                                            <DoubleAnimation
                                                Storyboard.TargetName="DotScale"
                                                Storyboard.TargetProperty="ScaleY"
                                                To="0.5"
                                                Duration="0:0:0.10" />
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!--  Button: rund, dezent Hover/Pressed  -->
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="Background" Value="{DynamicResource SurfaceAlt}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{DynamicResource Radius}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Surface}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentDark}" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentDark}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Icon-Button (z.B. Lupe)  -->
        <Style
            x:Key="IconButton"
            BasedOn="{StaticResource {x:Type Button}}"
            TargetType="Button">
            <Setter Property="Padding" Value="6" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
        </Style>

        <!--  CheckBox dunkel  -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        </Style>

        <!--  TextBox dunkel  -->
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="Background" Value="{DynamicResource SurfaceAlt}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border
                            x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{DynamicResource Radius}">
                            <ScrollViewer x:Name="PART_ContentHost" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Accent}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  ListBox dunkel + dezente Auswahl  -->
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource SurfaceAlt}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border
                            x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6">
                            <ContentPresenter Margin="4,2" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#264FC3F7" />
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1AFFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Log/TextBox Multiline  -->
        <Style TargetType="{x:Type ScrollViewer}">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <!--  Card-Container zum Wiederverwenden  -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Surface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{DynamicResource Radius}" />
            <Setter Property="Padding" Value="12" />
        </Style>

        <!--  Abschnittstitel  -->
        <Style
            x:Key="SectionTitle"
            BasedOn="{StaticResource {x:Type TextBlock}}"
            TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <conv:NotNullToBoolConverter x:Key="NotNull" />

        <DataTemplate x:Key="TrackedPlayerTemplate" DataType="{x:Type services:TrackedPlayer}">
            <Grid
                x:Name="PlayerRow"
                Margin="0,2"
                Background="Transparent">
                <Grid.ContextMenu>
                    <ContextMenu Style="{StaticResource DarkContextMenu}">
                        <MenuItem
                            Click="BtnViewTracked_Click"
                            Header="{x:Static p:Resources.ViewProfile}"
                            Icon="{ui:SymbolIcon Symbol=Eye24}">
                            <MenuItem.Style>
                                <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBMOnly}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </MenuItem.Style>
                        </MenuItem>

                        <MenuItem
                            Click="BtnGroupTracked_Click"
                            Header="{x:Static p:Resources.ChangeGroup}"
                            Icon="{ui:SymbolIcon Symbol=Folder24}" />
                        <MenuItem
                            Click="BtnRenameTracked_Click"
                            Header="{x:Static p:Resources.Rename}"
                            Icon="{ui:SymbolIcon Symbol=Edit24}" />
                        <Separator />
                        <MenuItem
                            Click="BtnRemoveTracked_Click"
                            Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                            Header="{x:Static p:Resources.RemoveTracked}"
                            Icon="{ui:SymbolIcon Symbol=Delete24}" />
                    </ContextMenu>
                </Grid.ContextMenu>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Player Info  -->
                <StackPanel
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Ellipse
                        x:Name="StatusDot"
                        Width="8"
                        Height="8"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        Fill="#666666" />
                    <TextBlock
                        x:Name="TxtName"
                        VerticalAlignment="Center"
                        FontSize="13"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{Binding Name}"
                        TextTrimming="CharacterEllipsis"
                        ToolTip="{Binding Name}" />
                </StackPanel>

                <!--  Timestamp / Playtime  -->
                <TextBlock
                    x:Name="TxtPlayTime"
                    Grid.Column="1"
                    Margin="8,0,8,0"
                    VerticalAlignment="Center"
                    FontSize="10"
                    Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                    Text="{Binding PlayTimeStr}"
                    Visibility="Collapsed" />

                <!--  Actions  -->
                <StackPanel
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <ui:Button
                        x:Name="BtnViewAction"
                        Padding="8,2"
                        Appearance="Transparent"
                        Click="BtnViewTracked_Click"
                        Content="{x:Static p:Resources.View}"
                        FontSize="11"
                        Tag="{Binding BMId}" />

                    <ui:Button
                        x:Name="BtnMore"
                        Padding="4"
                        Appearance="Transparent"
                        Click="BtnMore_Click"
                        Icon="{ui:SymbolIcon Symbol=MoreHorizontal24}"
                        Opacity="0"
                        ToolTip="{x:Static p:Resources.MoreOptions}" />
                </StackPanel>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsOnline}" Value="True">
                    <Setter TargetName="StatusDot" Property="Fill" Value="#62D38B" />
                    <Setter TargetName="TxtName" Property="Foreground" Value="White" />
                    <Setter TargetName="TxtPlayTime" Property="Visibility" Value="Visible" />
                </DataTrigger>
                <Trigger SourceName="PlayerRow" Property="IsMouseOver" Value="True">
                    <Setter TargetName="BtnMore" Property="Opacity" Value="1" />
                </Trigger>
                <DataTrigger Binding="{Binding IsBMOnly}" Value="True">
                    <Setter TargetName="BtnViewAction" Property="Content" Value="View on BM" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Custom TitleBar for Guaranteed Visibility in Mica/Dark Mode  -->
        <Border
            Grid.Row="0"
            Background="#0F1013"
            BorderBrush="#1AFFFFFF"
            BorderThickness="0,0,0,1">
            <ui:TitleBar
                x:Name="AppTitleBar"
                Title="{x:Static p:Resources.AppTitle}"
                Background="Transparent"
                Foreground="White">
                <ui:TitleBar.Icon>
                    <ui:ImageIcon Source="pack://application:,,,/Assets/rustplus-desktop-icon.ico" />
                </ui:TitleBar.Icon>
            </ui:TitleBar>
        </Border>

        <Grid
            x:Name="Root"
            Grid.Row="1"
            Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition
                    x:Name="ColSidebar"
                    Width="600"
                    MinWidth="400"
                    MaxWidth="600" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" MinWidth="800" />
            </Grid.ColumnDefinitions>

            <GridSplitter
                Grid.Column="1"
                Width="8"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="Transparent"
                DragCompleted="SidebarSplitter_DragCompleted"
                ResizeBehavior="PreviousAndNext"
                ResizeDirection="Columns"
                ShowsPreview="False" />

            <!--  Left Panel  -->
            <Border
                Grid.Column="0"
                MinWidth="400"
                MaxWidth="600"
                Margin="0,0,0,0"
                Padding="16"
                Background="{DynamicResource Surface}"
                BorderBrush="#1AFFFFFF"
                BorderThickness="0,0,1,0"
                CornerRadius="0"
                TextElement.FontFamily="Segoe UI Variable Display, Segoe UI">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="24"
                        Opacity="0.35"
                        ShadowDepth="0"
                        Color="#000000" />
                </Border.Effect>
                <Grid>
                    <DockPanel x:Name="LeftPanelContent" LastChildFill="True">

                    <!--  TOP: Account + Serverliste  -->
                    <StackPanel DockPanel.Dock="Top">
                        <!--  Header  -->
                        <Border
                            Margin="0,0,0,10"
                            Padding="10,8"
                            Background="{DynamicResource SurfaceAlt}"
                            BorderBrush="{DynamicResource CardBorder}"
                            BorderThickness="1"
                            CornerRadius="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!--  Profile Picture / Icon  -->
                                <Grid
                                    Grid.Column="0"
                                    Width="32"
                                    Height="32"
                                    Margin="0,0,10,0">
                                    <Border
                                        Background="#1AFFFFFF"
                                        ClipToBounds="True"
                                        CornerRadius="16">
                                        <Grid>
                                            <ui:SymbolIcon
                                                FontSize="18"
                                                Foreground="White"
                                                Opacity="0.4"
                                                Symbol="Person24" />
                                            <Image
                                                x:Name="ImgSteam"
                                                Source="{Binding MyAvatar}"
                                                Stretch="UniformToFill">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding MyAvatar}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <!--  Identity  -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <DockPanel>
                                        <TextBlock
                                            x:Name="TxtSteamName"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Foreground="White"
                                            Text="{x:Static p:Resources.SteamAccount}" />
                                        <TextBlock
                                            x:Name="TxtAppVersion"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Bottom"
                                            FontSize="10"
                                            Foreground="White"
                                            Opacity="0.4"
                                            Text="v0.0.0" />
                                    </DockPanel>
                                    <TextBlock
                                        x:Name="TxtSteamId"
                                        FontSize="9"
                                        Foreground="White"
                                        Opacity="0.6"
                                        Text="{x:Static p:Resources.NotLoggedIn}" />
                                </StackPanel>

                                <!--  Action Buttons  -->
                                <StackPanel
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                                    <Grid>
                                        <ui:Button
                                            x:Name="BtnCheckUpdates"
                                            Appearance="Transparent"
                                            Click="BtnCheckUpdates_Click"
                                            MouseEnter="BtnCheckUpdates_MouseEnter"
                                            MouseLeave="BtnCheckUpdates_MouseLeave"
                                            ToolTip="{x:Static p:Resources.CheckForUpdates}">
                                            <ui:Button.Icon>
                                                <ui:SymbolIcon Symbol="ArrowDownload24">
                                                    <ui:SymbolIcon.Style>
                                                        <Style TargetType="ui:SymbolIcon">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsDownloadingUpdate}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ui:SymbolIcon.Style>
                                                </ui:SymbolIcon>
                                            </ui:Button.Icon>
                                            <ui:Button.Style>
                                                <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="ui:Button">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUpdateAvailable}" Value="True">
                                                            <DataTrigger.EnterActions>
                                                                <BeginStoryboard x:Name="GlowStoryboard">
                                                                    <Storyboard RepeatBehavior="Forever">
                                                                        <ColorAnimation
                                                                            AutoReverse="True"
                                                                            Storyboard.TargetProperty="(ui:Button.Foreground).(SolidColorBrush.Color)"
                                                                            From="White"
                                                                            To="#FF00CCFF"
                                                                            Duration="0:0:1" />
                                                                        <DoubleAnimation
                                                                            AutoReverse="True"
                                                                            Storyboard.TargetProperty="(ui:Button.Effect).(DropShadowEffect.Opacity)"
                                                                            From="0"
                                                                            To="1"
                                                                            Duration="0:0:1" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.EnterActions>
                                                            <DataTrigger.ExitActions>
                                                                <StopStoryboard BeginStoryboardName="GlowStoryboard" />
                                                            </DataTrigger.ExitActions>
                                                            <Setter Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect
                                                                        BlurRadius="15"
                                                                        Opacity="0"
                                                                        ShadowDepth="0"
                                                                        Color="#FF00CCFF" />
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:Button.Style>
                                        </ui:Button>

                                        <!--  Circular Progress Indicator  -->
                                        <ui:ProgressRing
                                            Width="24"
                                            Height="24"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Foreground="{DynamicResource Accent}"
                                            IsHitTestVisible="False"
                                            IsIndeterminate="False"
                                            Progress="{Binding UpdateDownloadProgress}"
                                            Visibility="{Binding IsDownloadingUpdate, Converter={StaticResource BoolToVisibility}}" />

                                        <!--  Percentage Text  -->
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="8"
                                            FontWeight="Bold"
                                            Foreground="White"
                                            IsHitTestVisible="False"
                                            Text="{Binding UpdateDownloadPercentage}"
                                            Visibility="{Binding IsDownloadingUpdate, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock.RenderTransform>
                                                <TranslateTransform Y="1" />
                                            </TextBlock.RenderTransform>
                                        </TextBlock>

                                        <!--  Download Progress Popup (Keep for details on hover)  -->
                                        <Popup
                                            x:Name="UpdateDownloadPopup"
                                            AllowsTransparency="True"
                                            IsOpen="False"
                                            Placement="Bottom"
                                            PlacementTarget="{Binding ElementName=BtnCheckUpdates}"
                                            VerticalOffset="5">
                                            <Border
                                                Width="220"
                                                Padding="12"
                                                Background="#EE1E1E1E"
                                                BorderBrush="#44FFFFFF"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                                <StackPanel>
                                                    <TextBlock
                                                        Margin="0,0,0,8"
                                                        FontWeight="Bold"
                                                        Foreground="White"
                                                        Text="{Binding UpdateTag, StringFormat='Update: {0}'}" />

                                                    <Grid Margin="0,0,0,4">
                                                        <TextBlock
                                                            FontSize="11"
                                                            Foreground="#BBFFFFFF"
                                                            Text="{x:Static p:Resources.Downloading}" />
                                                        <TextBlock
                                                            HorizontalAlignment="Right"
                                                            FontSize="11"
                                                            FontWeight="Bold"
                                                            Foreground="White"
                                                            Text="{Binding UpdateDownloadPercentage}" />
                                                    </Grid>

                                                    <ProgressBar
                                                        Height="4"
                                                        Margin="0,0,0,10"
                                                        Value="{Binding UpdateDownloadProgress}" />

                                                    <Grid>
                                                        <StackPanel>
                                                            <TextBlock
                                                                FontSize="10"
                                                                FontWeight="SemiBold"
                                                                Foreground="#FF00CCFF"
                                                                Text="{Binding UpdateDownloadSpeed}" />
                                                            <TextBlock
                                                                FontSize="10"
                                                                Foreground="#88FFFFFF"
                                                                Text="{Binding UpdateDownloadSize}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </Popup>
                                    </Grid>
                                    <ui:Button
                                        x:Name="BtnDiscord"
                                        Margin="4,0,0,0"
                                        Appearance="Transparent"
                                        Click="BtnDiscord_Click"
                                        ToolTip="{x:Static p:Resources.JoinDiscord}">
                                        <Image
                                            Width="16"
                                            Height="16"
                                            RenderOptions.BitmapScalingMode="HighQuality"
                                            Source="pack://application:,,,/Assets/icons/discord.png" />
                                    </ui:Button>
                                    <ui:Button
                                        x:Name="BtnPatchNotes"
                                        Margin="2,0,0,0"
                                        Padding="6,4"
                                        Appearance="Transparent"
                                        Click="BtnPatchNotes_Click"
                                        Icon="{ui:SymbolIcon Symbol=DocumentBulletList24}"
                                        ToolTip="{x:Static p:Resources.PatchNotes}" />
                                    <ui:Button
                                        x:Name="BtnSettings"
                                        Margin="2,0,0,0"
                                        Padding="6,4"
                                        Appearance="Transparent"
                                        Click="BtnSettings_Click"
                                        Icon="{ui:SymbolIcon Symbol=Settings24}"
                                        ToolTip="{x:Static p:Resources.Settings}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!--  FCM Token Expiry Badge  -->
                        <ui:InfoBar
                            x:Name="FcmExpiryInfoBar"
                            Title="{x:Static p:Resources.FcmCredentials}"
                            Margin="0,0,0,10"
                            IsClosable="False"
                            IsOpen="True"
                            Message="{Binding FcmExpiryText}"
                            Severity="Informational">
                            <ui:InfoBar.Style>
                                <Style TargetType="ui:InfoBar">
                                    <Setter Property="Severity" Value="Informational" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FcmExpiryDays, Converter={StaticResource LessThanConverter}, ConverterParameter=30}" Value="True">
                                            <Setter Property="Severity" Value="Warning" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding FcmExpiryDays}" Value="-1">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:InfoBar.Style>
                        </ui:InfoBar>

                        <Border
                            Height="1"
                            Margin="0,0,0,12"
                            Background="#12FFFFFF" />

                        <TextBlock
                            Margin="0,4,0,6"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextBrushMuted}"
                            Text="{x:Static p:Resources.PairedServers}" />

                        <Grid x:Name="ServerListGrid">
                            <ListBox
                                x:Name="ListServers"
                                MinHeight="60"
                                MaxHeight="100"
                                DisplayMemberPath="Name"
                                Foreground="White"
                                ItemsSource="{Binding Servers}"
                                SelectedItem="{Binding Selected, Mode=TwoWay}"
                                SelectionChanged="ListServers_SelectionChanged">

                                <ListBox.Resources>
                                    <ContextMenu
                                        x:Key="ServerCtx"
                                        Foreground="White"
                                        Style="{StaticResource DarkContextMenu}">
                                        <!--  Der Trick: den aktuellen Server ins Tag binden  -->
                                        <MenuItem
                                            Click="Server_RelinkBM_Click"
                                            Foreground="Black"
                                            Header="{x:Static p:Resources.RelinkBattlemetricsId}"
                                            Tag="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <Separator />
                                        <MenuItem
                                            Click="Server_Delete_Click"
                                            Foreground="Black"
                                            Header="{x:Static p:Resources.DeleteServerEllipsis}"
                                            Tag="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    </ContextMenu>
                                </ListBox.Resources>

                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="ContextMenu" Value="{StaticResource ServerCtx}" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>

                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="12"
                                FontStyle="Italic"
                                Foreground="{StaticResource TextSubtle}"
                                IsHitTestVisible="False"
                                Text="{x:Static p:Resources.NoServersPaired}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Servers.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <!--  Compact Connection Card  -->
                        <Border
                            Margin="0,8,0,0"
                            Padding="12,10"
                            Background="{DynamicResource SurfaceAlt}"
                            BorderBrush="{DynamicResource CardBorder}"
                            BorderThickness="1"
                            CornerRadius="10">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Selected, Converter={StaticResource NotNull}}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <!--  Status Dot  -->
                                    <ColumnDefinition Width="*" />
                                    <!--  Name + Status  -->
                                    <ColumnDefinition Width="Auto" />
                                    <!--  Buttons  -->
                                </Grid.ColumnDefinitions>

                                <!--  Status Dot  -->
                                <Grid
                                    Width="10"
                                    Height="10"
                                    Margin="0,0,12,0"
                                    VerticalAlignment="Center">
                                    <Ellipse x:Name="StatusDot">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="#EF5350" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                        <Setter Property="Fill" Value="#FFCA28" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsInitializing}" Value="True">
                                                        <Setter Property="Fill" Value="#FFCA28" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Selected.IsConnected}" Value="True">
                                                        <Setter Property="Fill" Value="#66BB6A" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                </Grid>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="{Binding Selected.Name, FallbackValue='Select a Server'}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        FontSize="9"
                                        FontWeight="Bold"
                                        Opacity="0.7">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{x:Static p:Resources.StatusDisconnected}" />
                                                <Setter Property="Foreground" Value="#EF5350" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                        <Setter Property="Text" Value="{x:Static p:Resources.StatusConnecting}" />
                                                        <Setter Property="Foreground" Value="#FFCA28" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsInitializing}" Value="True">
                                                        <Setter Property="Text" Value="{x:Static p:Resources.StatusInitializing}" />
                                                        <Setter Property="Foreground" Value="#FFCA28" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Selected.IsConnected}" Value="True">
                                                        <Setter Property="Text" Value="{x:Static p:Resources.StatusDevicesActive}" />
                                                        <Setter Property="Foreground" Value="#66BB6A" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Selected.IsFullConnected}" Value="True">
                                                        <Setter Property="Text" Value="{x:Static p:Resources.StatusFullyConnected}" />
                                                        <Setter Property="Foreground" Value="#66BB6A" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                                    <!--  Connect  -->
                                    <ui:Button
                                        x:Name="UiBtnConnect"
                                        Margin="0,0,4,0"
                                        Padding="10,4"
                                        Appearance="Primary"
                                        Click="BtnConnect_Click"
                                        Content="{x:Static p:Resources.Connect}"
                                        Icon="{ui:SymbolIcon Symbol=PlugConnected20}"
                                        Visibility="{Binding Selected.IsConnected, Converter={StaticResource BoolToVisibilityInv}}" />

                                    <!--  Full Connect  -->
                                    <ui:Button
                                        x:Name="UiBtnFullConnect"
                                        Margin="0,0,4,0"
                                        Padding="10,4"
                                        Appearance="Primary"
                                        Click="BtnConnect_Click"
                                        Content="{x:Static p:Resources.FullConnect}"
                                        Icon="{ui:SymbolIcon Symbol=Play20}"
                                        ToolTip="{x:Static p:Resources.LoadMapTeam}">
                                        <ui:Button.Style>
                                            <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="ui:Button">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding Selected.IsConnected}" Value="True" />
                                                            <Condition Binding="{Binding Selected.IsFullConnected}" Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ui:Button.Style>
                                    </ui:Button>

                                    <!--  Disconnect  -->
                                    <ui:Button
                                        x:Name="UiBtnDisconnect"
                                        Padding="10,4"
                                        Appearance="Caution"
                                        Click="BtnDisconnect_Click"
                                        Icon="{ui:SymbolIcon Symbol=PlugDisconnected20}"
                                        ToolTip="{x:Static p:Resources.Disconnect}"
                                        Visibility="{Binding Selected.IsConnected, Converter={StaticResource BoolToVisibility}}" />

                                    <!--  Info  -->
                                    <ui:Button
                                        Margin="4,0,0,0"
                                        Padding="10,4"
                                        Appearance="Secondary"
                                        Click="BtnShowServerInfo_Click"
                                        Icon="{ui:SymbolIcon Symbol=Info20}"
                                        ToolTip="{x:Static p:Resources.ServerDetails}" />


                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel Margin="0,16,0,0">
                            <TextBlock
                                Margin="0,0,0,10"
                                FontSize="10"
                                FontWeight="Bold"
                                Foreground="White"
                                Opacity="0.6"
                                Text="{x:Static p:Resources.PairingMaintenance}" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <ui:Button
                                        x:Name="BtnListenPairing"
                                        Padding="8,2"
                                        Appearance="Secondary"
                                        Click="BtnListenPairing_Click"
                                        Content="{x:Static p:Resources.Listen}"
                                        Icon="{ui:SymbolIcon Symbol=Bluetooth24}"
                                        IsEnabled="{Binding CanStartPairing}"
                                        Visibility="{Binding IsPairingBusy, Converter={StaticResource BoolToVisibilityInv}}">
                                        <ui:Button.ContextMenu>
                                            <ContextMenu Style="{StaticResource DarkContextMenu}">
                                                <MenuItem Click="BtnListenWithEdge_Click" Header="{x:Static p:Resources.TryPairingEdge}" />
                                                <Separator />
                                                <MenuItem Click="BtnResetPairing_Click" Header="{x:Static p:Resources.ResetPairingConfig}" />
                                                <MenuItem Click="BtnResetAndListen_Click" Header="{x:Static p:Resources.ResetListenPairing}" />
                                                <MenuItem Click="BtnResetAndListenEdge_Click" Header="{x:Static p:Resources.ResetListenEdge}" />
                                            </ContextMenu>
                                        </ui:Button.ContextMenu>
                                    </ui:Button>

                                    <ui:Button
                                        x:Name="BtnStopPairing"
                                        Padding="8,2"
                                        Appearance="Caution"
                                        Click="BtnStopPairing_Click"
                                        Content="{x:Static p:Resources.Stop}"
                                        Icon="{ui:SymbolIcon Symbol=Stop24}"
                                        Visibility="{Binding IsPairingBusy, Converter={StaticResource BoolToVisibility}}" />
                                </StackPanel>

                                <StackPanel
                                    Grid.Column="1"
                                    Margin="12,0"
                                    VerticalAlignment="Center">
                                    <TextBlock
                                        x:Name="TxtPairingState"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextSubtle}"
                                        Text="{x:Static p:Resources.PairingIdle}" />
                                    <ProgressBar
                                        Height="3"
                                        Margin="0,4,0,0"
                                        Background="#1AFFFFFF"
                                        Foreground="{DynamicResource SystemAccentBrush}"
                                        IsIndeterminate="True"
                                        Visibility="{Binding IsPairingBusy, Converter={StaticResource BoolToVisibility}}" />
                                </StackPanel>

                                <TextBlock
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    FontSize="9"
                                    FontStyle="Italic"
                                    Foreground="White"
                                    Opacity="0.5"
                                    Text="{x:Static p:Resources.RightClickOptions}" />
                            </Grid>
                        </StackPanel>

                        <Border
                            Height="1"
                            Margin="0,4,0,4"
                            Background="#12FFFFFF" />

                        <Grid Margin="0,2,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse
                                    x:Name="TrackingPulse"
                                    Width="8"
                                    Height="8"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    Fill="#62D38B">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTrackingActive}" Value="True">
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard x:Name="Pulse">
                                                            <Storyboard>
                                                                <DoubleAnimation
                                                                    AutoReverse="True"
                                                                    RepeatBehavior="Forever"
                                                                    Storyboard.TargetProperty="Opacity"
                                                                    From="1"
                                                                    To="0.3"
                                                                    Duration="0:0:1" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <StopStoryboard BeginStoryboardName="Pulse" />
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock
                                    x:Name="TxtTrackingStatus"
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Text="{x:Static p:Resources.TrackingActive}" />
                            </StackPanel>
                            <TextBlock
                                x:Name="TxtLastPull"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                FontSize="10"
                                Foreground="{DynamicResource TextSubtle}"
                                Text="{x:Static p:Resources.LastPull}" />
                        </Grid>

                        <Border
                            Height="1"
                            Margin="0,8,0,8"
                            Background="#12FFFFFF" />
                    </StackPanel>

                    <!--  BOTTOM: Footer (Donate + Serverdaten) andocken  -->
                    <Grid Margin="0,8,0,0" DockPanel.Dock="Bottom">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!--  Donate  -->
                        <ui:Button
                            x:Name="BtnDonate"
                            Grid.Column="0"
                            Margin="0,0,10,0"
                            Background="#991A1A00"
                            BorderBrush="#80FFD166"
                            Click="BtnDonate_Click"
                            Content="{x:Static p:Resources.Donate}"
                            Foreground="#FFD166"
                            Icon="{ui:SymbolIcon Symbol=Heart24}"
                            ToolTip="{x:Static p:Resources.SupportDeveloper}" />

                        <!--  Reset Connection  -->
                        <Border Grid.Column="1" VerticalAlignment="Center">
                            <ui:Button
                                Margin="0,0,8,0"
                                Appearance="Secondary"
                                Click="BtnHardReset_Click"
                                Content="{x:Static p:Resources.Reset}"
                                Icon="{ui:SymbolIcon Symbol=ArrowReset24}"
                                ToolTip="{x:Static p:Resources.ResetWebSocket}" />
                        </Border>

                        <!--  Serverdaten (rechtsbündig, gleiche Zeile)  -->
                        <StackPanel
                            Grid.Column="2"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                            <TextBlock Text="{x:Static p:Resources.Players}" />
                            <TextBlock
                                Margin="4,0,0,0"
                                FontWeight="SemiBold"
                                Text="{Binding ServerPlayers}" />

                    <Button
                        x:Name="BtnShowOnline"
                        Width="18"
                        Height="18"
                        Margin="4,0,0,0"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="BtnShowOnline_Click"
                        Content="&#x25BC;"
                        Foreground="White"
                        ToolTip="{x:Static p:Resources.ShowOnlinePlayers}" />

                    <TextBlock Margin="6,0,0,0" VerticalAlignment="Center">
                        <Run Text=" | " />
                        <Run Text="{x:Static p:Resources.Queue}" />
                    </TextBlock>
                    <TextBlock
                        Margin="4,0,0,0"
                        FontWeight="SemiBold"
                        Text="{Binding ServerQueue}" />
                </StackPanel>
                    </Grid>

                    <!--  CENTER: TabControl füllt den Rest, mit Mindesthöhe  -->
            <TabControl
                x:Name="MainTabs"
                VerticalAlignment="Stretch"
                Style="{StaticResource PrettyTabControl}">
                <!--  ===== DEVICES =====  -->
                <TabItem Header="{x:Static p:Resources.DevicesTab}" Style="{StaticResource PrettyTabItem}">
                    <DockPanel LastChildFill="True">
                        <!--  Footer  -->
                        <StackPanel
                            Margin="0,10,0,0"
                            HorizontalAlignment="Right"
                            DockPanel.Dock="Bottom"
                            Orientation="Horizontal">
                            <ui:Button
                                x:Name="BtnHotkeys"
                                Width="90"
                                Margin="0,0,10,0"
                                Appearance="Secondary"
                                Click="BtnHotkeys_Click"
                                Content="{x:Static p:Resources.Hotkeys}" />
                            <ui:Button
                                x:Name="BtnDevicesImport"
                                Width="36"
                                Height="36"
                                Margin="0,0,8,0"
                                Padding="4"
                                Appearance="Secondary"
                                Click="BtnDevicesImport_Click"
                                Icon="{ui:SymbolIcon Symbol=ArrowDownload24}"
                                ToolTip="{x:Static p:Resources.ImportDevices}" />
                            <ui:Button
                                x:Name="BtnDevicesExport"
                                Width="36"
                                Height="36"
                                Margin="0,0,16,0"
                                Padding="4"
                                Appearance="Secondary"
                                Click="BtnDevicesExport_Click"
                                Icon="{ui:SymbolIcon Symbol=ArrowUpload24}"
                                ToolTip="{x:Static p:Resources.ExportDevices}" />
                            <ui:Button
                                Width="80"
                                Margin="10,0,0,0"
                                Appearance="Secondary"
                                Click="BtnDeviceRefresh_Click"
                                Content="{x:Static p:Resources.Refresh}" />
                            <ui:Button
                                Width="80"
                                Margin="10,0,0,0"
                                Appearance="Secondary"
                                Click="BtnDeleteDevice_Click"
                                Content="{x:Static p:Resources.Delete}"
                                IsEnabled="{Binding ElementName=ListDevices, Path=SelectedItem.IsMissing, Converter={StaticResource NotNull}}"
                                ToolTip="{x:Static p:Resources.DeleteMissingOnly}" />
                        </StackPanel>

                                <Grid>
                                    <TreeView
                                        x:Name="ListDevices"
                                        HorizontalContentAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Grid.IsSharedSizeScope="True"
                                        ItemsSource="{Binding CurrentDevices}"
                                        ScrollViewer.CanContentScroll="False"
                                        SelectedItemChanged="ListDevices_SelectedItemChanged"
                                        VirtualizingPanel.IsVirtualizing="False"
                                        VirtualizingPanel.ScrollUnit="Pixel">

                                        <TreeView.ItemContainerStyle>
                                            <Style TargetType="TreeViewItem">
                                                <Setter Property="AllowDrop" Value="True" />
                                                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="TreeViewItem_PreviewMouseLeftButtonDown" />
                                                <EventSetter Event="PreviewMouseMove" Handler="TreeViewItem_PreviewMouseMove" />
                                                <EventSetter Event="DragEnter" Handler="TreeViewItem_DragEnter" />
                                                <EventSetter Event="DragOver" Handler="TreeViewItem_DragOver" />
                                                <EventSetter Event="Drop" Handler="TreeViewItem_Drop" />
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderThickness" Value="0" />
                                                <Style.Resources>
                                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3340A070" />
                                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
                                                    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="Transparent" />
                                                </Style.Resources>
                                            </Style>
                                        </TreeView.ItemContainerStyle>

                                        <TreeView.ItemTemplate>
                                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                                <!--  Row + Details teilen sich den gleichen DataContext (SmartDevice)  -->
                                                <StackPanel Margin="0,2,0,0">

                                                    <!--  ===== Zeile =====  -->
                                                    <Border
                                                        Margin="0,2,8,2"
                                                        Padding="12,6"
                                                        CornerRadius="8">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#171A21" />
                                                                <Setter Property="BorderBrush" Value="#222734" />
                                                                <Setter Property="BorderThickness" Value="1" />
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#1C202A" />
                                                                        <Setter Property="BorderBrush" Value="#303746" />
                                                                    </Trigger>
                                                                    <DataTrigger Binding="{Binding IsMissing}" Value="True">
                                                                        <Setter Property="Opacity" Value="0.6" />
                                                                        <Setter Property="Background" Value="#101217" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsGroup}" Value="True">
                                                                        <Setter Property="Background" Value="#141F33" />
                                                                        <Setter Property="BorderBrush" Value="#253550" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid VerticalAlignment="Center">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" SharedSizeGroup="ColTypeID" />
                                                                <ColumnDefinition Width="*" SharedSizeGroup="ColAlias" />
                                                                <ColumnDefinition Width="Auto" SharedSizeGroup="ColToggle" />
                                                            </Grid.ColumnDefinitions>

                                                            <!--  Spalte 1: Icon  -->
                                                            <Image
                                                                Grid.Column="0"
                                                                Width="16"
                                                                Height="16"
                                                                VerticalAlignment="Center"
                                                                RenderOptions.BitmapScalingMode="HighQuality">
                                                                <Image.Style>
                                                                    <Style TargetType="Image">
                                                                        <Setter Property="Source" Value="{StaticResource IconSmartSwitch}" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Kind}" Value="StorageMonitor">
                                                                                <Setter Property="Source" Value="{StaticResource IconStorageMonitor}" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Kind}" Value="Storage Monitor">
                                                                                <Setter Property="Source" Value="{StaticResource IconStorageMonitor}" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Kind}" Value="SmartAlarm">
                                                                                <Setter Property="Source" Value="{StaticResource IconSmartAlarm}" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Kind}" Value="Smart Alarm">
                                                                                <Setter Property="Source" Value="{StaticResource IconSmartAlarm}" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding IsGroup}" Value="True">
                                                                                <Setter Property="Source" Value="{StaticResource IconGroup}" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Image.Style>
                                                            </Image>

                                                            <!--  Spalte 2: strukturierte Device-Infos  -->
                                                            <StackPanel
                                                                Grid.Column="1"
                                                                Margin="12,0"
                                                                VerticalAlignment="Center"
                                                                Orientation="Horizontal">
                                                                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                                                    <TextBlock
                                                                        VerticalAlignment="Center"
                                                                        FontSize="14"
                                                                        FontWeight="Bold"
                                                                        Foreground="#FF4B4B"
                                                                        Text="✗ ">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsMissing}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                    <TextBlock
                                                                        VerticalAlignment="Center"
                                                                        FontSize="13"
                                                                        FontWeight="SemiBold"
                                                                        Foreground="#EAECEE"
                                                                        Text="{Binding PureName, TargetNullValue=Device}"
                                                                        ToolTip="{x:Static p:Resources.RightClickRename}">                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsMissing}" Value="True">
                                                                                        <Setter Property="Foreground" Value="#888" />
                                                                                        <Setter Property="FontStyle" Value="Italic" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                        <TextBlock.ContextMenu>
                                                                            <ContextMenu Style="{StaticResource DarkContextMenu}">
                                                                                <MenuItem Click="Device_Rename_Click" Header="{x:Static p:Resources.RenameDevice}" />
                                                                            </ContextMenu>
                                                                        </TextBlock.ContextMenu>
                                                                    </TextBlock>
                                                                </StackPanel>

                                                                <TextBlock
                                                                    Margin="8,0,0,0"
                                                                    VerticalAlignment="Center"
                                                                    FontSize="10"
                                                                    Foreground="#8D98A8"
                                                                    Text="{Binding EntityId, StringFormat=#\{0\}}" />

                                                                <Border
                                                                    Margin="12,0,0,0"
                                                                    Padding="6,2"
                                                                    VerticalAlignment="Center"
                                                                    Background="#2E3646"
                                                                    BorderBrush="#4A5670"
                                                                    BorderThickness="1"
                                                                    CornerRadius="8">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Background" Value="#2E3646" />
                                                                            <Setter Property="BorderBrush" Value="#4A5670" />
                                                                            <Style.Triggers>
                                                                                <!--  ON / ACTIVE / ONLINE Status (Grün)  -->
                                                                                <DataTrigger Binding="{Binding IsOn}" Value="True">
                                                                                    <Setter Property="Background" Value="#193F2A" />
                                                                                    <Setter Property="BorderBrush" Value="#2B7A4E" />
                                                                                </DataTrigger>

                                                                                <!--  Storage Monitor & Others: Immer grün wenn da  -->
                                                                                <DataTrigger Binding="{Binding Kind}" Value="StorageMonitor">
                                                                                    <Setter Property="Background" Value="#193F2A" />
                                                                                    <Setter Property="BorderBrush" Value="#2B7A4E" />
                                                                                </DataTrigger>

                                                                                <!--  MISSING / DISCONNECTED (Rot)  -->
                                                                                <DataTrigger Binding="{Binding IsMissing}" Value="True">
                                                                                    <Setter Property="Background" Value="#412226" />
                                                                                    <Setter Property="BorderBrush" Value="#8E3B45" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>

                                                                    <TextBlock
                                                                        FontSize="9"
                                                                        FontWeight="SemiBold"
                                                                        Foreground="#EAF2FF">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Text" Value="{x:Static p:Resources.Online}" />
                                                                                <Style.Triggers>
                                                                                    <!--  MISSING  -->
                                                                                    <DataTrigger Binding="{Binding IsMissing}" Value="True">
                                                                                        <Setter Property="Text" Value="{x:Static p:Resources.Offline}" />
                                                                                    </DataTrigger>

                                                                                    <!--  Smart Switch  -->
                                                                                    <DataTrigger Binding="{Binding Kind}" Value="SmartSwitch">
                                                                                        <Setter Property="Text" Value="{x:Static p:Resources.Off}" />
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding Kind}" Value="Smart Switch">
                                                                                        <Setter Property="Text" Value="{x:Static p:Resources.Off}" />
                                                                                    </DataTrigger>
                                                                                    <MultiDataTrigger>
                                                                                        <MultiDataTrigger.Conditions>
                                                                                            <Condition Binding="{Binding Kind}" Value="SmartSwitch" />
                                                                                            <Condition Binding="{Binding IsOn}" Value="True" />
                                                                                        </MultiDataTrigger.Conditions>
                                                                                        <Setter Property="Text" Value="{x:Static p:Resources.On}" />
                                                                                    </MultiDataTrigger>
                                                                                    <MultiDataTrigger>
                                                                                        <MultiDataTrigger.Conditions>
                                                                                            <Condition Binding="{Binding Kind}" Value="Smart Switch" />
                                                                                            <Condition Binding="{Binding IsOn}" Value="True" />
                                                                                        </MultiDataTrigger.Conditions>
                                                                                        <Setter Property="Text" Value="{x:Static p:Resources.On}" />
                                                                                    </MultiDataTrigger>

                                                                                    <!--  Smart Alarm  -->
                                                                                    <DataTrigger Binding="{Binding Kind}" Value="SmartAlarm">
                                                                                        <Setter Property="Text" Value="{x:Static p:Resources.Inactive}" />
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding Kind}" Value="Smart Alarm">
                                                                                        <Setter Property="Text" Value="{x:Static p:Resources.Inactive}" />
                                                                                    </DataTrigger>
                                                                                    <MultiDataTrigger>
                                                                                        <MultiDataTrigger.Conditions>
                                                                                            <Condition Binding="{Binding Kind}" Value="SmartAlarm" />
                                                                                            <Condition Binding="{Binding IsOn}" Value="True" />
                                                                                        </MultiDataTrigger.Conditions>
                                                                                        <Setter Property="Text" Value="{x:Static p:Resources.Active}" />
                                                                                    </MultiDataTrigger>
                                                                                    <MultiDataTrigger>
                                                                                        <MultiDataTrigger.Conditions>
                                                                                            <Condition Binding="{Binding Kind}" Value="Smart Alarm" />
                                                                                            <Condition Binding="{Binding IsOn}" Value="True" />
                                                                                        </MultiDataTrigger.Conditions>
                                                                                        <Setter Property="Text" Value="{x:Static p:Resources.Active}" />
                                                                                    </MultiDataTrigger>

                                                                                    <!--  Group  -->
                                                                                    <DataTrigger Binding="{Binding IsGroup}" Value="True">
                                                                                        <Setter Property="Text" Value="{x:Static p:Resources.Group}" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </Border>
                                                            </StackPanel>

                                                            <!--  Spalte 3: Toggle NUR fÃ¼r SmartSwitch  -->
                                                            <ToggleButton
                                                                Grid.Column="2"
                                                                Width="60"
                                                                Height="22"
                                                                Margin="8,0,0,0"
                                                                VerticalAlignment="Center"
                                                                IsChecked="{Binding IsOn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                                                <ToggleButton.Style>
                                                                    <Style TargetType="ToggleButton">
                                                                        <Setter Property="Template">
                                                                            <Setter.Value>
                                                                                <ControlTemplate TargetType="ToggleButton">
                                                                                    <Border
                                                                                        x:Name="Bd"
                                                                                        Padding="2"
                                                                                        Background="{TemplateBinding Background}"
                                                                                        BorderBrush="#66000000"
                                                                                        BorderThickness="1"
                                                                                        CornerRadius="11">
                                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                                    </Border>
                                                                                    <ControlTemplate.Triggers>
                                                                                        <Trigger Property="IsEnabled" Value="False">
                                                                                            <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                                                                                        </Trigger>
                                                                                    </ControlTemplate.Triggers>
                                                                                </ControlTemplate>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                        <EventSetter Event="Checked" Handler="DeviceToggle_Checked" />
                                                                        <EventSetter Event="Unchecked" Handler="DeviceToggle_Unchecked" />

                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Setter Property="Foreground" Value="White" />
                                                                        <Setter Property="Background" Value="IndianRed" />
                                                                        <Setter Property="Content" Value="OFF" />
                                                                        <Setter Property="FontSize" Value="10" />
                                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                                        <Setter Property="Cursor" Value="Hand" />

                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Kind}" Value="SmartSwitch">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding IsMissing}" Value="True">
                                                                                <Setter Property="IsEnabled" Value="False" />
                                                                                <Setter Property="Opacity" Value="0.4" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding IsToggleBusy}" Value="True">
                                                                                <Setter Property="IsEnabled" Value="False" />
                                                                                <Setter Property="Opacity" Value="0.6" />
                                                                            </DataTrigger>
                                                                            <Trigger Property="IsChecked" Value="True">
                                                                                <Setter Property="Background" Value="SeaGreen" />
                                                                                <Setter Property="Content" Value="ON" />
                                                                            </Trigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </ToggleButton.Style>
                                                            </ToggleButton>

                                                            <!--  Spalte 3: Toggle NUR für Gruppen  -->
                                                            <Button
                                                                Grid.Column="2"
                                                                Width="60"
                                                                Height="22"
                                                                Margin="8,0,0,0"
                                                                VerticalAlignment="Center"
                                                                Click="GroupToggle_Click"
                                                                Content="{x:Static p:Resources.Toggle}"
                                                                Tag="{Binding}">
                                                                <Button.Style>
                                                                    <Style TargetType="Button">
                                                                        <Setter Property="Template">
                                                                            <Setter.Value>
                                                                                <ControlTemplate TargetType="Button">
                                                                                    <Border
                                                                                        x:Name="Bd"
                                                                                        Padding="2"
                                                                                        Background="{TemplateBinding Background}"
                                                                                        BorderBrush="#66000000"
                                                                                        BorderThickness="1"
                                                                                        CornerRadius="11">
                                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                                    </Border>
                                                                                </ControlTemplate>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Setter Property="Foreground" Value="White" />
                                                                        <Setter Property="Background" Value="#E67E22" />
                                                                        <Setter Property="FontSize" Value="10" />
                                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                                        <Setter Property="Cursor" Value="Hand" />
                                                                        <Style.Triggers>
                                                                            <MultiDataTrigger>
                                                                                <MultiDataTrigger.Conditions>
                                                                                    <Condition Binding="{Binding IsGroup}" Value="True" />
                                                                                    <Condition Binding="{Binding HasGroupSwitches}" Value="True" />
                                                                                </MultiDataTrigger.Conditions>
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </MultiDataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>
                                                            </Button>

                                                            <!--  Spalte 3: Toggles NUR für SmartAlarm  -->
                                                            <StackPanel
                                                                Grid.Column="2"
                                                                Margin="8,0,0,0"
                                                                VerticalAlignment="Center"
                                                                Orientation="Horizontal">
                                                                <StackPanel.Style>
                                                                    <Style TargetType="StackPanel">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Kind}" Value="SmartAlarm">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Kind}" Value="Smart Alarm">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding IsMissing}" Value="True">
                                                                                <Setter Property="IsEnabled" Value="False" />
                                                                                <Setter Property="Opacity" Value="0.4" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </StackPanel.Style>

                                                                <CheckBox
                                                                    Margin="0,0,8,0"
                                                                    ToolTip="{x:Static p:Resources.PopupWindow}"
                                                                    IsChecked="{Binding PopupEnabled, Mode=TwoWay}"
                                                                    Style="{StaticResource DotCheckBox}">
                                                                    <Image Source="pack://application:,,,/Assets/icons/Popup.png" Width="16" Height="16" Stretch="Uniform"/>
                                                                </CheckBox>

                                                                <CheckBox
                                                                    Margin="0,0,8,0"
                                                                    ToolTip="{x:Static p:Resources.InAppAlert}"
                                                                    IsChecked="{Binding OverlayEnabled, Mode=TwoWay}"
                                                                    Style="{StaticResource DotCheckBox}">
                                                                    <Image Source="pack://application:,,,/Assets/icons/PiP.png" Width="16" Height="16" Stretch="Uniform"/>
                                                                </CheckBox>

                                                                <CheckBox
                                                                    ToolTip="{x:Static p:Resources.AudioAlert}"
                                                                    IsChecked="{Binding AudioEnabled, Mode=TwoWay}"
                                                                    Style="{StaticResource DotCheckBox}">
                                                                    <ui:SymbolIcon Symbol="Speaker224" FontSize="16"/>
                                                                    <CheckBox.ContextMenu>
                                                                        <ContextMenu Style="{StaticResource DarkContextMenu}">
                                                                            <MenuItem
                                                                                Click="OnSelectAlarmAudioFileClick"
                                                                                Header="{x:Static p:Resources.CustomAudioFile}"
                                                                                Tag="{Binding}" />
                                                                            <MenuItem
                                                                                Click="OnResetAlarmAudioFileClick"
                                                                                Header="{x:Static p:Resources.ResetToDefault}"
                                                                                Tag="{Binding}" />
                                                                        </ContextMenu>
                                                                    </CheckBox.ContextMenu>
                                                                </CheckBox>
                                                            </StackPanel>
                                                            <!--  Spalte 3: Pill NUR bei StorageMonitor  -->
                                                            <Border
                                                                Grid.Column="2"
                                                                Margin="8,0,0,0"
                                                                Padding="6,2"
                                                                VerticalAlignment="Center"
                                                                Background="{Binding Storage, Converter={StaticResource UpkeepBackgroundConverter}}"
                                                                BorderBrush="#55FFFFFF"
                                                                BorderThickness="1"
                                                                CornerRadius="11"
                                                                PreviewMouseWheel="StorPill_PreviewMouseWheel"
                                                                ToolTipOpening="StorPill_ToolTipOpening"
                                                                ToolTipService.InitialShowDelay="250"
                                                                ToolTipService.Placement="Mouse"
                                                                ToolTipService.ShowDuration="30000"
                                                                Visibility="{Binding Kind, Converter={StaticResource KindToStorageVisibility}}">

                                                                <!--  sichtbarer Text  -->
                                                                <TextBlock
                                                                    FontSize="10.5"
                                                                    FontWeight="SemiBold"
                                                                    Foreground="White"
                                                                    Text="{Binding StorageSummary, Mode=OneWay}" />

                                                                <!--  Hover-Tooltip (ohne StaysOpen)  -->
                                                                <Border.ToolTip>
                                                                    <ToolTip MaxWidth="520">
                                                                        <Border
                                                                            Background="#171A1F"
                                                                            BorderBrush="#2A2F37"
                                                                            BorderThickness="1"
                                                                            CornerRadius="10">
                                                                            <StackPanel Margin="8,8,8,6">

                                                                                <!--  Header (no pencil / kebab)  -->
                                                                                <DockPanel Margin="0,0,0,2" LastChildFill="False">
                                                                                    <Image
                                                                                        Width="20"
                                                                                        Height="20"
                                                                                        Margin="0,0,6,0"
                                                                                        Opacity="0.9"
                                                                                        RenderOptions.BitmapScalingMode="HighQuality"
                                                                                        Source="{StaticResource IconStorageMonitor}" />
                                                                                    <StackPanel Orientation="Horizontal">
                                                                                        <TextBlock
                                                                                            VerticalAlignment="Center"
                                                                                            FontSize="13"
                                                                                            FontWeight="Bold"
                                                                                            Foreground="#FF4B4B"
                                                                                            Text="✗ ">
                                                                                            <TextBlock.Style>
                                                                                                <Style TargetType="TextBlock">
                                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                                    <Style.Triggers>
                                                                                                        <DataTrigger Binding="{Binding IsMissing}" Value="True">
                                                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                                                        </DataTrigger>
                                                                                                    </Style.Triggers>
                                                                                                </Style>
                                                                                            </TextBlock.Style>
                                                                                        </TextBlock>
                                                                                        <TextBlock
                                                                                            DockPanel.Dock="Left"
                                                                                            FontSize="13"
                                                                                            FontWeight="SemiBold"
                                                                                            Foreground="#EAECEE"
                                                                                            Text="{Binding PureName, TargetNullValue=Storage Monitor}" />
                                                                                    </StackPanel>
                                                                                </DockPanel>

                                                                                <!--  Upkeep line (compact)  -->
                                                                                <TextBlock
                                                                                    Margin="0,0,0,4"
                                                                                    FontSize="10.5"
                                                                                    Foreground="#9AA3B2"
                                                                                    Text="{Binding Storage, Converter={StaticResource StorageChipConverter}}" />

                                                                                <!--  Dense grid  -->
                                                                                <ScrollViewer MaxHeight="390" VerticalScrollBarVisibility="Auto">
                                                                                    <ItemsControl ItemsSource="{Binding Storage.Items}">
                                                                                        <ItemsControl.ItemsPanel>
                                                                                            <ItemsPanelTemplate>
                                                                                                <WrapPanel
                                                                                                    ItemHeight="64"
                                                                                                    ItemWidth="64"
                                                                                                    Orientation="Horizontal"
                                                                                                    SnapsToDevicePixels="True"
                                                                                                    UseLayoutRounding="True" />
                                                                                            </ItemsPanelTemplate>
                                                                                        </ItemsControl.ItemsPanel>

                                                                                        <ItemsControl.ItemTemplate>
                                                                                            <DataTemplate>
                                                                                                <Border
                                                                                                    Width="64"
                                                                                                    Height="64"
                                                                                                    Background="#1F242B"
                                                                                                    BorderBrush="#2A2F37"
                                                                                                    BorderThickness="0"
                                                                                                    SnapsToDevicePixels="True">
                                                                                                    <Grid>
                                                                                                        <!--  Icon groÃŸ & zentriert  -->
                                                                                                        <Image
                                                                                                            Width="48"
                                                                                                            Height="48"
                                                                                                            HorizontalAlignment="Center"
                                                                                                            VerticalAlignment="Center"
                                                                                                            RenderOptions.BitmapScalingMode="Fant"
                                                                                                            Source="{Binding Icon}" />

                                                                                                        <!--  Badge unten rechts  -->
                                                                                                        <Border
                                                                                                            Margin="1,1,1,1"
                                                                                                            Padding="4,1.5"
                                                                                                            HorizontalAlignment="Right"
                                                                                                            VerticalAlignment="Bottom"
                                                                                                            Background="#252B33"
                                                                                                            BorderBrush="#3B4756"
                                                                                                            BorderThickness="1"
                                                                                                            CornerRadius="5">
                                                                                                            <TextBlock
                                                                                                                FontSize="10"
                                                                                                                FontWeight="SemiBold"
                                                                                                                Foreground="#EAECEE">
                                                                                                                <Run Text="x" /><Run Text="{Binding Amount, StringFormat={}{0:N0}}" />
                                                                                                            </TextBlock>
                                                                                                        </Border>
                                                                                                    </Grid>
                                                                                                </Border>
                                                                                            </DataTemplate>
                                                                                        </ItemsControl.ItemTemplate>

                                                                                        <!--  Container ohne Margin, damit wirklich null Spalt  -->
                                                                                        <ItemsControl.ItemContainerStyle>
                                                                                            <Style TargetType="ContentPresenter">
                                                                                                <Setter Property="Margin" Value="1" />
                                                                                            </Style>
                                                                                        </ItemsControl.ItemContainerStyle>
                                                                                    </ItemsControl>
                                                                                </ScrollViewer>

                                                                                <!--  footer (compact)  -->
                                                                                <TextBlock
                                                                                    Margin="0,2,0,0"
                                                                                    HorizontalAlignment="Right"
                                                                                    FontSize="9.5"
                                                                                    Foreground="#7F8A99"
                                                                                    Text="{Binding Storage.ItemsCount, StringFormat={}{0} items}" />
                                                                            </StackPanel>
                                                                        </Border>
                                                                    </ToolTip>
                                                                </Border.ToolTip>
                                                            </Border>

                                                        </Grid>
                                                    </Border>
                                                    <!--  ===== Ende Zeile =====  -->

                                                    <!-- ===== Klappbereich (hÃ¤ngt direkt an
                                            ) =====
                                            <Grid Margin="0,4,0,8" Visibility="Collapsed">
                                                <Grid.Style>
                                                    <Style TargetType="Grid">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Grid.Style>

                                                <Border Background="#22000000"
                      BorderBrush="#33000000" BorderThickness="1"
                      CornerRadius="8" Padding="6">
                                                    <StackPanel>
                                                        <TextBlock Foreground="#99FFFFFF" FontStyle="Italic" Margin="0,0,0,6">
                    <Run Text="{x:Static p:Resources.Snapshot}"/>
                    <Run Text="{Binding Storage.ItemsCount, Mode=OneWay, FallbackValue=0}" />
                    <Run Text="{x:Static p:Resources.ItemsUpkeep}"/>
                    <Run Text="{Binding UpkeepSeconds, Mode=OneWay, TargetNullValue=—}"/>
                                                        </TextBlock>

                                                        <ItemsControl ItemsSource="{Binding Storage.Items, Mode=OneWay}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel Orientation="Horizontal" ItemWidth="210"/>
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <StackPanel Orientation="Horizontal" Margin="6">
                                                                        <Image Width="24" Height="24" Source="{Binding Icon}" Stretch="Uniform"/>
                                                                        <TextBlock Margin="8,0,0,0" Foreground="White">
                            <Run Text="{Binding Display}"/>
                            <Run Text=" Ã— "/>
                            <Run Text="{Binding Amount}"/>
                            <Run Text="{Binding MaxStack, StringFormat={} (Stack {0})}"/>
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>-->
                                                    <!--  ===== Ende Klappbereich =====  -->

                                                </StackPanel>
                                            </HierarchicalDataTemplate>
                                        </TreeView.ItemTemplate>
                                    </TreeView>

                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsHitTestVisible="False">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasItems, ElementName=ListDevices}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>

                                        <Border
                                            Padding="32,24"
                                            HorizontalAlignment="Center"
                                            Background="#101217"
                                            BorderBrush="#1C202A"
                                            BorderThickness="1"
                                            CornerRadius="16">
                                            <StackPanel>
                                                <TextBlock
                                                    Margin="0,0,0,12"
                                                    HorizontalAlignment="Center"
                                                    FontSize="36"
                                                    Opacity="0.8"
                                                    Text="📡" />
                                                <TextBlock
                                                    Margin="0,0,0,6"
                                                    HorizontalAlignment="Center"
                                                    FontSize="16"
                                                    FontWeight="SemiBold"
                                                    Foreground="#EAECEE"
                                                    Text="{x:Static p:Resources.NoDevicesFound}" />
                                                <TextBlock
                                                    MaxWidth="200"
                                                    HorizontalAlignment="Center"
                                                    FontSize="12"
                                                    Foreground="#7F8A96"
                                                    Text="{x:Static p:Resources.PairDeviceToSee}"
                                                    TextAlignment="Center"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>


                                </Grid>
                            </DockPanel>
                        </TabItem>

                        <!--  ===== TEAM =====  -->
                        <TabItem
                            x:Name="TabTeam"
                            Header="{x:Static p:Resources.TeamTab}"
                            Style="{StaticResource PrettyTabItem}">
                            <Grid>
                                <Grid Background="#181A1E">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid.Resources>
                                        <conv:BoolToVisibilityConverter x:Key="Vis" />
                                        <conv:BoolToVisibilityConverter x:Key="VisInv" Invert="True" />
                                        <Style x:Key="Card" TargetType="Border">
                                            <Setter Property="CornerRadius" Value="10" />
                                            <Setter Property="Background" Value="#FF141F2D" />
                                            <Setter Property="Padding" Value="8" />
                                            <Setter Property="Margin" Value="6" />
                                        </Style>
                                    </Grid.Resources>

                                    <!--  Liste oben  -->
                                    <ListBox
                                        x:Name="TeamList"
                                        Grid.Row="0"
                                        HorizontalContentAlignment="Stretch"
                                        ItemsSource="{Binding TeamMembers, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <!--  Kontextmenü  -->
                                        <ListBox.Resources>
                                            <ContextMenu x:Key="TeamContextMenu" Style="{StaticResource DarkContextMenu}">
                                                <MenuItem Click="Team_Center_Click" Header="{x:Static p:Resources.CenterOnMap}" />
                                                <MenuItem Click="Team_Follow_Click" Header="{x:Static p:Resources.FollowOnMap}" />
                                                <MenuItem Click="Team_OpenProfile_Click" Header="{x:Static p:Resources.OpenSteamProfile}" />
                                                <Separator />
                                                <MenuItem Click="Team_Promote_Click" Header="{x:Static p:Resources.PromoteToLeader}" />
                                                <MenuItem Click="Team_Kick_Click" Header="{x:Static p:Resources.KickFromTeam}" />
                                            </ContextMenu>
                                        </ListBox.Resources>

                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Width" Value="210" />
                                                <!--  an deine Fensterbreite anpassen  -->
                                                <Setter Property="Margin" Value="6" />
                                                <EventSetter Event="MouseLeftButtonUp" Handler="TeamItem_MouseLeftButtonUp" />
                                                <Setter Property="ContextMenu" Value="{StaticResource TeamContextMenu}" />
                                            </Style>
                                        </ListBox.ItemContainerStyle>

                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource Card}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="56" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <!--  Avatar + Status  -->
                                                        <Grid Width="44" Height="44">
                                                            <Image
                                                                ClipToBounds="True"
                                                                RenderOptions.BitmapScalingMode="HighQuality"
                                                                Source="{Binding Avatar}"
                                                                Stretch="UniformToFill" />

                                                            <!--  Online (grün)  -->
                                                            <Ellipse
                                                                Width="12"
                                                                Height="12"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Bottom"
                                                                Fill="#4CAF50"
                                                                Stroke="Black"
                                                                Visibility="{Binding IsOnline, Converter={StaticResource Vis}}" />

                                                            <!--  Offline (grau)  -->
                                                            <Ellipse
                                                                Width="12"
                                                                Height="12"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Bottom"
                                                                Fill="#666"
                                                                Stroke="Black"
                                                                Visibility="{Binding IsOnline, Converter={StaticResource VisInv}}" />

                                                            <!--  Leader-Stern  -->
                                                            <Path
                                                                Width="20"
                                                                Height="20"
                                                                HorizontalAlignment="Left"
                                                                VerticalAlignment="Top"
                                                                Data="M 10,1 12,7 19,7 13,11 15,18 10,14 5,18 7,11 1,7 8,7 z"
                                                                Fill="Gold"
                                                                Stroke="Black"
                                                                Visibility="{Binding IsLeader, Converter={StaticResource Vis}}" />
                                                        </Grid>

                                                        <!--  Textseite  -->
                                                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                            <!--  Name: Standard weiß, offline leicht ausgrauen, tot = rot  -->
                                                            <TextBlock FontSize="14" FontWeight="SemiBold">
                                                                <TextBlock.Text>
                                                                    <Binding Path="Name" />
                                                                </TextBlock.Text>
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="White" />
                                                                        <Setter Property="Opacity" Value="1" />
                                                                        <Style.Triggers>
                                                                            <!--  tot -> rot  -->
                                                                            <DataTrigger Binding="{Binding IsDead}" Value="True">
                                                                                <Setter Property="Foreground" Value="#EF5350" />
                                                                            </DataTrigger>
                                                                            <!--  offline -> etwas ausgegraut  -->
                                                                            <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                                                                <Setter Property="Opacity" Value="0.55" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>

                                                            <TextBlock
                                                                FontSize="11"
                                                                Foreground="White"
                                                                Opacity="0.65"
                                                                Text="{Binding SteamId}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>




                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <!--  Buttonleiste unten  -->
                                    <Grid Grid.Row="1" Margin="0,10,0,0">
                                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                            <!--  Profile marker toggle (default ON)  -->
                                            <CheckBox
                                                x:Name="ChkProfileMarkers"
                                                Margin="0,0,12,0"
                                                Checked="ChkProfileMarkers_Toggled"
                                                IsChecked="True"
                                                Style="{StaticResource DotCheckBox}"
                                                Unchecked="ChkProfileMarkers_Toggled">
                                                <StackPanel Orientation="Horizontal">
                                                    <Grid
                                                        Width="20"
                                                        Height="20"
                                                        Margin="0,0,6,0">
                                                        <!--  Avatar Preview (Visible when checked)  -->
                                                        <Ellipse
                                                            Width="18"
                                                            Height="18"
                                                            Stroke="Black"
                                                            StrokeThickness="1"
                                                            Visibility="{Binding IsChecked, ElementName=ChkProfileMarkers, Converter={StaticResource BoolToVisibility}}">
                                                            <Ellipse.Fill>
                                                                <ImageBrush ImageSource="{Binding MyAvatar}" Stretch="UniformToFill" />
                                                            </Ellipse.Fill>
                                                        </Ellipse>
                                                        <!--  Dot Preview (Visible when unchecked)  -->
                                                        <Ellipse
                                                            Width="10"
                                                            Height="10"
                                                            Fill="LimeGreen"
                                                            Stroke="Black"
                                                            StrokeThickness="1.5"
                                                            Visibility="{Binding IsChecked, ElementName=ChkProfileMarkers, Converter={StaticResource BoolToVisibilityInv}}" />
                                                    </Grid>
                                                    <TextBlock VerticalAlignment="Center" Text="{x:Static p:Resources.ProfileMarkers}" />
                                                </StackPanel>
                                            </CheckBox>

                                            <!--  Death markers toggle (default OFF)  -->
                                            <CheckBox
                                                x:Name="ChkDeathMarkers"
                                                Margin="0,0,12,0"
                                                Checked="ChkDeathMarkers_Toggled"
                                                IsChecked="False"
                                                Style="{StaticResource DotCheckBox}"
                                                Unchecked="ChkDeathMarkers_Toggled">
                                                <StackPanel Orientation="Horizontal">
                                                    <Grid
                                                        Width="20"
                                                        Height="20"
                                                        Margin="0,0,6,0">
                                                        <!--  Death Preview (Visible when checked)  -->
                                                        <Grid Visibility="{Binding IsChecked, ElementName=ChkDeathMarkers, Converter={StaticResource BoolToVisibility}}">
                                                            <Path
                                                                Width="16"
                                                                Height="20"
                                                                Data="M20,0 C31,0 40,9 40,20 C40,33 20,56 20,56 C20,56 0,33 0,20 C0,9 9,0 20,0 Z"
                                                                Fill="IndianRed"
                                                                Stretch="Uniform"
                                                                Stroke="Black"
                                                                StrokeThickness="1" />
                                                            <Ellipse
                                                                Width="10"
                                                                Height="10"
                                                                Margin="0,0,0,5">
                                                                <Ellipse.Fill>
                                                                    <ImageBrush ImageSource="{Binding MyAvatar}" Stretch="UniformToFill" />
                                                                </Ellipse.Fill>
                                                            </Ellipse>
                                                        </Grid>
                                                        <!--  Grey dot (Visible when unchecked - indicates hidden/none)  -->
                                                        <Ellipse
                                                            Width="10"
                                                            Height="10"
                                                            Fill="#444"
                                                            Stroke="#666"
                                                            StrokeThickness="1.5"
                                                            Visibility="{Binding IsChecked, ElementName=ChkDeathMarkers, Converter={StaticResource BoolToVisibilityInv}}" />
                                                    </Grid>
                                                    <TextBlock VerticalAlignment="Center" Text="{x:Static p:Resources.DeathMarkers}" />
                                                </StackPanel>
                                            </CheckBox>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </TabItem>

                        <!--  ===== CAMERAS =====  -->
                        <TabItem Header="{x:Static p:Resources.CamerasTab}" Style="{StaticResource PrettyTabItem}">
                            <DockPanel LastChildFill="True">
                                <!--  Add Camera unten rechts  -->
                                <StackPanel
                                    Margin="0,10,0,0"
                                    HorizontalAlignment="Right"
                                    DockPanel.Dock="Bottom"
                                    Orientation="Horizontal">
                                    <Button x:Name="BtnAddCam" Style="{StaticResource PrimaryButton}">
                                        <StackPanel Margin="6,1" Orientation="Horizontal">
                                            <TextBlock Text="{x:Static p:Resources.AddCamera}" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <Grid>
                                        <ItemsControl x:Name="CamItems">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel ItemHeight="180" ItemWidth="220" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>

                                        <StackPanel
                                            Margin="0,50"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            IsHitTestVisible="False">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasItems, ElementName=CamItems}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontStyle="Italic"
                                                Foreground="{StaticResource TextSubtle}"
                                                Text="{x:Static p:Resources.NoCamerasFound}" />
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontSize="10"
                                                Foreground="{StaticResource TextSubtle}"
                                                Opacity="0.6"
                                                Text="{x:Static p:Resources.PairCameraToSee}" />
                                        </StackPanel>
                                    </Grid>
                                </ScrollViewer>
                            </DockPanel>
                        </TabItem>

                        <!--  ===== PLAYERS =====  -->
                        <TabItem Header="{x:Static p:Resources.PlayersTab}" Style="{StaticResource PrettyTabItem}">
                            <TabControl
                                Margin="0,10,0,0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Background="Transparent"
                                BorderThickness="0">
                                <TabControl.Template>
                                    <ControlTemplate TargetType="{x:Type TabControl}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            
                                            <TabPanel
                                                Grid.Row="0" Grid.Column="0"
                                                Margin="0"
                                                Panel.ZIndex="1"
                                                IsItemsHost="True" />
                                                
                                            <ui:Button
                                                Grid.Row="0" Grid.Column="1"
                                                Margin="0,0,12,0"
                                                Padding="8,4"
                                                VerticalAlignment="Center"
                                                Appearance="Secondary"
                                                Click="BtnHowToTrack_Click"
                                                ToolTip="{x:Static p:Resources.LearnHowTrackingWorks}"
                                                Icon="{ui:SymbolIcon Symbol=QuestionCircle24}"
                                                Content="{x:Static p:Resources.HowToTrack}" />

                                            <ContentPresenter
                                                Grid.Row="1" Grid.ColumnSpan="2"
                                                Margin="0,8,0,0"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Stretch"
                                                ContentSource="SelectedContent" />
                                        </Grid>
                                    </ControlTemplate>
                                </TabControl.Template>

                                <!--  Online Players Tab  -->
                                <TabItem Header="{x:Static p:Resources.OnlineTab}" Style="{StaticResource PrettyTabItem}">
                                    <Border
                                        Padding="12"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        TextElement.FontFamily="Segoe UI Variable Display, Segoe UI">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontSize="16"
                                                    FontWeight="Bold"
                                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                    Text="{x:Static p:Resources.OnlinePlayers}" />



                                                <ui:Button
                                                    x:Name="BtnSearchBM"
                                                    Grid.Column="1"
                                                    Margin="0,0,4,0"
                                                    Padding="8,4"
                                                    Appearance="Primary"
                                                    Click="BtnSearchBM_Click"
                                                    Content="{x:Static p:Resources.SearchBM}"
                                                    ToolTip="{x:Static p:Resources.SearchServerBM}" />

                                                <ui:Button
                                                    Grid.Column="2"
                                                    Padding="8,4"
                                                    Appearance="Secondary"
                                                    Click="BtnShowOnline_Click"
                                                    Content="{x:Static p:Resources.Refresh}"
                                                    Icon="{ui:SymbolIcon Symbol=ArrowClockwise24}" />

                                                <ui:Button
                                                    x:Name="BtnPopoutPlayers"
                                                    Grid.Column="3"
                                                    Margin="4,0,0,0"
                                                    Padding="8,4"
                                                    Appearance="Secondary"
                                                    Click="BtnPopoutPlayers_Click"
                                                    ToolTip="{x:Static p:Resources.OpenPlayersSeparateWindow}"
                                                    Content="{x:Static p:Resources.Popout}" />
                                            </Grid>

                                            <DockPanel x:Name="PnlManualTrack" Grid.Row="1" Margin="0,0,0,8">
                                                <ui:Button
                                                    x:Name="BtnAddManual"
                                                    Margin="4,0,0,0"
                                                    Padding="8,4"
                                                    Appearance="Primary"
                                                    Click="BtnAddManual_Click"
                                                    Content="{x:Static p:Resources.Track}"
                                                    DockPanel.Dock="Right" />
                                                <ui:TextBox
                                                    x:Name="TxtManualBMId"
                                                    GotFocus="TxtManualBMId_GotFocus"
                                                    LostFocus="TxtManualBMId_LostFocus"
                                                    PlaceholderText="{x:Static p:Resources.ManualTrackPlaceholder}"
                                                    Text="{x:Static p:Resources.ManualTrackPlaceholder}" />
                                            </DockPanel>

                                            <ui:TextBox
                                                x:Name="TxtOnlineFilter"
                                                Grid.Row="2"
                                                Margin="0,0,0,8"
                                                GotFocus="TxtOnlineFilter_GotFocus"
                                                LostFocus="TxtOnlineFilter_LostFocus"
                                                PlaceholderText="{x:Static p:Resources.FilterPlayersPlaceholder}"
                                                TextChanged="TxtOnlineFilter_TextChanged"
                                                Visibility="Collapsed" />

                                            <Grid
                                                x:Name="PnlOnlineStatus"
                                                Grid.Row="3"
                                                Margin="20"
                                                VerticalAlignment="Center"
                                                Visibility="Collapsed"
                                                Background="Transparent">
                                                <Grid.ContextMenu>
                                                    <ContextMenu Style="{StaticResource DarkContextMenu}">
                                                        <MenuItem Click="Server_RelinkBM_Click" Header="{x:Static p:Resources.RelinkBattlemetricsId}" />
                                                    </ContextMenu>
                                                </Grid.ContextMenu>
                                                <StackPanel>
                                                    <ui:ProgressRing
                                                        x:Name="PbOnlineLoading"
                                                        Width="32"
                                                        Height="32"
                                                        Margin="0,0,0,12"
                                                        IsIndeterminate="True" />
                                                    <TextBlock
                                                        x:Name="TxtOnlinePlayersStatus"
                                                        HorizontalAlignment="Center"
                                                        FontSize="12"
                                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                        Text="{x:Static p:Resources.LoadingPlayers}"
                                                        TextAlignment="Center"
                                                        TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Grid>

                                            <ListBox
                                                x:Name="ListOnlinePlayers"
                                                Grid.Row="3"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,4">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                                <Ellipse
                                                                    x:Name="StatusDot"
                                                                    Width="8"
                                                                    Height="8"
                                                                    Margin="0,0,8,0"
                                                                    VerticalAlignment="Center"
                                                                    Fill="{DynamicResource SystemAccentColorPrimaryBrush}" />
                                                                <TextBlock
                                                                    MaxWidth="160"
                                                                    VerticalAlignment="Center"
                                                                    FontSize="13"
                                                                    FontWeight="SemiBold"
                                                                    Text="{Binding Name}"
                                                                    TextTrimming="CharacterEllipsis"
                                                                    ToolTip="{Binding Name}" />
                                                            </StackPanel>
                                                            <TextBlock
                                                                Grid.Column="1"
                                                                Margin="0,0,8,0"
                                                                VerticalAlignment="Center"
                                                                FontSize="11"
                                                                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                Text="{Binding PlayTimeStr}" />

                                                            <ui:Button
                                                                x:Name="BtnAction"
                                                                Grid.Column="3"
                                                                Width="60"
                                                                Margin="0"
                                                                Padding="6,2"
                                                                Appearance="Secondary"
                                                                Click="BtnTrackPlayer_Click"
                                                                Content="{x:Static p:Resources.Track}"
                                                                FontSize="11"
                                                                Tag="{Binding}" />
                                                        </Grid>
                                                        <DataTemplate.Triggers>
                                                            <DataTrigger Binding="{Binding IsTracked}" Value="True">
                                                                <Setter TargetName="StatusDot" Property="Fill" Value="#FFD166" />
                                                                <Setter TargetName="BtnAction" Property="Content" Value="Details" />
                                                                <Setter TargetName="BtnAction" Property="Appearance" Value="Primary" />
                                                            </DataTrigger>
                                                            <Trigger Property="IsMouseOver" Value="False">
                                                                <Setter TargetName="BtnAction" Property="Opacity" Value="0.6" />
                                                            </Trigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="BtnAction" Property="Opacity" Value="1" />
                                                            </Trigger>
                                                        </DataTemplate.Triggers>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Grid>
                                    </Border>
                                </TabItem>

                                <!--  Tracked Players Tab  -->
                                <TabItem Header="{x:Static p:Resources.TrackedTab}" Style="{StaticResource PrettyTabItem}">
                                    <Border
                                        Padding="12"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        TextElement.FontFamily="Segoe UI Variable Display, Segoe UI">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontSize="16"
                                                    FontWeight="Bold"
                                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                    Text="{x:Static p:Resources.TrackedPlayers}" />
                                                <ui:Button
                                                    Grid.Column="1"
                                                    Padding="8,4"
                                                    Appearance="Secondary"
                                                    Click="BtnManageGroups_Click"
                                                    Content="{x:Static p:Resources.ManageGroups}"
                                                    Icon="Group24" />
                                            </Grid>

                                            <ui:TextBox
                                                x:Name="TxtTrackedFilter"
                                                Grid.Row="1"
                                                Margin="0,0,0,8"
                                                GotFocus="TxtTrackedFilter_GotFocus"
                                                LostFocus="TxtTrackedFilter_LostFocus"
                                                PlaceholderText="{x:Static p:Resources.FilterPlayersPlaceholder}"
                                                Text="{x:Static p:Resources.FilterPlayersPlaceholder}"
                                                TextChanged="TxtTrackedFilter_TextChanged" />

                                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                                <StackPanel x:Name="ListTrackedPlayers" />
                                            </ScrollViewer>

                                            <ui:Button
                                                x:Name="BtnViewTracking"
                                                Grid.Row="3"
                                                Margin="0,8,0,0"
                                                HorizontalAlignment="Stretch"
                                                Appearance="Primary"
                                                Click="BtnViewAllAnalysis_Click"
                                                Content="{x:Static p:Resources.ViewFullAnalysisReport}"
                                                Icon="DataHistogram24" />
                                        </Grid>
                                    </Border>
                                </TabItem>
                            </TabControl>
                        </TabItem>
                    </TabControl>

                    </DockPanel>

                    <!--  Profit Trades Overlay  -->
                    <Border
                        x:Name="ProfitTradesPanel"
                        Background="{DynamicResource Surface}"
                        Visibility="Collapsed">
                        <Grid ClipToBounds="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="36" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1" Padding="12,0">
                                <Grid>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="💰" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" />
                                        <TextBlock Text="{x:Static p:Resources.ProfitTrades}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <Button x:Name="BtnRefreshProfitTrades" Content="⟳" Style="{StaticResource GhostButton}" Width="26" Height="26" Padding="0" FontSize="15" Margin="0,0,6,0" ToolTip="{x:Static p:Resources.Refresh}" />
                                        <Button x:Name="BtnCloseProfitTrades" Content="&#x2715;" Style="{StaticResource GhostButton}" Width="26" Height="26" Padding="0" FontSize="12" Foreground="{DynamicResource TextSubtle}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1" Padding="12,7" BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1">
                                <TextBlock Text="{x:Static p:Resources.ArbitrageOpportunities}" Foreground="{DynamicResource TextSubtle}" FontSize="11" />
                            </Border>

                            <ListBox x:Name="ProfitTradesList" Grid.Row="2" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch" Padding="10" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" VirtualizingStackPanel.ScrollUnit="Pixel" VirtualizingStackPanel.IsVirtualizing="True" />
                        </Grid>
                    </Border>

                    <!--  Buy X For Y Overlay  -->
                    <Border
                        x:Name="BuyXForYPanel"
                        Background="{DynamicResource Surface}"
                        Visibility="Collapsed">
                        <Grid ClipToBounds="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="36" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="130" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1" Padding="12,0">
                                <Grid>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="🔁" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" />
                                        <TextBlock Text="{x:Static p:Resources.BuyXForY}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" />
                                    </StackPanel>
                                    <Button x:Name="BtnCloseBuyXForY" Content="&#x2715;" Style="{StaticResource GhostButton}" Width="26" Height="26" Padding="0" FontSize="12" Foreground="{DynamicResource TextSubtle}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1" Margin="12,8,12,6" HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Margin="0,0,4,0" Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="6" Padding="6,3">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="🎯" Margin="0,0,4,0" VerticalAlignment="Center" FontSize="13" />
                                        <TextBox x:Name="BuyXForY_WantTb" Grid.Column="1" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextPrimary}" CaretBrush="{DynamicResource TextPrimary}" Padding="2,3" VerticalContentAlignment="Center" ToolTip="{x:Static p:Resources.IWantToGetToolTip}" FontSize="12" />
                                    </Grid>
                                </Border>

                                <Border Grid.Column="1" Margin="4,0" Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="6" Padding="6,3">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="💰" Margin="0,0,4,0" VerticalAlignment="Center" FontSize="13" />
                                        <TextBox x:Name="BuyXForY_PayTb" Grid.Column="1" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextPrimary}" CaretBrush="{DynamicResource TextPrimary}" Padding="2,3" VerticalContentAlignment="Center" ToolTip="{x:Static p:Resources.ICanPayWithToolTip}" FontSize="12" />
                                    </Grid>
                                </Border>

                                <Button x:Name="BuyXForY_AnalyzeBtn" Grid.Column="2" Content="{x:Static p:Resources.Analyze}" Style="{StaticResource PrimaryButton}" Margin="4,0,0,0" Padding="12,3" FontSize="12" />
                            </Grid>

                            <Grid Grid.Row="2" Margin="12,0,12,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Margin="0,0,4,0" Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="6" Padding="5">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Top" Text="{x:Static p:Resources.IWantToGet}" Foreground="{DynamicResource Accent}" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,3" />
                                        <ListBox x:Name="BuyXForY_WantPreview" Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" VirtualizingStackPanel.ScrollUnit="Pixel" VirtualizingStackPanel.IsVirtualizing="True" />
                                    </DockPanel>
                                </Border>

                                <Border Grid.Column="1" Margin="4,0,0,0" Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="6" Padding="5">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Top" Text="{x:Static p:Resources.ICanPayWith}" Foreground="{DynamicResource Accent}" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,3" />
                                        <ListBox x:Name="BuyXForY_PayPreview" Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" VirtualizingStackPanel.ScrollUnit="Pixel" VirtualizingStackPanel.IsVirtualizing="True" />
                                    </DockPanel>
                                </Border>
                            </Grid>

                            <ListBox x:Name="BuyXForY_ResultList" Grid.Row="3" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch" Margin="12,0,12,10" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" VirtualizingStackPanel.ScrollUnit="Pixel" VirtualizingStackPanel.IsVirtualizing="True" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!--  Rechte Spalte: Login/Status + WebViewHost  -->
            <Border
                Grid.Column="2"
                MinWidth="800"
                Padding="12"
                Background="{DynamicResource Surface}"
                BorderBrush="{DynamicResource CardBorder}"
                BorderThickness="1,0,0,0"
                CornerRadius="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  RE-DESIGNED MAP CONTROL BAR  -->
                    <Border
                        Grid.Row="0"
                        Margin="-12,-12,-12,0"
                        Padding="16,8"
                        Background="{DynamicResource SurfaceAlt}"
                        BorderBrush="{DynamicResource CardBorder}"
                        BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!--  Left Group: Map Filters  -->
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    Margin="0,0,16,0"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource TextSubtle}"
                                    Opacity="0.8"
                                    Text="{x:Static p:Resources.MapFilters}" />

                                <CheckBox
                                    x:Name="ChkGrid"
                                    Margin="0,0,8,0"
                                    Checked="ChkGrid_Checked"
                                    Content="{x:Static p:Resources.Grid}"
                                    Style="{StaticResource PillToggleButton}"
                                    Unchecked="ChkGrid_Checked" />
                                <CheckBox
                                    x:Name="ChkPlayers"
                                    Margin="0,0,8,0"
                                    Checked="ChkPlayers_Checked"
                                    Content="{x:Static p:Resources.PlayersOnly}"
                                    IsChecked="True"
                                    Style="{StaticResource PillToggleButton}"
                                    Unchecked="ChkPlayers_Checked" />
                                <CheckBox
                                    x:Name="Monuments"
                                    Margin="0,0,8,0"
                                    Checked="Monuments_Checked"
                                    Content="{x:Static p:Resources.Monuments}"
                                    IsChecked="True"
                                    Style="{StaticResource PillToggleButton}"
                                    Unchecked="Monuments_Unchecked" />
                                <CheckBox
                                    x:Name="ChkShops"
                                    Margin="0,0,24,0"
                                    Checked="ChkShops_Checked"
                                    Content="{x:Static p:Resources.Shops}"
                                    Style="{StaticResource PillToggleButton}"
                                    Unchecked="ChkShops_Checked" />

                                <TextBlock
                                    Margin="0,0,16,0"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource TextSubtle}"
                                    Opacity="0.8"
                                    Text="{x:Static p:Resources.ChatAlerts}" />

                                <CheckBox
                                    x:Name="ChatAnnounce"
                                    Margin="0,0,8,0"
                                    Click="ChatAnnounce_Toggle"
                                    IsChecked="False"
                                    Style="{StaticResource PillToggleButton}"
                                    ToolTip="{x:Static p:Resources.RightClickConfigure}">
                                    <CheckBox.ContextMenu>
                                        <ContextMenu Style="{StaticResource DarkContextMenu}">
                                            <MenuItem
                                                Click="SelectAllAlerts_Click"
                                                Header="{x:Static p:Resources.SelectAll}"
                                                Style="{StaticResource DarkMenuItem}">
                                                <MenuItem.Icon>
                                                    <ui:SymbolIcon Symbol="CheckmarkSquare24" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem
                                                Click="DeselectAllAlerts_Click"
                                                Header="{x:Static p:Resources.DeselectAll}"
                                                Style="{StaticResource DarkMenuItem}">
                                                <MenuItem.Icon>
                                                    <ui:SymbolIcon Symbol="DismissSquare24" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </CheckBox.ContextMenu>
                                    <CheckBox.Content>
                                        <TextBlock
                                            x:Name="ChatAnnounceLabel"
                                            Text="{x:Static p:Resources.Alerts}" />
                                    </CheckBox.Content>
                                </CheckBox>

