                                                        <DataTrigger Binding="{Binding ServerTime}" Value="-">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ServerTime}" Value="–">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ServerTime}" Value="">
                                                            <Setter Property="Visibility" Value="Visible" />
