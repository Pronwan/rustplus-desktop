                                            PlacementTarget="{Binding ElementName=BtnToggleHeatmapGate}"
                                            StaysOpen="True"
                                            IsHitTestVisible="False">
                                            <ui:Card Margin="8,0,0,0" Padding="12,10" Background="#F20E1117" BorderBrush="#55FF8C00" BorderThickness="1" MaxWidth="280" IsHitTestVisible="False">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                        <ui:SymbolIcon Symbol="Info20" Foreground="#FF8C00" Margin="0,0,7,0" />
                                                        <TextBlock Text="Heatmaps unavailable" FontSize="13" FontWeight="SemiBold" Foreground="White" />
                                                    </StackPanel>
                                                    <TextBlock x:Name="TxtHeatmapAvailabilityMessage" Text="Generate the 3D map before using heatmaps." TextWrapping="Wrap" FontSize="12" Foreground="#D8FFFFFF" />
                                                </StackPanel>
                                            </ui:Card>
                                        </Popup>
                                        <Popup
                                            x:Name="HeatmapPopup"
                                            AllowsTransparency="True"
                                            PopupAnimation="Fade"
                                            IsOpen="False"
                                            Placement="Right"
                                            PlacementTarget="{Binding ElementName=BtnToggleHeatmap}"
                                            StaysOpen="False"
                                            VerticalOffset="0">
                                            <ui:Card Margin="8,0,0,0" Padding="0" Background="#D60E1117" BorderBrush="#33FFFFFF" BorderThickness="1" MaxWidth="620" MaxHeight="560">
                                                <ui:Card.Resources>

                                                    <!-- ════════════════════════════════════════════ -->
                                                    <!--  BENTO TILE CONTAINER (selection border)   -->
                                                    <!-- ════════════════════════════════════════════ -->
                                                    <Style x:Key="HeatmapTileContainer" TargetType="Border">
                                                        <Setter Property="Width" Value="64" />
                                                        <Setter Property="Height" Value="64" />
                                                        <Setter Property="CornerRadius" Value="8" />
                                                        <Setter Property="BorderThickness" Value="1.5" />
                                                        <Setter Property="BorderBrush" Value="Transparent" />
                                                        <Setter Property="Margin" Value="2" />
                                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                                        <Setter Property="VerticalAlignment" Value="Center" />
                                                        <Setter Property="Background" Value="#1A1F2E" />
                                                        <Setter Property="Effect">
                                                            <Setter.Value>
                                                                <DropShadowEffect BlurRadius="6" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.4" />
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>

                                                    <!-- ════════════════════════════════════════════ -->
                                                    <!--  BENTO TILE BUTTON (icon-only + hover)    -->
                                                    <!-- ════════════════════════════════════════════ -->
                                                    <Style x:Key="HeatmapTileButton" TargetType="Button">
                                                        <Setter Property="Cursor" Value="Hand" />
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <Setter Property="BorderThickness" Value="0" />
                                                        <Setter Property="Padding" Value="2" />
                                                        <Setter Property="Margin" Value="0" />
                                                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                                                        <Setter Property="VerticalAlignment" Value="Stretch" />
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                        <Grid>
                                                                        <Grid.RenderTransform>
                                                                             <ScaleTransform ScaleX="1" ScaleY="1" />
                                                                        </Grid.RenderTransform>

                                                                         <!-- Full-area hit-test background -->
                                                                         <Border Background="Transparent" />

                                                                         <!-- Hover glow layer -->
                                                                        <Border x:Name="HoverGlow" CornerRadius="8" Background="#FF8A00" Opacity="0" IsHitTestVisible="False" />

                                                                         <!-- Icon content (no label) -->
                                                                        <Border CornerRadius="8" Padding="0">
                                                                            <ContentPresenter x:Name="IconContent" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                              Width="42" Height="42">
                                                                                <ContentPresenter.RenderTransform>
                                                                                    <ScaleTransform ScaleX="1" ScaleY="1" />
                                                                                </ContentPresenter.RenderTransform>
                                                                            </ContentPresenter>
                                                                        </Border>

                                                                        <!-- Selection indicator ring -->
                                                                        <Border x:Name="SelectedRing" CornerRadius="8" BorderThickness="2" BorderBrush="#FF8A00"
                                                                                Opacity="0" IsHitTestVisible="False" />
                                                                        <!-- Checkmark badge -->
                                                                        <Border x:Name="CheckBadge" VerticalAlignment="Top" HorizontalAlignment="Right"
                                                                                Width="14" Height="14" CornerRadius="7" Background="#FF8A00"
                                                                                Margin="0,-3,-3,0" IsHitTestVisible="False" Opacity="0">
                                                                            <TextBlock Text="✓" FontSize="9" Foreground="White"
                                                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                        </Border>
                                                                    </Grid>
                                                                    <ControlTemplate.Triggers>
                                                                        <!-- HOVER: glow + scale-up -->
                                                                        <EventTrigger RoutedEvent="MouseEnter">
                                                                            <EventTrigger.Actions>
                                                                                <BeginStoryboard Name="HoverOn">
                                                                                    <Storyboard>
                                                                                        <DoubleAnimation Storyboard.TargetName="HoverGlow" Storyboard.TargetProperty="Opacity" To="0.18" Duration="0:0:0.15" />
                                                                                        <DoubleAnimation Storyboard.TargetName="IconContent" Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.05" Duration="0:0:0.15" />
                                                                                        <DoubleAnimation Storyboard.TargetName="IconContent" Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.05" Duration="0:0:0.15" />
                                                                                    </Storyboard>
                                                                                </BeginStoryboard>
                                                                            </EventTrigger.Actions>
                                                                        </EventTrigger>
                                                                        <EventTrigger RoutedEvent="MouseLeave">
                                                                            <EventTrigger.Actions>
                                                                                <BeginStoryboard Name="HoverOff">
                                                                                    <Storyboard>
                                                                                        <DoubleAnimation Storyboard.TargetName="HoverGlow" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2" />
                                                                                        <DoubleAnimation Storyboard.TargetName="IconContent" Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.0" Duration="0:0:0.2" />
                                                                                        <DoubleAnimation Storyboard.TargetName="IconContent" Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.0" Duration="0:0:0.2" />
                                                                                    </Storyboard>
                                                                                </BeginStoryboard>
                                                                            </EventTrigger.Actions>
                                                                        </EventTrigger>
                                                                        <!-- PRESSED: subtle scale down -->
                                                                        <Trigger Property="IsPressed" Value="True">
                                                                            <Setter TargetName="IconContent" Property="RenderTransform">
                                                                                <Setter.Value>
                                                                                    <ScaleTransform ScaleX="0.9" ScaleY="0.9" />
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </Trigger>
                                                                        <!-- DISABLED: dim -->
                                                                        <Trigger Property="IsEnabled" Value="False">
                                                                            <Setter TargetName="IconContent" Property="Opacity" Value="0.35" />
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>

                                                    <!-- ════════════════════════════════════════════ -->
                                                    <!--  CATEGORY CARD CONTAINER                   -->
                                                    <!-- ════════════════════════════════════════════ -->
                                                    <Style x:Key="CategoryCard" TargetType="Border">
                                                        <Setter Property="Background" Value="#121824" />
                                                        <Setter Property="BorderBrush" Value="#22FFFFFF" />
                                                        <Setter Property="BorderThickness" Value="1" />
                                                        <Setter Property="CornerRadius" Value="10" />
                                                        <Setter Property="Padding" Value="8" />
                                                    </Style>

                                                    <!-- ════════════════════════════════════════════ -->
                                                    <!--  ACTIVE HEATMAP TITLE BADGE                -->
                                                    <!-- ════════════════════════════════════════════ -->
                                                    <Style x:Key="ActiveBadge" TargetType="ui:Badge">
                                                        <Setter Property="Appearance" Value="Success" />
                                                        <Setter Property="Padding" Value="8,4" />
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </Style>

                                                </ui:Card.Resources>

                                                <!-- ════════════════════════════════════════════ -->
                                                <!--  MAIN LAYOUT                                -->
                                                <!-- ════════════════════════════════════════════ -->
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="*" />
                                                    </Grid.RowDefinitions>

                                                    <!-- ── ROW 0: HEADER ── -->
                                                    <Grid Grid.Row="0" Margin="14,12,14,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Title area -->
                                                        <Grid VerticalAlignment="Center">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="◉" FontSize="14" Foreground="#FF8A00" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                            <StackPanel Grid.Column="1">
                                                                <TextBlock Text="Procedural Heatmaps" FontSize="14" FontWeight="Bold" Foreground="#F2F2F2" />
                                                                <TextBlock Text="Select a layer to view spawn density" FontSize="10" Foreground="#9AA4B6" Margin="0,1,0,0" />
                                                            </StackPanel>
                                                            <!-- Active heatmap indicator -->
                                                            <ui:Badge x:Name="ActiveHeatmapBadge" Grid.Column="2" Style="{StaticResource ActiveBadge}" Margin="8,0,0,0" VerticalAlignment="Center">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Ellipse Width="6" Height="6" Fill="#22C55E" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                                    <TextBlock x:Name="ActiveHeatmapLabel" Text="No heatmap active" FontSize="10" Foreground="#9CA3AF" />
                                                                </StackPanel>
                                                            </ui:Badge>
                                                        </Grid>

                                                        <!-- Clear button -->
                                                        <ui:Button Grid.Column="1" Padding="8,6" Appearance="Secondary" Tag="clear"
                                                                   Click="BtnHeatmapIcon_Click" Height="30" VerticalAlignment="Top">
                                                            <StackPanel Orientation="Horizontal">
                                                                <ui:SymbolIcon Symbol="Dismiss20" FontSize="12" Foreground="#FF8A00" Margin="0,0,4,0" />
                                                                <TextBlock Text="Clear" FontSize="11" FontWeight="SemiBold" Foreground="#FF8A00" />
                                                            </StackPanel>
                                                        </ui:Button>
                                                    </Grid>

                                                    <!-- ── ROW 1: BENTO CATEGORY GRID ── -->
                                                    <ScrollViewer Grid.Row="1" Margin="14,10,14,14" VerticalScrollBarVisibility="Auto"
                                                                  HorizontalScrollBarVisibility="Disabled">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="1*" />
                                                                <ColumnDefinition Width="1*" />
                                                            </Grid.ColumnDefinitions>

                                                            <!-- ──── LEFT COLUMN ──── -->

                                                            <!-- Resources & Forestry -->
                                                            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CategoryCard}" Margin="0,0,6,8">
                                                                <StackPanel>
                                                                    <TextBlock FontSize="14" Foreground="#9AA4B6" Margin="6,6,0,8">
    <Run Text="⛏" /><Run Text="  Resources &amp; Forestry" FontSize="11" />
</TextBlock>
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="*" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <Border x:Name="Bento_ores" Grid.Column="0" Style="{StaticResource HeatmapTileContainer}">
                                                                            <Button Tag="ores" ToolTip="Ores" Style="{StaticResource HeatmapTileButton}"
                                                                                    Click="BtnHeatmapIcon_Click">
                                                                                <Image Source="pack://application:,,,/Assets/heatmap icons/nodes.png" Stretch="Uniform"
                                                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                                                            </Button>
                                                                        </Border>
                                                                        <Border x:Name="Bento_wood" Grid.Column="1" Style="{StaticResource HeatmapTileContainer}">
                                                                            <Button Tag="wood" ToolTip="Wood Piles" Style="{StaticResource HeatmapTileButton}"
                                                                                    Click="BtnHeatmapIcon_Click">
                                                                                <Image Source="pack://application:,,,/Assets/heatmap icons/wood-pile.png" Stretch="Uniform"
                                                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                                                            </Button>
                                                                        </Border>
                                                                        <Border x:Name="Bento_logs" Grid.Column="2" Style="{StaticResource HeatmapTileContainer}">
                                                                            <Button Tag="logs" ToolTip="Log Piles" Style="{StaticResource HeatmapTileButton}"
                                                                                    Click="BtnHeatmapIcon_Click">
                                                                                <Image Source="pack://application:,,,/Assets/heatmap icons/logs.png" Stretch="Uniform"
                                                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                                                            </Button>
                                                                        </Border>
                                                                    </Grid>
                                                                    <Grid Margin="0,6,0,0">
                                                                        <Border x:Name="Bento_flowers" Style="{StaticResource HeatmapTileContainer}">
                                                                            <Button Tag="flowers" ToolTip="Flowers" Style="{StaticResource HeatmapTileButton}"
                                                                                    Click="BtnHeatmapIcon_Click">
                                                                                <Image Source="pack://application:,,,/Assets/heatmap icons/Flowers/flowers.png" Stretch="Uniform"
                                                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                                                            </Button>
                                                                        </Border>
                                                                    </Grid>
                                                                </StackPanel>
                                                            </Border>

                                                            <!-- Agriculture & Food -->
                                                            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CategoryCard}" Margin="0,0,6,0">
                                                                <StackPanel>
                                                                    <TextBlock FontSize="14" Foreground="#9AA4B6" Margin="6,6,0,8">
    <Run Text="🌾" /><Run Text="  Agriculture &amp; Food" FontSize="11" />
</TextBlock>
                                                                    <UniformGrid Columns="3">
                                                                        <Border x:Name="Bento_mushroom" Style="{StaticResource HeatmapTileContainer}">
                                                                            <Button Tag="mushroom" ToolTip="Mushrooms" Style="{StaticResource HeatmapTileButton}"
                                                                                    Click="BtnHeatmapIcon_Click">
                                                                                <Image Source="pack://application:,,,/Assets/heatmap icons/Food/mushroom.png" Stretch="Uniform"
                                                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                                                            </Button>
                                                                        </Border>
                                                                        <Border x:Name="Bento_berries" Style="{StaticResource HeatmapTileContainer}">
                                                                            <Button Tag="berries" ToolTip="Berries" Style="{StaticResource HeatmapTileButton}"
                                                                                    Click="BtnHeatmapIcon_Click">
                                                                                <Image Source="pack://application:,,,/Assets/heatmap icons/Food/red-berry.png" Stretch="Uniform"
                                                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                                                            </Button>
                                                                        </Border>
                                                                        <Border x:Name="Bento_corn" Style="{StaticResource HeatmapTileContainer}">
                                                                            <Button Tag="corn" ToolTip="Corn" Style="{StaticResource HeatmapTileButton}"
                                                                                    Click="BtnHeatmapIcon_Click">
                                                                                <Image Source="pack://application:,,,/Assets/heatmap icons/Food/corn.png" Stretch="Uniform"
                                                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                                                            </Button>
                                                                        </Border>
                                                                        <Border x:Name="Bento_pumpkin" Style="{StaticResource HeatmapTileContainer}">
                                                                            <Button Tag="pumpkin" ToolTip="Pumpkins" Style="{StaticResource HeatmapTileButton}"
                                                                                    Click="BtnHeatmapIcon_Click">
                                                                                <Image Source="pack://application:,,,/Assets/heatmap icons/Food/pumpkin.png" Stretch="Uniform"
                                                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                                                            </Button>
                                                                        </Border>
                                                                        <Border x:Name="Bento_potato" Style="{StaticResource HeatmapTileContainer}">
                                                                            <Button Tag="potato" ToolTip="Potatoes" Style="{StaticResource HeatmapTileButton}"
                                                                                    Click="BtnHeatmapIcon_Click">
                                                                                <Image Source="pack://application:,,,/Assets/heatmap icons/Food/potato.png" Stretch="Uniform"
                                                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                                                            </Button>
                                                                        </Border>
                                                                        <Border x:Name="Bento_wheat" Style="{StaticResource HeatmapTileContainer}">
                                                                            <Button Tag="wheat" ToolTip="Wheat" Style="{StaticResource HeatmapTileButton}"
                                                                                    Click="BtnHeatmapIcon_Click">
                                                                                <Image Source="pack://application:,,,/Assets/heatmap icons/Food/wheat.png" Stretch="Uniform"
                                                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                                                            </Button>
                                                                        </Border>
                                                                    </UniformGrid>
                                                                </StackPanel>
                                                            </Border>

                                                            <!-- ──── RIGHT COLUMN ──── -->

                                                            <!-- Loot & Transport -->
                                                            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource CategoryCard}" Margin="6,0,0,8">
                                                                <StackPanel>
                                                                    <TextBlock FontSize="14" Foreground="#9AA4B6" Margin="6,6,0,8">
    <Run Text="📦" /><Run Text="  Loot &amp; Transport" FontSize="11" />
</TextBlock>
                                                                    <UniformGrid Columns="3">
                                                                        <Border x:Name="Bento_junkpiles" Style="{StaticResource HeatmapTileContainer}">
                                                                            <Button Tag="junkpiles" ToolTip="Junkpiles" Style="{StaticResource HeatmapTileButton}"
                                                                                    Click="BtnHeatmapIcon_Click">
                                                                                <Image Source="pack://application:,,,/Assets/heatmap icons/loot-barrel-1.png" Stretch="Uniform"
                                                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                                                            </Button>
                                                                        </Border>
                                                                        <Border x:Name="Bento_rowboat" Style="{StaticResource HeatmapTileContainer}">
                                                                            <Button Tag="rowboat" ToolTip="Rowboats" Style="{StaticResource HeatmapTileButton}"
                                                                                    Click="BtnHeatmapIcon_Click">
                                                                                <Image Source="pack://application:,,,/Assets/heatmap icons/rowboat.png" Stretch="Uniform"
                                                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                                                            </Button>
                                                                        </Border>
                                                                        <Border x:Name="Bento_modularcar" Style="{StaticResource HeatmapTileContainer}">
                                                                            <Button Tag="modularcar" ToolTip="Modular Cars" Style="{StaticResource HeatmapTileButton}"
                                                                                    Click="BtnHeatmapIcon_Click">
                                                                                <Image Source="pack://application:,,,/Assets/heatmap icons/modular-car.png" Stretch="Uniform"
                                                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                                                            </Button>
                                                                        </Border>
                                                                        <Border x:Name="Bento_horse" Style="{StaticResource HeatmapTileContainer}">
                                                                            <Button Tag="horse" ToolTip="Horses" Style="{StaticResource HeatmapTileButton}"
                                                                                    Click="BtnHeatmapIcon_Click">
                                                                                <Image Source="pack://application:,,,/Assets/heatmap icons/animals icons/horse.png" Stretch="Uniform"
                                                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                                                            </Button>
                                                                        </Border>
                                                                        <Border x:Name="Bento_pedalbike" Style="{StaticResource HeatmapTileContainer}">
                                                                            <Button Tag="pedalbike" ToolTip="Bicycles" Style="{StaticResource HeatmapTileButton}"
                                                                                    Click="BtnHeatmapIcon_Click">
                                                                                <Image Source="pack://application:,,,/Assets/heatmap icons/bicycle.png" Stretch="Uniform"
                                                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                                                            </Button>
                                                                        </Border>
                                                                        <Border x:Name="Bento_hab" Style="{StaticResource HeatmapTileContainer}">
                                                                            <Button Tag="hab" ToolTip="Hot Air Balloons" Style="{StaticResource HeatmapTileButton}"
                                                                                    Click="BtnHeatmapIcon_Click">
                                                                                <Image Source="pack://application:,,,/Assets/heatmap icons/hab.png" Stretch="Uniform"
                                                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                                                            </Button>
                                                                        </Border>
                                                                    </UniformGrid>
                                                                </StackPanel>
                                                            </Border>

                                                            <!-- Fauna & Wildlife -->
                                                            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CategoryCard}" Margin="6,0,0,0">
                                                                <StackPanel>
                                                                    <TextBlock FontSize="14" Foreground="#9AA4B6" Margin="6,6,0,8">
    <Run Text="🐾" /><Run Text="  Fauna &amp; Wildlife" FontSize="11" />
</TextBlock>
                                                                    <UniformGrid Columns="4">
                                                                        <Border x:Name="Bento_bear" Style="{StaticResource HeatmapTileContainer}">
                                                                            <Button Tag="bear" ToolTip="Bears" Style="{StaticResource HeatmapTileButton}"
                                                                                    Click="BtnHeatmapIcon_Click">
                                                                                <Image Source="pack://application:,,,/Assets/heatmap icons/animals icons/bear.png" Stretch="Uniform"
                                                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                                                            </Button>
                                                                        </Border>
                                                                        <Border x:Name="Bento_boar" Style="{StaticResource HeatmapTileContainer}">
                                                                            <Button Tag="boar" ToolTip="Boars" Style="{StaticResource HeatmapTileButton}"
                                                                                    Click="BtnHeatmapIcon_Click">
                                                                                <Image Source="pack://application:,,,/Assets/heatmap icons/animals icons/boar.png" Stretch="Uniform"
                                                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                                                            </Button>
                                                                        </Border>
                                                                        <Border x:Name="Bento_chicken" Style="{StaticResource HeatmapTileContainer}">
                                                                            <Button Tag="chicken" ToolTip="Chickens" Style="{StaticResource HeatmapTileButton}"
                                                                                    Click="BtnHeatmapIcon_Click">
                                                                                <Image Source="pack://application:,,,/Assets/heatmap icons/animals icons/chicken.png" Stretch="Uniform"
                                                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                                                            </Button>
                                                                        </Border>
                                                                        <Border x:Name="Bento_wolf" Style="{StaticResource HeatmapTileContainer}">
                                                                            <Button Tag="wolf" ToolTip="Wolves" Style="{StaticResource HeatmapTileButton}"
                                                                                    Click="BtnHeatmapIcon_Click">
                                                                                <Image Source="pack://application:,,,/Assets/heatmap icons/animals icons/wolf.png" Stretch="Uniform"
                                                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                                                            </Button>
                                                                        </Border>
                                                                        <Border x:Name="Bento_stag" Style="{StaticResource HeatmapTileContainer}">
                                                                            <Button Tag="stag" ToolTip="Deers" Style="{StaticResource HeatmapTileButton}"
                                                                                    Click="BtnHeatmapIcon_Click">
                                                                                <Image Source="pack://application:,,,/Assets/heatmap icons/animals icons/stag.png" Stretch="Uniform"
                                                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                                                            </Button>
                                                                        </Border>
                                                                        <Border x:Name="Bento_crocodile" Style="{StaticResource HeatmapTileContainer}">
                                                                            <Button Tag="crocodile" ToolTip="Crocodiles" Style="{StaticResource HeatmapTileButton}"
                                                                                    Click="BtnHeatmapIcon_Click">
                                                                                <Image Source="pack://application:,,,/Assets/heatmap icons/animals icons/crocodile.png" Stretch="Uniform"
                                                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                                                            </Button>
                                                                        </Border>
                                                                        <Border x:Name="Bento_tiger" Style="{StaticResource HeatmapTileContainer}">
                                                                            <Button Tag="tiger" ToolTip="Tigers" Style="{StaticResource HeatmapTileButton}"
                                                                                    Click="BtnHeatmapIcon_Click">
                                                                                <Image Source="pack://application:,,,/Assets/heatmap icons/animals icons/tiger.png" Stretch="Uniform"
                                                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                                                            </Button>
                                                                        </Border>
                                                                        <Border x:Name="Bento_snake" Style="{StaticResource HeatmapTileContainer}">
                                                                            <Button Tag="snake" ToolTip="Snakes" Style="{StaticResource HeatmapTileButton}"
                                                                                    Click="BtnHeatmapIcon_Click">
                                                                                <Image Source="pack://application:,,,/Assets/heatmap icons/animals icons/snake.png" Stretch="Uniform"
                                                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                                                            </Button>
                                                                        </Border>
                                                                    </UniformGrid>
                                                                </StackPanel>
                                                            </Border>

                                                        </Grid>
                                                    </ScrollViewer>
                                                </Grid>
                                            </ui:Card>
                                        </Popup>

                                    </WrapPanel>
                                </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </ui:Card>

                                <!--  SUBSCRIPTION DOCK  -->
                                <ui:Card
                                    x:Name="SubscriptionDock"
                                    Margin="0,6,0,0"
                                    Padding="6"
                                    Background="#AA16181C"
                                    BorderBrush="#40FFFFFF"
                                    BorderThickness="1"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Visibility="Collapsed">
                                    <StackPanel Orientation="Vertical">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="240" HorizontalScrollBarVisibility="Disabled">
                                            <StackPanel x:Name="SubscriptionStack" Orientation="Vertical" />
                                        </ScrollViewer><ui:Button
                                            x:Name="DockEditSubscriptionsButton"
                                            Margin="0,4,0,0"
                                            Padding="4"
                                            Width="36"
                                            Height="36"
                                            HorizontalAlignment="Center"
                                            Click="DockEditSubscriptionsButton_Click"
                                            ToolTip="Edit Subscriptions (Drawing Overlay)">
                                            <ui:Button.Style>
                                                <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMouseOver, ElementName=SubscriptionDock}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:Button.Style>
                                            <ui:SymbolIcon Symbol="Edit24" Foreground="White" FontSize="18" />
                                        </ui:Button>
                                    </StackPanel>
                                </ui:Card>
                            </StackPanel>

                            <ui:Card
                                x:Name="FollowOverlay"
                                Margin="8,0,0,0"
                                Padding="0"
                                Height="38"
                                Background="#AA16181C"
                                BorderBrush="#40FFFFFF"
                                BorderThickness="1"
                                VerticalAlignment="Top">
                                <Grid>
                                    <!--  Active Glow  -->
                                    <Ellipse
                                        Width="32"
                                        Height="32"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Fill="#4000C8FF">
                                        <Ellipse.Effect>
                                            <BlurEffect Radius="15" />
                                        </Ellipse.Effect>
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFollowing}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>

                                    <ui:Button
                                        x:Name="BtnFollowPlayer"
                                        Height="36"
                                        Padding="4,0"
                                        Appearance="Transparent"
                                        Click="BtnFollowPlayer_Click"
                                        IsEnabled="{Binding Selected.IsFullConnected, FallbackValue=False}"
                                        ToolTip="{DynamicResource FollowPlayer}">
                                        <StackPanel Orientation="Horizontal">
                                            <!--  Avatar or Default Icon  -->
                                            <Grid Width="24" Height="24">
                                                <!--  Default Icon (Placeholder)  -->
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontFamily="Segoe MDL2 Assets"
                                                    FontSize="14"
                                                    Foreground="#8D98A8"
                                                    Text="&#xE77B;">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsFollowing}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <!--  Real Avatar  -->
                                                <Image
                                                    Width="24"
                                                    Height="24"
                                                    ClipToBounds="True"
                                                    Source="{Binding FollowingPlayerAvatar}"
                                                    Stretch="UniformToFill"
                                                    RenderOptions.BitmapScalingMode="HighQuality">
                                                    <Image.Clip>
                                                        <EllipseGeometry
                                                            Center="12,12"
                                                            RadiusX="12"
                                                            RadiusY="12" />
                                                    </Image.Clip>
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsFollowing}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                    <Setter Property="Effect">
                                                                        <Setter.Value>
                                                                            <DropShadowEffect
                                                                                BlurRadius="8"
                                                                                Opacity="0.8"
                                                                                ShadowDepth="0"
                                                                                Color="Cyan" />
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                </Image>

                                                <!--  Active Icon Overlay (small dot or similar if needed)  -->
                                            </Grid>

                                            <TextBlock
                                                x:Name="IconFollow"
                                                Margin="4,0,0,0"
                                                VerticalAlignment="Center"
                                                FontFamily="Segoe MDL2 Assets"
                                                FontSize="10"
                                                Foreground="#8D98A8"
                                                Text="&#xE70D;" />
                                        </StackPanel>
                                        <ui:Button.ContextMenu>
                                            <ContextMenu x:Name="MenuFollowPlayer">
                                                <!--  Dynamically filled  -->
                                            </ContextMenu>
                                        </ui:Button.ContextMenu>
                                    </ui:Button>
                                </Grid>
                            </ui:Card>

                            <ui:Card
                                x:Name="MonumentsToggleOverlay"
                                Margin="8,0,0,0"
                                Padding="0"
                                Height="38"
                                Background="#AA16181C"
                                BorderBrush="#40FFFFFF"
                                BorderThickness="1"
                                VerticalAlignment="Top">
                                <Grid>
                                    <ui:Button
                                        x:Name="BtnToggleMonumentsPanel"
                                        Height="36"
                                        Padding="4,0"
                                        Appearance="Transparent"
                                        Click="BtnToggleMonumentsPanel_Click"
                                        IsEnabled="{Binding Selected.IsFullConnected, FallbackValue=False}"
                                        ToolTip="Toggle Monument List">
                                        <StackPanel Orientation="Horizontal" Margin="4,0" VerticalAlignment="Center">
                                            <TextBlock
                                                FontFamily="Segoe MDL2 Assets"
                                                FontSize="14"
                                                Foreground="#8D98A8"
                                                Text="&#xE707;" 
                                                VerticalAlignment="Center"/>
                                            <TextBlock
                                                Text="Monuments"
                                                Margin="6,0,4,0"
                                                FontSize="12"
                                                FontWeight="Bold"
                                                Foreground="White"
                                                VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </ui:Button>
                                </Grid>
                            </ui:Card>
                            
                            <ui:Card
                                x:Name="WipeDeathMarkersOverlay"
                                Margin="8,0,0,0"
                                Padding="0"
                                Height="38"
                                Background="#AA16181C"
                                BorderBrush="#40FFFFFF"
                                BorderThickness="1"
                                VerticalAlignment="Top"
                                Visibility="Collapsed">
                                <Grid>
                                    <ui:Button
                                        x:Name="BtnWipeDeathMarkers"
                                        Height="36"
                                        Padding="4,0"
                                        Appearance="Transparent"
                                        Click="BtnWipeDeathMarkers_Click"
                                        ToolTip="{DynamicResource WipeDeathMarkers}">
                                        <StackPanel Orientation="Horizontal" Margin="4,0" VerticalAlignment="Center">
                                            <Grid Width="14" Height="16" Margin="0,0,4,0">
                                                <Path Width="14" Height="16" Data="M20,0 C31,0 40,9 40,20 C40,33 20,56 20,56 C20,56 0,33 0,20 C0,9 9,0 20,0 Z" Fill="IndianRed" Stretch="Uniform" Stroke="Black" StrokeThickness="1" />
                                            </Grid>
                                            <ui:SymbolIcon Symbol="Delete24" Foreground="IndianRed" FontSize="14" />
                                        </StackPanel>
                                    </ui:Button>
                                </Grid>
                            </ui:Card>
                        </StackPanel>


                        <!--  LIVE EVENT DOCK & TIMER DOCK (Top Right)  -->
                        <StackPanel
                            Margin="15,45,15,15"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Panel.ZIndex="100"
                            Orientation="Vertical">
                            
                            <StackPanel
                                x:Name="EventDock"
                                Orientation="Vertical" />
                            
                            <ui:Button
                                x:Name="BtnCustomTimer"
                                HorizontalAlignment="Right"
                                Margin="0,10,0,0"
                                Padding="8"
                                Background="#AA16181C"
                                BorderBrush="#40FFFFFF"
                                BorderThickness="1"
                                CornerRadius="12"
                                Appearance="Transparent"
                                Click="BtnCustomTimer_Click"
                                ToolTip="{DynamicResource HoverCustomTimer}">
                                <ui:SymbolIcon x:Name="IconCustomTimer" Symbol="Timer24" FontSize="20" Foreground="{DynamicResource TextPrimary}" />
                            </ui:Button>
                            
                            <Popup x:Name="PopupCustomTimer" AllowsTransparency="True" StaysOpen="False" PlacementTarget="{Binding ElementName=BtnCustomTimer}" Placement="Left" HorizontalOffset="-10">
                                <ui:Card Margin="0,0,10,10" Padding="16" MinWidth="320" MaxWidth="360" Background="#AA16181C" BorderBrush="#40FFFFFF" BorderThickness="1">
                                    <ui:Card.Resources>
                                        <Style x:Key="WpfUiToggleButtonStyle" TargetType="ToggleButton">
                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                            <Setter Property="Background" Value="#12FFFFFF"/>
                                            <Setter Property="BorderBrush" Value="#16FFFFFF"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="Width" Value="32"/>
                                            <Setter Property="Height" Value="32"/>
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0,0,6,0"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border x:Name="Bd"
                                                                Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="5">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#40FFFFFF"/>
                                                            </Trigger>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Accent}"/>
                                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                                                <Setter Property="Foreground" Value="Black"/>
                                                            </Trigger>
                                                            <MultiTrigger>
                                                                <MultiTrigger.Conditions>
                                                                    <Condition Property="IsChecked" Value="True"/>
                                                                    <Condition Property="IsMouseOver" Value="True"/>
                                                                </MultiTrigger.Conditions>
                                                                <Setter TargetName="Bd" Property="Background" Value="#80CDFF"/>
                                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#80CDFF"/>
                                                                <Setter Property="Foreground" Value="Black"/>
                                                            </MultiTrigger>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ui:Card.Resources>
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource ActiveTimersCategory}" FontWeight="SemiBold" Margin="0,0,0,12" FontSize="13" />
                                        
                                        <!-- List of active timers -->
                                        <ItemsControl x:Name="ListActiveTimers">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" ToolTip="{Binding Name}" Margin="4,0,8,0">
                                                            <Run Text="{Binding Name}" />
                                                            <Run Text=" (" Foreground="{DynamicResource TextSubtle}" FontSize="11" />
                                                            <Run Text="{Binding PlacementTarget.DataContext.Selected.ChatCommandPrefix, RelativeSource={RelativeSource AncestorType=Popup}}" Foreground="{DynamicResource TextSubtle}" FontSize="11" />
                                                            <Run Text="{Binding Command}" Foreground="{DynamicResource TextSubtle}" FontSize="11" />
                                                            <Run Text=")" Foreground="{DynamicResource TextSubtle}" FontSize="11" />
                                                        </TextBlock>
                                                        <TextBlock Grid.Column="1" Text="{Binding RemainingTimeText}" VerticalAlignment="Center" Margin="0,0,12,0" FontFamily="Consolas" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Accent}" />
                                                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                            <ToggleButton IsChecked="{Binding EnableCountdownAudio}" Style="{StaticResource WpfUiToggleButtonStyle}" ToolTip="Play 1min countdown audio">
                                                                <ui:SymbolIcon Symbol="Hourglass24" FontSize="14" Foreground="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}" />
                                                            </ToggleButton>
                                                            <ToggleButton IsChecked="{Binding EnableAlarmAudio}" Style="{StaticResource WpfUiToggleButtonStyle}" ToolTip="Play loud alarm at 00:00">
                                                                <ui:SymbolIcon Symbol="Alert24" FontSize="14" Foreground="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}" />
                                                            </ToggleButton>
                                                            <ui:Button Appearance="Transparent" Width="32" Height="32" Padding="0" Tag="{Binding Id}" Click="BtnDeleteTimer_Click" ToolTip="Delete Timer">
                                                                <ui:SymbolIcon Symbol="Dismiss24" Foreground="IndianRed" FontSize="14" />
                                                            </ui:Button>
                                                        </StackPanel>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        
                                        <!-- Add Timer Section -->
                                        <Border BorderThickness="0,1,0,0" BorderBrush="{DynamicResource ControlStrokeDefault}" Margin="0,8,0,12" Padding="0,12,0,0">
                                            <StackPanel>
                                                <TextBlock Text="{DynamicResource AddTimer}" FontWeight="SemiBold" Margin="0,0,0,12" FontSize="13" />
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ui:TextBox x:Name="TxtTimerName" PlaceholderText="{DynamicResource TimerName}" TextChanged="TxtTimerName_TextChanged" Height="32" Padding="8,4" VerticalContentAlignment="Center" />
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0" VerticalAlignment="Center">
                                                        <ui:TextBox x:Name="TxtTimerHours" ClearButtonEnabled="False" PlaceholderText="hh" MaxLength="2" Width="42" Height="32" Padding="0,4" TextAlignment="Center" VerticalContentAlignment="Center" />
                                                        <TextBlock Text=":" VerticalAlignment="Center" Margin="2,0,2,0" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextSubtle}" />
                                                        <ui:TextBox x:Name="TxtTimerMinutes" ClearButtonEnabled="False" PlaceholderText="mm" MaxLength="2" Width="42" Height="32" Padding="0,4" TextAlignment="Center" VerticalContentAlignment="Center" />
                                                        <TextBlock Text=":" VerticalAlignment="Center" Margin="2,0,2,0" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextSubtle}" />
                                                        <ui:TextBox x:Name="TxtTimerSeconds" ClearButtonEnabled="False" PlaceholderText="ss" MaxLength="2" Width="42" Height="32" Padding="0,4" TextAlignment="Center" VerticalContentAlignment="Center" />
                                                    </StackPanel>
                                                </Grid>
                                                
                                                <TextBlock x:Name="TxtTimerValidation" Foreground="IndianRed" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <Trigger Property="Text" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </Trigger>
                                                                <Trigger Property="Text" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                
                                                <Grid Margin="0,4,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0,0,0">
                                                        <TextBlock Text="{Binding PlacementTarget.DataContext.Selected.ChatCommandPrefix, RelativeSource={RelativeSource AncestorType=Popup}}" Foreground="{DynamicResource TextSubtle}" FontWeight="Bold" Margin="0,0,2,0" />
                                                        <TextBlock x:Name="TxtTimerCommandPreview" Text="" Foreground="{DynamicResource TextSubtle}" />
                                                    </StackPanel>
                                                    
                                                    <ToggleButton x:Name="TglAddTimerCountdown" Grid.Column="1" IsChecked="True" Style="{StaticResource WpfUiToggleButtonStyle}" ToolTip="Play 1min countdown audio">
                                                        <ui:SymbolIcon Symbol="Hourglass24" FontSize="14" Foreground="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}" />
                                                    </ToggleButton>
                                                    <ToggleButton x:Name="TglAddTimerAlarm" Grid.Column="2" IsChecked="False" Style="{StaticResource WpfUiToggleButtonStyle}" ToolTip="Play loud alarm at 00:00" Margin="0,0,10,0">
                                                        <ui:SymbolIcon Symbol="Alert24" FontSize="14" Foreground="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}" />
                                                    </ToggleButton>

                                                    <ui:Button Grid.Column="3" x:Name="BtnAddTimer" Content="{DynamicResource AddTimer}" Appearance="Primary" Padding="14,6" Height="32" CornerRadius="5" Click="BtnAddTimer_Click" />
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- Timer Alarm Controls -->
                                        <Border BorderThickness="0,1,0,0" BorderBrush="{DynamicResource ControlStrokeDefault}" Margin="0,8,0,0" Padding="0,12,0,0">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ui:Button x:Name="BtnStopTimerAlarm" Visibility="Collapsed" Appearance="Secondary" Padding="12,6" Margin="0,0,6,0" Height="32" CornerRadius="5" Click="BtnStopTimerAlarm_Click" ToolTip="Stop alarm sound">
                                                        <StackPanel Orientation="Horizontal">
                                                            <ui:SymbolIcon Symbol="SpeakerMute24" Foreground="IndianRed" FontSize="16" />
                                                            <TextBlock Text="Stop" Margin="6,0,0,0" VerticalAlignment="Center" Foreground="IndianRed" FontWeight="SemiBold" />
                                                        </StackPanel>
                                                    </ui:Button>
                                                    <ui:Button x:Name="BtnSnoozeTimerAlarm" Grid.Column="1" Visibility="Collapsed" Appearance="Secondary" Padding="12,6" Margin="0,0,6,0" Height="32" CornerRadius="5" Click="BtnSnoozeTimerAlarm_Click" ToolTip="Snooze alarm">
                                                        <StackPanel Orientation="Horizontal">
                                                            <ui:SymbolIcon Symbol="ClockAlarm24" Foreground="#FFA500" FontSize="16" />
                                                            <TextBlock Text="Snooze" Margin="6,0,0,0" VerticalAlignment="Center" Foreground="#FFA500" FontWeight="SemiBold" />
                                                        </StackPanel>
                                                    </ui:Button>
                                                    
                                                    <!-- Spacer Column (Column 2) -->
                                                    
                                                    <ui:Button Grid.Column="3" Appearance="Secondary" Padding="8,6" Margin="0,0,6,0" Height="32" CornerRadius="5" Click="BtnSelectTimerCountdownAudio_Click" ToolTip="Select custom 1-minute countdown sound">
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                            <ui:SymbolIcon Symbol="Hourglass24" FontSize="16" />
                                                            <TextBlock Text="1min" FontSize="11" Margin="4,0,0,0" VerticalAlignment="Center" />
                                                        </StackPanel>
                                                    </ui:Button>
                                                    <ui:Button Grid.Column="4" Appearance="Secondary" Padding="8,6" Margin="0,0,6,0" Height="32" Width="32" CornerRadius="5" Click="BtnSelectTimerAlarmAudio_Click" ToolTip="Select custom alarm sound (00:00)">
                                                        <ui:SymbolIcon Symbol="MusicNote224" FontSize="16" />
                                                    </ui:Button>
                                                    <ui:Button Grid.Column="5" Appearance="Secondary" Padding="8,6" Height="32" Width="32" CornerRadius="5" Click="BtnResetTimerAlarmAudio_Click" ToolTip="Reset sounds to default">
                                                        <ui:SymbolIcon Symbol="ArrowReset24" FontSize="16" />
                                                    </ui:Button>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ui:Card>
                            </Popup>
                        </StackPanel>

                        <Canvas x:Name="GridLayer" IsHitTestVisible="False" />
                        <Canvas x:Name="Overlay" IsHitTestVisible="True" />

                        <!-- Monument Navigation Panel -->
                        <Border
                            x:Name="MonumentNavPanel"
                            Width="280"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            Margin="15,70,0,15"
                            Panel.ZIndex="1050"
                            Background="#E5101217"
                            BorderBrush="#40FFFFFF"
                            BorderThickness="0"
                            CornerRadius="12"
                            Visibility="Collapsed">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="15"
                                    Opacity="0.6"
                                    ShadowDepth="0"
                                    Color="Black" />
                            </Border.Effect>
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                
                                <!-- Header -->
                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <TextBlock
                                        Text="Monuments"
                                        FontSize="16"
                                        FontWeight="Bold"
                                        Foreground="White"
                                        VerticalAlignment="Center"/>
                                    <Button
                                        x:Name="BtnCloseMonumentNav"
                                        Width="24"
                                        Height="24"
                                        HorizontalAlignment="Right"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        Style="{StaticResource GhostButton}"
                                        Click="BtnToggleMonumentsPanel_Click"
                                        Content="&#x2715;"
                                        Foreground="#8D98A8"
                                        FontSize="12"/>
                                </Grid>
                                
                                <!-- Search Box -->
                                <ui:TextBox
                                    x:Name="TxtMonumentSearch"
                                    Grid.Row="1"
                                    PlaceholderText="Search monument..."
                                    Margin="0,0,0,10"
                                    TextChanged="TxtMonumentSearch_TextChanged" />
                                    
                                <!-- Monument List -->
                                <ScrollViewer
                                    Grid.Row="2"
                                    VerticalScrollBarVisibility="Auto"
                                    HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel x:Name="MonumentListContainer" />
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <!--  Shop Details Panel (Clamped to Map Container)  -->
                        <Border
                            x:Name="ShopDetailsPopup"
                            Width="340"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Panel.ZIndex="1100"
                            Background="#1E2126"
                            BorderBrush="#60FFFFFF"
                            BorderThickness="1"
                            CornerRadius="12"
                            Visibility="Collapsed">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="15"
                                    Opacity="0.6"
                                    ShadowDepth="0"
                                    Color="Black" />
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Button
                                    x:Name="BtnCloseShopDetails"
                                    Width="30"
                                    Height="30"
                                    HorizontalAlignment="Right"
                                    Panel.ZIndex="10"
                                    Click="BtnCloseShopDetails_Click"
                                    Content="&#x2715;"
                                    FontSize="14"
                                    Foreground="Gray"
                                    Style="{StaticResource GhostButton}" />

                                <ScrollViewer
                                    x:Name="ShopDetailsScroll"
                                    Grid.Row="1"
                                    MaxHeight="600"
                                    HorizontalScrollBarVisibility="Disabled"
                                    VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="ShopDetailsContent" Margin="12,4,12,12" />
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <!-- Base Hover Preview Popup -->
                        <Border
                            x:Name="BaseHoverPopup"
                            Width="260"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Panel.ZIndex="1100"
                            Background="#1A1D21"
                            BorderBrush="#40FFFFFF"
                            BorderThickness="1"
                            CornerRadius="10"
                            Visibility="Collapsed"
                            MouseEnter="BaseHoverPopup_MouseEnter"
                            MouseLeave="BaseHoverPopup_MouseLeave">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" Opacity="0.5" ShadowDepth="0" Color="Black"/>
                            </Border.Effect>
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <Button
                                    x:Name="BtnCloseBaseHover"
                                    Width="24"
                                    Height="24"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Click="BtnCloseBaseHover_Click"
                                    Content="&#x00D7;"
                                    FontSize="13"
                                    FontWeight="Bold"
                                    Foreground="Gray"
                                    Style="{StaticResource GhostButton}" />

                                <StackPanel Grid.Row="0" Margin="0,0,24,0">
                                    <TextBlock x:Name="TxtBaseHoverNote"
                                               Foreground="White"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               MaxHeight="60"/>
                                </StackPanel>

                                <Border Grid.Row="1" x:Name="BorderBaseHoverImage" Margin="0,8,0,0" CornerRadius="6" ClipToBounds="True" Background="#10FFFFFF" Visibility="Collapsed">
                                    <Image x:Name="ImgBaseHoverScreenshot" Stretch="Uniform" MaxHeight="150"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Base Detailed Gallery Popup -->
                        <Border
                            x:Name="BaseGalleryPopup"
                            Width="540"
                            Height="480"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Panel.ZIndex="1200"
                            Background="#1A1D21"
                            BorderBrush="#40FFFFFF"
                            BorderThickness="1"
                            CornerRadius="14"
                            Visibility="Collapsed">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="20" Opacity="0.7" ShadowDepth="0" Color="Black"/>
                            </Border.Effect>
                            <Grid Margin="16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Title / Close -->
                                <DockPanel Grid.Row="0" Margin="0,0,0,10">
                                    <TextBlock Text="Base Details" FontSize="16" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                    <Button
                                        Width="28"
                                        Height="28"
                                        HorizontalAlignment="Right"
                                        Click="BtnCloseBaseGallery_Click"
                                        Content="&#x00D7;"
                                        FontSize="14"
                                        FontWeight="Bold"
                                        Foreground="Gray"
                                        Style="{StaticResource GhostButton}" />
                                </DockPanel>

                                <!-- Mid Panel (Gallery & Active Image Zoom Container) -->
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <!-- Thumbnail Strip (left) -->
                                        <ColumnDefinition Width="70"/>
                                        <!-- Main Image View (right) -->
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Thumbnails List -->
                                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,6,0">
                                        <StackPanel x:Name="BaseGalleryThumbsPanel" Orientation="Vertical"/>
                                    </ScrollViewer>

                                    <!-- Main Image Zoom Area -->
                                    <Grid Grid.Column="1" x:Name="BaseGalleryMainImageArea" Background="#0C0D0F" ClipToBounds="True"
                                          MouseMove="MainImage_MouseMove" MouseLeave="MainImage_MouseLeave" MouseEnter="MainImage_MouseEnter">
                                        <Image x:Name="ImgBaseGalleryMain" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        
                                        <!-- Loupe Magnifying circular Border (lens) -->
                                        <Canvas IsHitTestVisible="False">
                                            <Border x:Name="BaseGalleryMagnifierLens" Width="150" Height="150" CornerRadius="75" BorderBrush="White" BorderThickness="2" Visibility="Collapsed" IsHitTestVisible="False">
                                                <Border.Background>
                                                    <VisualBrush x:Name="BaseGalleryMagnifierBrush" Visual="{Binding ElementName=ImgBaseGalleryMain}" ViewboxUnits="Absolute" ViewportUnits="RelativeToBoundingBox" Viewport="0,0,1,1"/>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="8" Opacity="0.5" ShadowDepth="0" Color="Black"/>
                                                </Border.Effect>
                                            </Border>
                                        </Canvas>

                                        <!-- Placeholder when no screenshots exist -->
                                        <StackPanel x:Name="BaseGalleryNoImagePlaceholder" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
                                            <ui:SymbolIcon Symbol="Camera24" FontSize="36" Foreground="Gray" Margin="0,0,0,8"/>
                                            <TextBlock Text="{DynamicResource BaseNoScreenshotsYet}" Foreground="Gray" FontSize="12"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>

                                <!-- Bottom Note Area -->
                                <Border Grid.Row="2" Margin="0,12,0,0" Padding="10" Background="#121417" BorderBrush="#20FFFFFF" BorderThickness="1" CornerRadius="8">
                                    <ScrollViewer MaxHeight="80" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <TextBlock x:Name="TxtBaseGalleryNote" Foreground="White" FontSize="13" TextWrapping="Wrap" LineHeight="18"/>
