                                             </Button>
                                             <Button x:Name="BtnIconTurret" Style="{StaticResource IconSelectorButton}" Click="IconSelection_Click" Tag="pack://application:,,,/Assets/icons/map-icons/turret.png" ToolTip="Turret">
                                                 <Image Source="pack://application:,,,/Assets/icons/map-icons/turret.png" RenderOptions.BitmapScalingMode="HighQuality"/>
                                             </Button>
                                         </StackPanel>

                                         <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,4,0,0">
                                             <TextBlock Text="Marker:" VerticalAlignment="Center" Foreground="Gray" FontSize="11" Margin="0,0,6,0"/>
                                             <UniformGrid x:Name="RustMarkerSelectorPanel" Rows="2" Columns="6" Height="72" VerticalAlignment="Center">
