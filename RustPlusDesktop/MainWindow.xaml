                                                        FontSize="12"
                                                        FontWeight="SemiBold"
                                                        Style="{StaticResource DonateButton}" />
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Border
                                    x:Name="BtnShopToggleBorder"
                                    Grid.Row="1"
                                    Width="160"
                                    Height="26"
                                    HorizontalAlignment="Right"
                                    Background="#16181C"
                                    BorderBrush="#40FFFFFF"
                                    BorderThickness="1,1,1,0"
                                    CornerRadius="8,8,0,0">
