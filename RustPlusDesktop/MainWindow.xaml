                                                                    <ToolTip MaxWidth="520">
                                                                        <Border
                                                                            Background="#171A1F"
                                                                            BorderBrush="#2A2F37"
                                                                            BorderThickness="1"
                                                                            CornerRadius="10">
                                                                            <StackPanel Margin="8,8,8,6">

                                                                                <!--  Header (no pencil / kebab)  -->
