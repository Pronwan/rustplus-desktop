                                    TextWrapping="Wrap"
                                    VerticalScrollBarVisibility="Auto" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
            <!--  Premium Busy Overlay (Single)  -->
            <Grid
                Panel.ZIndex="9999"
                Background="#AA000000"
                IsHitTestVisible="True"
                Visibility="{Binding IsGlobalBusyOverlayVisible, Converter={StaticResource BoolToVisibility}}">
                <Border
                    Width="340"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource Surface}"
                    BorderBrush="{DynamicResource CardBorder}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel>
                        <ui:ProgressRing
                            Width="48"
                            Height="48"
                            Margin="0,0,0,20"
                            IsIndeterminate="True" />
                        <TextBlock
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextPrimary}"
                            Text="{Binding BusyText}"
                            TextAlignment="Center" />
                        <TextBlock
                            Margin="0,8,0,0"
                            FontSize="12"
                            Foreground="{DynamicResource TextSubtle}"
                            Text="{DynamicResource MayTakeAMoment}"
                            TextAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>

            <!--  Dedicated Login & Pairing Overlay  -->
            <Grid
                Panel.ZIndex="9998"
                Background="#DD0F1115"
                IsHitTestVisible="True"
                Visibility="{Binding ShowLoginOverlay, Converter={StaticResource BoolToVisibility}}">

                <Border
                    Width="450"
                    Padding="40"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource Surface}"
                    BorderBrush="{DynamicResource CardBorder}"
                    BorderThickness="1"
                    CornerRadius="20">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="50"
                            Opacity="0.5"
                            ShadowDepth="0"
                            Color="Black" />
                    </Border.Effect>

                    <StackPanel>
                        <!--  Icon / Brand  -->
                        <Border
                            Width="80"
                            Height="80"
                            Margin="0,0,0,24"
                            Background="{DynamicResource AccentDark}"
                            CornerRadius="40">
                            <ui:SymbolIcon
                                FontSize="40"
                                Foreground="{DynamicResource Accent}"
                                Symbol="ShieldLock24" />
                        </Border>

                        <TextBlock
                            Margin="0,0,0,12"
                            FontSize="28"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="Connect Rust+ Companion"
                            TextAlignment="Center" />

                        <TextBlock
                            Margin="0,0,0,32"
                            FontSize="14"
                            Foreground="{DynamicResource TextSubtle}"
                            LineHeight="20"
                            Text="This connection is for the Rust companion API. It enables FCM pairing, in-game broadcasts, alarms, and team chat. Your Cloud account is separate."
                            TextAlignment="Center"
                            TextWrapping="Wrap" />

                        <TextBlock
                            x:Name="TxtLoginOverlayMessage"
                            Margin="0,-16,0,24"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="#FFFF4B4B"
                            Text="{Binding LoginOverlayMessage}"
                            TextAlignment="Center"
                            TextWrapping="Wrap"
                            Visibility="{Binding HasLoginOverlayMessage, Converter={StaticResource Vis}}" />

                        <ui:Button
                            x:Name="BtnOverlayPair"
                            Height="50"
                            HorizontalAlignment="Stretch"
                            Appearance="Primary"
                            Click="BtnOverlayPair_Click"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Icon="{ui:SymbolIcon Symbol=BluetoothConnected24}">
                            <ui:Button.Content>
                                <TextBlock Margin="8,0,0,0" Text="Connect Rust+ Companion" />
                            </ui:Button.Content>
                        </ui:Button>

                        <ui:Button
                            x:Name="BtnOverlayRestore"
                            Height="40"
                            Margin="0,12,0,0"
                            HorizontalAlignment="Stretch"
                            Appearance="Secondary"
                            Click="BtnOverlayRestore_Click"
                            FontSize="14"
                            Icon="{ui:SymbolIcon Symbol=ArrowDownload24}">
                            <ui:Button.Content>
                                <TextBlock Margin="8,0,0,0" Text="Restore local backup" />
                            </ui:Button.Content>
                        </ui:Button>

                        <ui:Button
                            x:Name="BtnOverlayFcmInfo"
                            Height="36"
                            Margin="0,12,0,0"
                            HorizontalAlignment="Stretch"
                            Appearance="Transparent"
