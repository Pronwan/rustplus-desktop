                                                                                         Text="{TemplateBinding Header}"
                                                                                         FontSize="11"
                                                                                         FontWeight="Bold"
                                                                                         Foreground="{DynamicResource TextSubtle}"
                                                                                         Opacity="0.8"
                                                                                         Margin="8,4,8,8" />
                                                                                     <ItemsPresenter />
                                                                                 </StackPanel>
                                                                             </Border>
                                                                         </ControlTemplate>
                                                                     </Setter.Value>
                                                                 </Setter>
                                                             </Style>
                                                         </MenuItem.Style>

                                                         <MenuItem
                                                             Header="{DynamicResource CargoShip}"
                                                             Style="{StaticResource DarkMenuItem}"
                                                             Tag="Cargo">
                                                             <MenuItem
                                                                 Click="Alert_MenuItem_Click"
                                                                 Header="{DynamicResource CargoSpawn}"
                                                                 IsCheckable="True"
                                                                 StaysOpenOnClick="True"
                                                                 Style="{StaticResource DarkMenuItem}"
                                                                 Tag="CargoSpawn" />
                                                             <MenuItem
                                                                 Click="Alert_MenuItem_Click"
                                                                 Header="{DynamicResource CargoDock}"
                                                                 IsCheckable="True"
                                                                 StaysOpenOnClick="True"
                                                                 Style="{StaticResource DarkMenuItem}"
                                                                 Tag="CargoDock" />
                                                             <MenuItem
                                                                 Click="Alert_MenuItem_Click"
                                                                 Header="{DynamicResource CargoEgress}"
                                                                 IsCheckable="True"
                                                                 StaysOpenOnClick="True"
                                                                 Style="{StaticResource DarkMenuItem}"
                                                                 Tag="CargoEgress" />
                                                             <MenuItem
                                                                 x:Name="MenuCargoArrival"
                                                                 Click="Alert_MenuItem_Click"
                                                                 Header="{DynamicResource CargoArrival}"
                                                                 IsCheckable="True"
                                                                 StaysOpenOnClick="True"
                                                                 Style="{StaticResource DarkMenuItem}"
                                                                 Tag="CargoArrival" />
                                                         </MenuItem>
                                                         <MenuItem
                                                             Click="Alert_MenuItem_Click"
                                                             Header="{DynamicResource Heli}"
                                                             IsCheckable="True"
                                                             StaysOpenOnClick="True"
                                                             Style="{StaticResource DarkMenuItem}"
                                                             Tag="Heli" />
                                                         <MenuItem
                                                             Click="Alert_MenuItem_Click"
                                                             Header="{DynamicResource Chinook}"
                                                             IsCheckable="True"
                                                             StaysOpenOnClick="True"
                                                             Style="{StaticResource DarkMenuItem}"
                                                             Tag="Chinook" />
                                                         <MenuItem
                                                             Click="Alert_MenuItem_Click"
                                                             Header="{DynamicResource Vendor}"
                                                             IsCheckable="True"
                                                             StaysOpenOnClick="True"
                                                             Style="{StaticResource DarkMenuItem}"
                                                             Tag="Vendor" />
                                                         <MenuItem
                                                             Click="Alert_MenuItem_Click"
                                                             Header="{DynamicResource OilRig}"
                                                             IsCheckable="True"
                                                             StaysOpenOnClick="True"
                                                             Style="{StaticResource DarkMenuItem}"
                                                             Tag="OilRig" />
                                                         <MenuItem
                                                             Click="Alert_MenuItem_Click"
                                                             Header="{DynamicResource DeepSea}"
                                                             IsCheckable="True"
                                                             StaysOpenOnClick="True"
                                                             Style="{StaticResource DarkMenuItem}"
                                                             Tag="DeepSea" />
                                                         <MenuItem
                                                             Click="Alert_MenuItem_Click"
                                                             Header="{DynamicResource SmartAlerts}"
                                                             IsCheckable="True"
                                                             StaysOpenOnClick="True"
                                                             Style="{StaticResource DarkMenuItem}"
                                                             Tag="SmartAlerts" />
                                                         <MenuItem
                                                             Click="Alert_MenuItem_Click"
                                                             Header="{DynamicResource CustomTimerCategory}"
                                                             IsCheckable="True"
                                                             StaysOpenOnClick="True"
                                                             Style="{StaticResource DarkMenuItem}"
                                                             Tag="CustomTimer" />
                                                     </MenuItem>

                                                     <!-- Column 2: Players -->
                                                     <MenuItem Header="{DynamicResource PlayersHeader}" BorderThickness="0,0,1,0">
                                                         <MenuItem.Style>
                                                             <Style TargetType="MenuItem">
                                                                 <Setter Property="Template">
                                                                     <Setter.Value>
                                                                         <ControlTemplate TargetType="MenuItem">
                                                                             <Border
                                                                                 BorderBrush="#15FFFFFF"
