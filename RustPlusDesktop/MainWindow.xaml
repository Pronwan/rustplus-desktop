                                                        <ui:SymbolIcon Symbol="Map20" Margin="0,0,7,0" />
                                                        <TextBlock Text="Browse monuments" />
                                                    </StackPanel>
                                                </ui:Button>

                                                <Border Margin="0,14,0,12" BorderBrush="#20FFFFFF" BorderThickness="0,1,0,0" />
                                                <TextBlock Margin="0,0,0,8" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource Accent}" Text="SHOPS" />
                                                <CheckBox
