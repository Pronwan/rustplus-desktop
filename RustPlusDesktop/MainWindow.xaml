                                            <ui:Button
                                                x:Name="BtnOpenChatCommands"
                                                Margin="12,0,0,8"
                                                Padding="6,4"
                                                HorizontalAlignment="Left"
                                                Appearance="Transparent"
                                                Click="BtnOpenChatCommands_Click"
                                                ToolTip="{DynamicResource ChatCommandsSettings}">
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:SymbolIcon Symbol="Settings24" Margin="0,0,6,0" FontSize="14" Foreground="{DynamicResource TextSubtle}"/>
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontSize="10"
                                                        Foreground="{DynamicResource TextSubtle}"
                                                        Text="{DynamicResource ChatCommands}" />
                                                </StackPanel>
                                            </ui:Button>
                                        </StackPanel>

                                        <!--  Chat Commands Overlay  -->
                                        <views:ChatCommandsOverlay
                                            x:Name="ChatCommandsOverlay"
                                            Grid.RowSpan="3"
                                            Panel.ZIndex="2000"
                                            CloseRequested="BtnCloseChatCommands_Click"
                                            Visibility="Collapsed" />
                                    </Grid>
                                </Border>

                                <Border
                                    x:Name="BtnChatToggleBorder"
                                    Grid.Row="1"
                                    Width="160"
                                    Height="26"
                                    HorizontalAlignment="Left"
                                    Background="#16181C"
                                    BorderBrush="#40FFFFFF"
                                    BorderThickness="1,1,1,0"
                                    CornerRadius="8,8,0,0">
                                    <Button
                                        x:Name="BtnChatToggle"
                                        Padding="0"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Click="BtnToggleChat_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border
                                                    x:Name="border"
                                                    Background="{TemplateBinding Background}"
