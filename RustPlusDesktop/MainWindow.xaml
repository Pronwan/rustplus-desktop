                                                                                    <Image
                                                                                        Width="20"
                                                                                        Height="20"
                                                                                        Margin="0,0,6,0"
                                                                                        Opacity="0.9"
                                                                                        RenderOptions.BitmapScalingMode="HighQuality"
                                                                                        Source="{StaticResource IconStorageMonitor}" />
                                                                                    <StackPanel Orientation="Horizontal">
                                                                                        <TextBlock
                                                                                            VerticalAlignment="Center"
                                                                                            FontSize="13"
                                                                                            FontWeight="Bold"
                                                                                            Foreground="#FF4B4B"
                                                                                            Text="✗ ">
                                                                                            <TextBlock.Style>
                                                                                                <Style TargetType="TextBlock">
                                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                                    <Style.Triggers>
                                                                                                        <DataTrigger Binding="{Binding IsMissing}" Value="True">
                                                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                                                        </DataTrigger>
                                                                                                    </Style.Triggers>
                                                                                                </Style>
                                                                                            </TextBlock.Style>
                                                                                        </TextBlock>
                                                                                        <TextBlock
                                                                                            DockPanel.Dock="Left"
                                                                                            FontSize="13"
                                                                                            FontWeight="SemiBold"
                                                                                            Foreground="#EAECEE"
                                                                                            Text="{Binding PureName, TargetNullValue=Storage Monitor}" />
                                                                                    </StackPanel>
                                                                                </DockPanel>

                                                                                <!--  Upkeep line (compact)  -->
                                                                                <TextBlock
                                                                                    Margin="0,0,0,4"
                                                                                    FontSize="10.5"
                                                                                    Foreground="#9AA3B2"
                                                                                    Text="{Binding Storage, Converter={StaticResource StorageChipConverter}}" />

                                                                                <!--  Dense grid  -->
                                                                                <ScrollViewer MaxHeight="390" VerticalScrollBarVisibility="Auto">
                                                                                    <ItemsControl ItemsSource="{Binding Storage.Items}">
                                                                                        <ItemsControl.ItemsPanel>
                                                                                            <ItemsPanelTemplate>
                                                                                                <WrapPanel
                                                                                                    ItemHeight="64"
                                                                                                    ItemWidth="64"
                                                                                                    Orientation="Horizontal"
                                                                                                    SnapsToDevicePixels="True"
                                                                                                    UseLayoutRounding="True" />
                                                                                            </ItemsPanelTemplate>
                                                                                        </ItemsControl.ItemsPanel>

                                                                                        <ItemsControl.ItemTemplate>
                                                                                            <DataTemplate>
                                                                                                <Border
                                                                                                    Width="64"
                                                                                                    Height="64"
                                                                                                    Background="#1F242B"
                                                                                                    BorderBrush="#2A2F37"
                                                                                                    BorderThickness="0"
                                                                                                    SnapsToDevicePixels="True">
                                                                                                    <Grid>
                                                                                                        <!--  Icon groÃŸ & zentriert  -->
                                                                                                        <Image
                                                                                                            Width="48"
                                                                                                            Height="48"
                                                                                                            HorizontalAlignment="Center"
                                                                                                            VerticalAlignment="Center"
                                                                                                            RenderOptions.BitmapScalingMode="Fant"
                                                                                                            Source="{Binding Icon}" />

                                                                                                        <!--  Badge unten rechts  -->
                                                                                                        <Border
                                                                                                            Margin="1,1,1,1"
                                                                                                            Padding="4,1.5"
                                                                                                            HorizontalAlignment="Right"
                                                                                                            VerticalAlignment="Bottom"
                                                                                                            Background="#252B33"
                                                                                                            BorderBrush="#3B4756"
                                                                                                            BorderThickness="1"
                                                                                                            CornerRadius="5">
                                                                                                            <TextBlock
                                                                                                                FontSize="10"
                                                                                                                FontWeight="SemiBold"
                                                                                                                Foreground="#EAECEE">
                                                                                                                <Run Text="x" /><Run Text="{Binding Amount, StringFormat={}{0:N0}}" />
                                                                                                            </TextBlock>
                                                                                                        </Border>
                                                                                                    </Grid>
                                                                                                </Border>
                                                                                            </DataTemplate>
                                                                                        </ItemsControl.ItemTemplate>

                                                                                        <!--  Container ohne Margin, damit wirklich null Spalt  -->
                                                                                        <ItemsControl.ItemContainerStyle>
                                                                                            <Style TargetType="ContentPresenter">
                                                                                                <Setter Property="Margin" Value="1" />
                                                                                            </Style>
                                                                                        </ItemsControl.ItemContainerStyle>
                                                                                    </ItemsControl>
                                                                                </ScrollViewer>

                                                                                <!--  footer (compact)  -->
                                                                                <TextBlock
                                                                                    Margin="0,2,0,0"
                                                                                    HorizontalAlignment="Right"
                                                                                    FontSize="9.5"
                                                                                    Foreground="#7F8A99"
                                                                                    Text="{Binding Storage.ItemsCount, StringFormat={}{0} items}" />
                                                                            </StackPanel>
                                                                        </Border>
                                                                    </ToolTip>
                                                                </Border.ToolTip>
                                                            </Border>

                                                        </Grid>
                                                    </Border>
                                                    <!--  ===== Ende Zeile =====  -->

                                                    <!-- ===== Klappbereich (hÃ¤ngt direkt an
                                            ) =====
                                            <Grid Margin="0,4,0,8" Visibility="Collapsed">
                                                <Grid.Style>
                                                    <Style TargetType="Grid">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Grid.Style>

                                                <Border Background="#22000000"
                      BorderBrush="#33000000" BorderThickness="1"
                      CornerRadius="8" Padding="6">
                                                    <StackPanel>
                                                        <TextBlock Foreground="#99FFFFFF" FontStyle="Italic" Margin="0,0,0,6">
                    <Run Text="{DynamicResource Snapshot}"/>
                    <Run Text="{Binding Storage.ItemsCount, Mode=OneWay, FallbackValue=0}" />
                    <Run Text="{DynamicResource ItemsUpkeep}"/>
                    <Run Text="{Binding UpkeepSeconds, Mode=OneWay, TargetNullValue=—}"/>
                                                        </TextBlock>

                                                        <ItemsControl ItemsSource="{Binding Storage.Items, Mode=OneWay}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel Orientation="Horizontal" ItemWidth="210"/>
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <StackPanel Orientation="Horizontal" Margin="6">
                                                                        <Image Width="24" Height="24" Source="{Binding Icon}" Stretch="Uniform"/>
                                                                        <TextBlock Margin="8,0,0,0" Foreground="White">
                            <Run Text="{Binding Display}"/>
                            <Run Text=" Ã— "/>
                            <Run Text="{Binding Amount}"/>
                            <Run Text="{Binding MaxStack, StringFormat={} (Stack {0})}"/>
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>-->
                                                    <!--  ===== Ende Klappbereich =====  -->

                                                </StackPanel>
                                            </HierarchicalDataTemplate>
                                        </TreeView.ItemTemplate>
                                    </TreeView>

                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        IsHitTestVisible="False">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasItems, ElementName=ListDevices}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>

                                        <Border
                                            Padding="32,24"
                                            HorizontalAlignment="Center"
                                            Background="#101217"
                                            BorderBrush="#1C202A"
                                            BorderThickness="1"
                                            CornerRadius="16">
                                            <StackPanel>
                                                <TextBlock
                                                    Margin="0,0,0,12"
                                                    HorizontalAlignment="Center"
                                                    FontSize="36"
                                                    Opacity="0.8"
                                                    Text="📡" />
                                                <TextBlock
                                                    Margin="0,0,0,6"
                                                    HorizontalAlignment="Center"
                                                    FontSize="16"
                                                    FontWeight="SemiBold"
                                                    Foreground="#EAECEE"
                                                    Text="{DynamicResource NoDevicesFound}" />
                                                <TextBlock
                                                    MaxWidth="200"
                                                    HorizontalAlignment="Center"
                                                    FontSize="12"
                                                    Foreground="#7F8A96"
                                                    Text="{DynamicResource PairDeviceToSee}"
                                                    TextAlignment="Center"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>


                                </Grid>
                            </DockPanel>
                        </TabItem>

                        <!--  ===== TEAM =====  -->
                        <TabItem
                            x:Name="TabTeam"
                            Style="{StaticResource PrettyTabItem}">
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock VerticalAlignment="Center" Text="👥 " />
                                    <TextBlock VerticalAlignment="Center" Text="{DynamicResource TeamTab}" />
                                </StackPanel>
                            </TabItem.Header>
                            <Grid>
                                <Grid Background="#181A1E">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid.Resources>
                                        <conv:BoolToVisibilityConverter x:Key="Vis" />
                                        <conv:BoolToVisibilityConverter x:Key="VisInv" Invert="True" />
                                        <Style x:Key="Card" TargetType="Border">
                                            <Setter Property="CornerRadius" Value="10" />
                                            <Setter Property="Background" Value="#FF141F2D" />
                                            <Setter Property="Padding" Value="8" />
                                            <Setter Property="Margin" Value="6" />
                                        </Style>
                                    </Grid.Resources>

                                    <!--  Liste oben  -->
                                    <ListBox
                                        x:Name="TeamList"
                                        Grid.Row="0"
                                        HorizontalContentAlignment="Stretch"
                                        ItemsSource="{Binding TeamMembers, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <!--  Kontextmenü  -->
                                        <ListBox.Resources>
                                            <ContextMenu x:Key="TeamContextMenu" Style="{StaticResource DarkContextMenu}">
                                                <MenuItem Click="Team_Center_Click" Header="{DynamicResource CenterOnMap}" />
                                                <MenuItem Click="Team_Follow_Click" Header="{DynamicResource FollowOnMap}" />
                                                <MenuItem Click="Team_OpenProfile_Click" Header="{DynamicResource OpenSteamProfile}" />
                                                <Separator />
                                                <MenuItem Click="Team_Promote_Click" Header="{DynamicResource PromoteToLeader}" />
                                                <MenuItem Click="Team_Kick_Click" Header="{DynamicResource KickFromTeam}" />
                                            </ContextMenu>
                                        </ListBox.Resources>

                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Width" Value="210" />
                                                <!--  an deine Fensterbreite anpassen  -->
                                                <Setter Property="Margin" Value="6" />
                                                <EventSetter Event="MouseLeftButtonUp" Handler="TeamItem_MouseLeftButtonUp" />
                                                <Setter Property="ContextMenu" Value="{StaticResource TeamContextMenu}" />
                                            </Style>
                                        </ListBox.ItemContainerStyle>

                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource Card}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="56" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <!--  Avatar + Status  -->
                                                        <Grid Width="44" Height="44">
                                                            <Image
                                                                ClipToBounds="True"
                                                                RenderOptions.BitmapScalingMode="HighQuality"
                                                                Source="{Binding Avatar}"
                                                                Stretch="UniformToFill" />

                                                            <!--  Online (grün)  -->
                                                            <Ellipse
                                                                Width="12"
                                                                Height="12"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Bottom"
                                                                Fill="#4CAF50"
                                                                Stroke="Black"
                                                                Visibility="{Binding IsOnline, Converter={StaticResource Vis}}" />

                                                            <!--  Offline (grau)  -->
                                                            <Ellipse
                                                                Width="12"
                                                                Height="12"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Bottom"
                                                                Fill="#666"
                                                                Stroke="Black"
                                                                Visibility="{Binding IsOnline, Converter={StaticResource VisInv}}" />

                                                            <!--  Leader-Stern  -->
                                                            <Path
                                                                Width="20"
                                                                Height="20"
                                                                HorizontalAlignment="Left"
                                                                VerticalAlignment="Top"
                                                                Data="M 10,1 12,7 19,7 13,11 15,18 10,14 5,18 7,11 1,7 8,7 z"
                                                                Fill="Gold"
                                                                Stroke="Black"
                                                                Visibility="{Binding IsLeader, Converter={StaticResource Vis}}" />
                                                        </Grid>

                                                        <!--  Textseite  -->
                                                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                            <!--  Name: Standard weiß, offline leicht ausgrauen, tot = rot  -->
                                                            <TextBlock FontSize="14" FontWeight="SemiBold">
                                                                <TextBlock.Text>
                                                                    <Binding Path="DisplayName" />
                                                                </TextBlock.Text>
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="White" />
                                                                        <Setter Property="Opacity" Value="1" />
                                                                        <Style.Triggers>
                                                                            <!--  tot -> rot  -->
                                                                            <DataTrigger Binding="{Binding IsDead}" Value="True">
                                                                                <Setter Property="Foreground" Value="#EF5350" />
                                                                            </DataTrigger>
                                                                            <!--  offline -> etwas ausgegraut  -->
                                                                            <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                                                                <Setter Property="Opacity" Value="0.55" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>

                                                            <TextBlock
                                                                FontSize="11"
                                                                Foreground="White"
                                                                Opacity="0.65"
                                                                Text="{Binding DisplaySteamId}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>




                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <!--  Buttonleiste unten  -->
                                    <Grid Grid.Row="1" Margin="0,10,0,0">
                                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                            <!--  Profile marker toggle (default ON)  -->
                                            <CheckBox
                                                x:Name="ChkProfileMarkers"
                                                Margin="0,0,12,0"
                                                Checked="ChkProfileMarkers_Toggled"
                                                IsChecked="True"
                                                Style="{StaticResource DotCheckBox}"
                                                Unchecked="ChkProfileMarkers_Toggled">
                                                <StackPanel Orientation="Horizontal">
                                                    <Grid
                                                        Width="20"
                                                        Height="20"
                                                        Margin="0,0,6,0">
                                                        <!--  Avatar Preview (Visible when checked)  -->
                                                        <Ellipse
                                                            Width="18"
                                                            Height="18"
                                                            Stroke="Black"
                                                            StrokeThickness="1"
                                                            Visibility="{Binding IsChecked, ElementName=ChkProfileMarkers, Converter={StaticResource BoolToVisibility}}">
                                                            <Ellipse.Fill>
                                                                <ImageBrush ImageSource="{Binding MyAvatar}" Stretch="UniformToFill" />
                                                            </Ellipse.Fill>
                                                        </Ellipse>
                                                        <!--  Dot Preview (Visible when unchecked)  -->
                                                        <Ellipse
                                                            Width="10"
                                                            Height="10"
                                                            Fill="LimeGreen"
                                                            Stroke="Black"
                                                            StrokeThickness="1.5"
                                                            Visibility="{Binding IsChecked, ElementName=ChkProfileMarkers, Converter={StaticResource BoolToVisibilityInv}}" />
                                                    </Grid>
                                                    <TextBlock VerticalAlignment="Center" Text="{DynamicResource ProfileMarkers}" />
                                                </StackPanel>
                                            </CheckBox>

                                            <!--  Death markers toggle (default OFF)  -->
                                            <CheckBox
                                                x:Name="ChkDeathMarkers"
                                                Margin="0,0,12,0"
                                                Checked="ChkDeathMarkers_Toggled"
                                                IsChecked="False"
                                                Style="{StaticResource DotCheckBox}"
                                                Unchecked="ChkDeathMarkers_Toggled">
                                                <StackPanel Orientation="Horizontal">
                                                    <Grid
                                                        Width="20"
                                                        Height="20"
                                                        Margin="0,0,6,0">
                                                        <!--  Death Preview (Visible when checked)  -->
                                                        <Grid Visibility="{Binding IsChecked, ElementName=ChkDeathMarkers, Converter={StaticResource BoolToVisibility}}">
                                                            <Path
                                                                Width="16"
                                                                Height="20"
                                                                Data="M20,0 C31,0 40,9 40,20 C40,33 20,56 20,56 C20,56 0,33 0,20 C0,9 9,0 20,0 Z"
                                                                Fill="IndianRed"
                                                                Stretch="Uniform"
                                                                Stroke="Black"
                                                                StrokeThickness="1" />
                                                            <Ellipse
                                                                Width="10"
                                                                Height="10"
                                                                Margin="0,0,0,5">
                                                                <Ellipse.Fill>
                                                                    <ImageBrush ImageSource="{Binding MyAvatar}" Stretch="UniformToFill" />
                                                                </Ellipse.Fill>
                                                            </Ellipse>
                                                        </Grid>
                                                        <!--  Grey dot (Visible when unchecked - indicates hidden/none)  -->
                                                        <Ellipse
                                                            Width="10"
                                                            Height="10"
                                                            Fill="#444"
                                                            Stroke="#666"
                                                            StrokeThickness="1.5"
                                                            Visibility="{Binding IsChecked, ElementName=ChkDeathMarkers, Converter={StaticResource BoolToVisibilityInv}}" />
                                                    </Grid>
                                                    <TextBlock VerticalAlignment="Center" Text="{DynamicResource DeathMarkers}" />
                                                </StackPanel>
                                            </CheckBox>

                                            <!-- Abbreviate Names Toggle -->
                                            <ToggleButton x:Name="BtnAbbreviateNames"
                                                          Margin="0,0,12,0"
                                                          Width="24" Height="24"
                                                          ToolTip="{DynamicResource StreamerMode}"                                                          Checked="BtnAbbreviateNames_Toggled"
                                                          Unchecked="BtnAbbreviateNames_Toggled">
                                                <ToggleButton.Style>
                                                    <Style TargetType="ToggleButton">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                        <Setter Property="BorderBrush" Value="#444"/>
                                                        <Setter Property="Foreground" Value="#CCC"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ToggleButton">
                                                                    <Border Background="{TemplateBinding Background}"
                                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                                            CornerRadius="3">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#222"/>
                                                            </Trigger>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter Property="Background" Value="#1C4B82"/>
                                                                <Setter Property="BorderBrush" Value="#2A6CA6"/>
                                                                <Setter Property="Foreground" Value="White"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ToggleButton.Style>
                                                <TextBlock Text="A..." FontSize="10" FontWeight="Bold" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                                            </ToggleButton>

                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{DynamicResource ScaleLabel}" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="#AAA" FontSize="10"/>
                                                <Slider x:Name="SliderPlayerIconSize" 
                                                        Width="50" Minimum="0.5" Maximum="1.5" Value="1.0" 
                                                        TickFrequency="0.05" IsSnapToTickEnabled="True" 
                                                        ValueChanged="SliderPlayerIconSize_ValueChanged"
                                                        VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding Value, ElementName=SliderPlayerIconSize, StringFormat={}{0:P0}}" 
                                                           VerticalAlignment="Center" Margin="4,0,0,0" Foreground="#AAA" FontSize="10" Width="30"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </TabItem>

                        <!--  ===== CAMERAS =====  -->
                        <TabItem Style="{StaticResource PrettyTabItem}">
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock VerticalAlignment="Center" Text="🎥 " />
                                    <TextBlock VerticalAlignment="Center" Text="{DynamicResource CamerasTab}" />
                                </StackPanel>
                            </TabItem.Header>
                            <DockPanel LastChildFill="True">
                                <!--  Add Camera unten rechts  -->
                                <StackPanel
                                    Margin="0,10,0,0"
                                    HorizontalAlignment="Right"
                                    DockPanel.Dock="Bottom"
                                    Orientation="Horizontal">
                                    <Button x:Name="BtnAddCam" Style="{StaticResource PrimaryButton}">
                                        <StackPanel Margin="6,1" Orientation="Horizontal">
                                            <TextBlock VerticalAlignment="Center" Text="📷 " />
                                            <TextBlock VerticalAlignment="Center" Text="{DynamicResource AddCamera}" />
                                        </StackPanel>
                                    </Button>                                </StackPanel>

                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <Grid>
                                        <ItemsControl x:Name="CamItems">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel ItemHeight="180" ItemWidth="220" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>

                                        <StackPanel
                                            Margin="0,50"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            IsHitTestVisible="False">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasItems, ElementName=CamItems}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontStyle="Italic"
                                                Foreground="{StaticResource TextSubtle}"
                                                Text="{DynamicResource NoCamerasFound}" />
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontSize="10"
                                                Foreground="{StaticResource TextSubtle}"
                                                Opacity="0.6"
                                                Text="{DynamicResource PairCameraToSee}" />
                                        </StackPanel>
                                    </Grid>
                                </ScrollViewer>
                            </DockPanel>
                        </TabItem>

                        <!--  ===== PLAYERS =====  -->
                        <TabItem Style="{StaticResource PrettyTabItem}">
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock VerticalAlignment="Center" Text="🌍 " />
                                    <TextBlock VerticalAlignment="Center" Text="{DynamicResource PlayersTab}" />
                                </StackPanel>
                            </TabItem.Header>
                            <TabControl
                                Margin="0,10,0,0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Background="Transparent"
                                BorderThickness="0">
                                <TabControl.Template>
                                    <ControlTemplate TargetType="{x:Type TabControl}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            
                                            <TabPanel
                                                Grid.Row="0" Grid.Column="0"
                                                Margin="0"
                                                Panel.ZIndex="1"
                                                IsItemsHost="True" />
                                                
                                            <ui:Button
                                                Grid.Row="0" Grid.Column="1"
                                                Margin="0,0,12,0"
                                                Padding="8,4"
                                                VerticalAlignment="Center"
                                                Appearance="Secondary"
                                                Click="BtnHowToTrack_Click"
                                                ToolTip="{DynamicResource LearnHowTrackingWorks}"
                                                Icon="{ui:SymbolIcon Symbol=QuestionCircle24}"
                                                Content="{DynamicResource HowToTrack}" />

                                            <ContentPresenter
                                                Grid.Row="1" Grid.ColumnSpan="2"
                                                Margin="0,8,0,0"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Stretch"
                                                ContentSource="SelectedContent" />
                                        </Grid>
                                    </ControlTemplate>
                                </TabControl.Template>

                                <!--  Online Players Tab  -->
                                <TabItem Header="{DynamicResource OnlineTab}" Style="{StaticResource PrettyTabItem}">
                                    <Border
                                        Padding="12"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        TextElement.FontFamily="Segoe UI Variable Display, Segoe UI">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontSize="16"
                                                    FontWeight="Bold"
                                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                    Text="{DynamicResource OnlinePlayers}" />



                                                <ui:Button
                                                    Grid.Column="2"
                                                    Padding="8,4"
                                                    Appearance="Secondary"
                                                    Click="BtnShowOnline_Click"
                                                    Content="{DynamicResource Refresh}"
                                                    Icon="{ui:SymbolIcon Symbol=ArrowClockwise24}" />

                                                <ui:Button
                                                    x:Name="BtnPopoutPlayers"
                                                    Grid.Column="3"
                                                    Margin="4,0,0,0"
                                                    Padding="8,4"
                                                    Appearance="Secondary"
                                                    Click="BtnPopoutPlayers_Click"
                                                    ToolTip="{DynamicResource OpenPlayersSeparateWindow}"
                                                    Content="{DynamicResource Popout}" />
                                            </Grid>

                                            <DockPanel x:Name="PnlManualTrack" Grid.Row="1" Margin="0,0,0,8">
                                                <ui:Button
                                                    x:Name="BtnAddManual"
                                                    Margin="4,0,0,0"
                                                    Padding="8,4"
                                                    Appearance="Primary"
                                                    Click="BtnAddManual_Click"
                                                    Content="{DynamicResource Track}"
                                                    DockPanel.Dock="Right" />
                                                <ui:TextBox
                                                    x:Name="TxtManualBMId"
                                                    PlaceholderText="{DynamicResource ManualTrackPlaceholder}" />
                                            </DockPanel>

                                            <ui:TextBox
                                                x:Name="TxtOnlineFilter"
                                                Grid.Row="2"
                                                Margin="0,0,0,8"
                                                PlaceholderText="{DynamicResource FilterPlayersPlaceholder}"
                                                TextChanged="TxtOnlineFilter_TextChanged"
                                                Visibility="Collapsed" />

                                            <Grid
                                                x:Name="PnlOnlineStatus"
                                                Grid.Row="3"
                                                Margin="20"
                                                VerticalAlignment="Center"
                                                Visibility="Collapsed"
                                                Background="Transparent">
                                                <Grid.ContextMenu>
                                                    <ContextMenu Style="{StaticResource DarkContextMenu}">
                                                        <MenuItem Click="Server_Delete_Click" Tag="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                            <MenuItem.Header>
                                                                <TextBlock>
                                                                    <Run Text="🗑️ " /><Run Text="{DynamicResource DeleteServerEllipsis}" />
                                                                </TextBlock>
                                                            </MenuItem.Header>
                                                        </MenuItem>
                                                    </ContextMenu>
                                                </Grid.ContextMenu>
                                                <StackPanel>
                                                    <ui:ProgressRing
                                                        x:Name="PbOnlineLoading"
                                                        Width="32"
                                                        Height="32"
                                                        Margin="0,0,0,12"
                                                        IsIndeterminate="True" />
                                                    <TextBlock
                                                        x:Name="TxtOnlinePlayersStatus"
                                                        HorizontalAlignment="Center"
                                                        FontSize="12"
                                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                        Text="{DynamicResource LoadingPlayers}"
                                                        TextAlignment="Center"
                                                        TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Grid>

                                            <ListBox
                                                x:Name="ListOnlinePlayers"
                                                Grid.Row="3"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,4">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                                <Ellipse
                                                                    x:Name="StatusDot"
                                                                    Width="8"
                                                                    Height="8"
                                                                    Margin="0,0,8,0"
                                                                    VerticalAlignment="Center"
                                                                    Fill="{DynamicResource SystemAccentColorPrimaryBrush}" />
                                                                <TextBlock
                                                                    MaxWidth="160"
                                                                    VerticalAlignment="Center"
                                                                    FontSize="13"
                                                                    FontWeight="SemiBold"
                                                                    Text="{Binding Name}"
                                                                    TextTrimming="CharacterEllipsis"
                                                                    ToolTip="{Binding Name}" />
                                                            </StackPanel>
                                                            <TextBlock
                                                                Grid.Column="1"
                                                                Margin="0,0,8,0"
                                                                VerticalAlignment="Center"
                                                                FontSize="11"
                                                                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                Text="{Binding PlayTimeStr}" />

                                                            <ui:Button
                                                                x:Name="BtnAction"
                                                                Grid.Column="3"
                                                                Width="60"
                                                                Margin="0"
                                                                Padding="6,2"
                                                                Appearance="Secondary"
                                                                Click="BtnTrackPlayer_Click"
                                                                Content="{DynamicResource Track}"
                                                                FontSize="11"
                                                                Tag="{Binding}" />
                                                        </Grid>
                                                        <DataTemplate.Triggers>
                                                            <DataTrigger Binding="{Binding IsTracked}" Value="True">
                                                                <Setter TargetName="StatusDot" Property="Fill" Value="#FFD166" />
                                                                <Setter TargetName="BtnAction" Property="Content" Value="Details" />
                                                                <Setter TargetName="BtnAction" Property="Appearance" Value="Primary" />
                                                            </DataTrigger>
                                                            <Trigger Property="IsMouseOver" Value="False">
                                                                <Setter TargetName="BtnAction" Property="Opacity" Value="0.6" />
                                                            </Trigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="BtnAction" Property="Opacity" Value="1" />
                                                            </Trigger>
                                                        </DataTemplate.Triggers>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Grid>
                                    </Border>
                                </TabItem>

                                <!--  Tracked Players Tab  -->
                                <TabItem Header="{DynamicResource TrackedTab}" Style="{StaticResource PrettyTabItem}">
                                    <Border
                                        Padding="12"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        TextElement.FontFamily="Segoe UI Variable Display, Segoe UI">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontSize="16"
                                                    FontWeight="Bold"
                                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                    Text="{DynamicResource TrackedPlayers}" />
                                                <ui:Button
                                                    Grid.Column="1"
                                                    Padding="8,4"
                                                    Appearance="Secondary"
                                                    Click="BtnManageGroups_Click"
                                                    Content="{DynamicResource ManageGroups}"
                                                    Icon="Group24" />
                                            </Grid>

                                            <ui:TextBox
                                                x:Name="TxtTrackedFilter"
                                                Grid.Row="1"
                                                Margin="0,0,0,8"
                                                PlaceholderText="{DynamicResource FilterPlayersPlaceholder}"
                                                TextChanged="TxtTrackedFilter_TextChanged" />

                                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                                <StackPanel x:Name="ListTrackedPlayers" />
                                            </ScrollViewer>

                                            <ui:Button
                                                x:Name="BtnViewTracking"
                                                Grid.Row="3"
                                                Margin="0,8,0,0"
                                                HorizontalAlignment="Stretch"
                                                Appearance="Primary"
                                                Click="BtnViewAllAnalysis_Click"
                                                Content="{DynamicResource ViewFullAnalysisReport}"
                                                Icon="DataHistogram24" />
                                        </Grid>
                                    </Border>
                                </TabItem>
                            </TabControl>
                        </TabItem>
                    </TabControl>

                    </DockPanel>

                    <!--  Profit Trades Overlay  -->
                    <Border
                        x:Name="ProfitTradesPanel"
                        Background="{DynamicResource Surface}"
                        Visibility="Collapsed">
                        <Grid ClipToBounds="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="36" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1" Padding="12,0">
                                <Grid>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="💰" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" />
                                        <TextBlock Text="{DynamicResource ProfitTrades}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <Button x:Name="BtnRefreshProfitTrades" Content="⟳" Style="{StaticResource GhostButton}" Width="26" Height="26" Padding="0" FontSize="15" Margin="0,0,6,0" ToolTip="{DynamicResource Refresh}" />
                                        <Button x:Name="BtnCloseProfitTrades" Content="&#x2715;" Style="{StaticResource GhostButton}" Width="26" Height="26" Padding="0" FontSize="12" Foreground="{DynamicResource TextSubtle}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1" Padding="12,7" BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1">
                                <TextBlock Text="{DynamicResource ArbitrageOpportunities}" Foreground="{DynamicResource TextSubtle}" FontSize="11" />
                            </Border>

                            <ListBox x:Name="ProfitTradesList" Grid.Row="2" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch" Padding="10" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" VirtualizingStackPanel.ScrollUnit="Pixel" VirtualizingStackPanel.IsVirtualizing="True" />
                        </Grid>
                    </Border>

                    <!--  Buy X For Y Overlay  -->
                    <Border
                        x:Name="BuyXForYPanel"
                        Background="{DynamicResource Surface}"
                        Visibility="Collapsed">
                        <Grid ClipToBounds="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="36" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="130" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1" Padding="12,0">
                                <Grid>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="🔁" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" />
                                        <TextBlock Text="{DynamicResource BuyXForY}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" />
                                    </StackPanel>
                                    <Button x:Name="BtnCloseBuyXForY" Content="&#x2715;" Style="{StaticResource GhostButton}" Width="26" Height="26" Padding="0" FontSize="12" Foreground="{DynamicResource TextSubtle}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1" Margin="12,8,12,6" HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Margin="0,0,4,0" Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="6" Padding="6,3">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="🎯" Margin="0,0,4,0" VerticalAlignment="Center" FontSize="13" />
                                        <TextBox x:Name="BuyXForY_WantTb" Grid.Column="1" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextPrimary}" CaretBrush="{DynamicResource TextPrimary}" Padding="2,3" VerticalContentAlignment="Center" ToolTip="{DynamicResource IWantToGetToolTip}" FontSize="12" />
                                    </Grid>
                                </Border>

                                <Border Grid.Column="1" Margin="4,0" Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="6" Padding="6,3">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="💰" Margin="0,0,4,0" VerticalAlignment="Center" FontSize="13" />
                                        <TextBox x:Name="BuyXForY_PayTb" Grid.Column="1" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextPrimary}" CaretBrush="{DynamicResource TextPrimary}" Padding="2,3" VerticalContentAlignment="Center" ToolTip="{DynamicResource ICanPayWithToolTip}" FontSize="12" />
                                    </Grid>
                                </Border>

                                <Button x:Name="BuyXForY_AnalyzeBtn" Grid.Column="2" Content="{DynamicResource Analyze}" Style="{StaticResource PrimaryButton}" Margin="4,0,0,0" Padding="12,3" FontSize="12" />
                            </Grid>

                            <Grid Grid.Row="2" Margin="12,0,12,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Margin="0,0,4,0" Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="6" Padding="5">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Top" Text="{DynamicResource IWantToGet}" Foreground="{DynamicResource Accent}" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,3" />
                                        <ListBox x:Name="BuyXForY_WantPreview" Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" VirtualizingStackPanel.ScrollUnit="Pixel" VirtualizingStackPanel.IsVirtualizing="True" />
                                    </DockPanel>
                                </Border>

                                <Border Grid.Column="1" Margin="4,0,0,0" Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="6" Padding="5">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Top" Text="{DynamicResource ICanPayWith}" Foreground="{DynamicResource Accent}" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,3" />
                                        <ListBox x:Name="BuyXForY_PayPreview" Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" VirtualizingStackPanel.ScrollUnit="Pixel" VirtualizingStackPanel.IsVirtualizing="True" />
                                    </DockPanel>
                                </Border>
                            </Grid>

                            <ListBox x:Name="BuyXForY_ResultList" Grid.Row="3" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch" Margin="12,0,12,10" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" VirtualizingStackPanel.ScrollUnit="Pixel" VirtualizingStackPanel.IsVirtualizing="True" />
                        </Grid>
                    </Border>

                    <!--  App Settings Overlay  -->
                    <views:AppSettingsOverlay
                        x:Name="AppSettingsPanel"
                        Visibility="Collapsed" />
                </Grid>
            </Border>

            <!--  Rechte Spalte: Login/Status + WebViewHost  -->
            <Border
                Grid.Column="2"
                MinWidth="800"
                Padding="12"
                Background="{DynamicResource Surface}"
                BorderBrush="{DynamicResource CardBorder}"
                BorderThickness="1,0,0,0"
                CornerRadius="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  RE-DESIGNED MAP CONTROL BAR  -->
                    <Border
                        Grid.Row="0"
                        Margin="-12,-12,-12,0"
                        Padding="16,8"
                        Background="{DynamicResource SurfaceAlt}"
                        BorderBrush="{DynamicResource CardBorder}"
                        BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!--  Left Group: Map Filters  -->
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
