                                                    <StackPanel Orientation="Horizontal">
                                                        <ui:SymbolIcon Symbol="Map20" Margin="0,0,7,0" />
                                                        <TextBlock Text="Open shop filters" />
                                                    </StackPanel>
                                                </ui:Button>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                                <CheckBox
                                    x:Name="ChkNoBuildZones"
                                    Margin="0,0,24,0"
                                    Checked="ChkNoBuildZones_Checked"
                                    Content="No Build"
                                    Style="{StaticResource PillToggleButton}"
                                    Unchecked="ChkNoBuildZones_Checked"
                                    Visibility="Collapsed" />

                                 <Border
                                     Background="#AA16181C"
                                     BorderBrush="#30FFFFFF"
                                     BorderThickness="1"
                                     CornerRadius="8"
                                     Padding="2"
                                     Margin="0,0,8,0"
                                     VerticalAlignment="Center">
                                     <Grid>
                                         <Grid.ColumnDefinitions>
                                             <ColumnDefinition Width="Auto" />
                                             <ColumnDefinition Width="Auto" />
                                             <ColumnDefinition Width="Auto" />
                                         </Grid.ColumnDefinitions>

                                         <!-- Alerts Toggle Button -->
                                         <CheckBox
                                             x:Name="ChatAnnounce"
                                             Grid.Column="0"
                                             Click="ChatAnnounce_Toggle"
                                             Height="30"
                                             IsChecked="False"
                                             Margin="0"
                                             Padding="0"
                                             ToolTip="{DynamicResource Alerts}"
                                             Width="36">
                                             <CheckBox.Style>
                                                 <Style TargetType="CheckBox">
                                                     <Setter Property="Foreground" Value="{DynamicResource TextSubtle}" />
                                                     <Setter Property="Background" Value="Transparent" />
                                                     <Setter Property="Cursor" Value="Hand" />
                                                     <Setter Property="FontSize" Value="12" />
                                                     <Setter Property="FontWeight" Value="SemiBold" />
                                                     <Setter Property="Template">
                                                         <Setter.Value>
                                                             <ControlTemplate TargetType="CheckBox">
                                                                 <Border
                                                                     x:Name="Bd"
                                                                     Background="{TemplateBinding Background}"
                                                                     CornerRadius="6,0,0,6"
                                                                     Padding="{TemplateBinding Padding}"
                                                                     SnapsToDevicePixels="True">
                                                                     <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                 </Border>
                                                                 <ControlTemplate.Triggers>
                                                                     <Trigger Property="IsChecked" Value="True">
                                                                         <Setter TargetName="Bd" Property="Background" Value="#3D4B5C" />
                                                                         <Setter Property="Foreground" Value="White" />
                                                                         <Setter TargetName="Bd" Property="Effect">
                                                                             <Setter.Value>
                                                                                 <DropShadowEffect BlurRadius="8" Color="#60CDFF" Opacity="0.3" ShadowDepth="0" />
                                                                             </Setter.Value>
                                                                         </Setter>
                                                                     </Trigger>
                                                                     <Trigger Property="IsMouseOver" Value="True">
                                                                         <Setter TargetName="Bd" Property="Background" Value="#1AFFFFFF" />
                                                                     </Trigger>
                                                                 </ControlTemplate.Triggers>
                                                             </ControlTemplate>
                                                         </Setter.Value>
                                                     </Setter>
                                                 </Style>
                                             </CheckBox.Style>
                                             <CheckBox.Content>
                                                 <Grid Width="32" Height="26">
                                                     <ui:SymbolIcon
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"
                                                         FontSize="16"
                                                         Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=CheckBox}}"
                                                         Symbol="Alert24" />
                                                     <Ellipse
                                                         x:Name="AlertEnabledDot"
                                                         Width="7"
                                                         Height="7"
                                                         Margin="0,1,2,0"
                                                         HorizontalAlignment="Right"
                                                         VerticalAlignment="Top"
                                                         Fill="#45E39A"
                                                         Visibility="Collapsed" />
                                                     <Border
                                                         x:Name="AlertEnabledBadge"
                                                         MinWidth="14"
                                                         Height="14"
                                                         Margin="0,-1,-3,0"
                                                         Padding="3,0"
                                                         HorizontalAlignment="Right"
                                                         VerticalAlignment="Top"
                                                         Background="#45E39A"
                                                         CornerRadius="7"
                                                         Visibility="Collapsed">
                                                         <TextBlock
                                                             x:Name="AlertEnabledCountText"
                                                             VerticalAlignment="Center"
                                                             FontSize="8"
                                                             FontWeight="Bold"
                                                             Foreground="#071711"
                                                             TextAlignment="Center" />
                                                     </Border>
                                                 </Grid>
                                             </CheckBox.Content>
                                         </CheckBox>

                                         <!-- Vertical Separator -->
                                         <Border
                                             Grid.Column="1"
                                             Width="1"
                                             Background="#20FFFFFF"
                                             Margin="0,4"
                                             VerticalAlignment="Stretch" />

                                         <!-- Chat Alerts Dropdown -->
                                         <ui:DropDownButton
                                             x:Name="ChatAlertsConfigureButton"
                                             Grid.Column="2"
                                             Margin="0"
                                             Padding="7,6,9,6"
                                             Height="30"
                                             VerticalAlignment="Center"
                                             ToolTip="{DynamicResource Configure}"
                                             Icon="{ui:SymbolIcon Symbol=Settings20}">
                                             <ui:DropDownButton.Style>
                                                 <Style TargetType="ui:DropDownButton" BasedOn="{StaticResource {x:Type ui:DropDownButton}}">
                                                     <Setter Property="Background" Value="Transparent" />
                                                     <Setter Property="BorderBrush" Value="Transparent" />
                                                     <Setter Property="BorderThickness" Value="0" />
                                                     <Setter Property="CornerRadius" Value="0,6,6,0" />
                                                     <Style.Triggers>
                                                         <Trigger Property="IsMouseOver" Value="True">
                                                             <Setter Property="Background" Value="#1AFFFFFF" />
                                                             <Setter Property="BorderBrush" Value="Transparent" />
                                                         </Trigger>
                                                     </Style.Triggers>
                                                 </Style>
                                             </ui:DropDownButton.Style>
                                             <ui:DropDownButton.Flyout>
                                                 <ContextMenu Placement="Custom" CustomPopupPlacementCallback="CenterMegaMenu_Callback">
                                                     <ContextMenu.Style>
                                                         <Style TargetType="ContextMenu" BasedOn="{StaticResource DarkContextMenu}">
                                                             <Setter Property="Template">
                                                                 <Setter.Value>
                                                                     <ControlTemplate TargetType="ContextMenu">
                                                                         <Border
                                                                             Padding="12,10"
                                                                             Background="{TemplateBinding Background}"
                                                                             BorderBrush="{DynamicResource CardBorder}"
                                                                             BorderThickness="1"
                                                                             CornerRadius="{DynamicResource Radius}"
                                                                             SnapsToDevicePixels="True">
                                                                             <StackPanel Orientation="Vertical">
                                                                                 <!-- Top Row: Quick Actions -->
                                                                                 <Grid Margin="4,2,4,8">
                                                                                      <Grid.ColumnDefinitions>
                                                                                          <ColumnDefinition Width="*" />
                                                                                          <ColumnDefinition Width="6" />
                                                                                          <ColumnDefinition Width="*" />
                                                                                          <ColumnDefinition Width="6" />
                                                                                          <ColumnDefinition Width="Auto" />
                                                                                      </Grid.ColumnDefinitions>
                                                                                      
                                                                                      <ui:Button
                                                                                          Grid.Column="0"
                                                                                          Content="{DynamicResource SelectAll}"
                                                                                          Click="SelectAllAlerts_Click"
                                                                                          Appearance="Secondary"
                                                                                          HorizontalAlignment="Stretch">
                                                                                          <ui:Button.Icon>
                                                                                              <ui:SymbolIcon Symbol="CheckmarkSquare24" />
                                                                                          </ui:Button.Icon>
                                                                                      </ui:Button>
                                                                                      
                                                                                      <ui:Button
                                                                                          Grid.Column="2"
                                                                                          Content="{DynamicResource DeselectAll}"
                                                                                          Click="DeselectAllAlerts_Click"
                                                                                          Appearance="Secondary"
                                                                                          HorizontalAlignment="Stretch">
                                                                                          <ui:Button.Icon>
                                                                                              <ui:SymbolIcon Symbol="DismissSquare24" />
                                                                                          </ui:Button.Icon>
                                                                                      </ui:Button>

                                                                                      <ui:Button
                                                                                          Grid.Column="4"
                                                                                          Click="EditAlertTemplates_Click"
                                                                                          Appearance="Secondary"
                                                                                          Padding="8,6"
                                                                                          ToolTip="{DynamicResource CustomizeChatAlertsToolTip}">
                                                                                          <ui:Button.Icon>
                                                                                              <ui:SymbolIcon Symbol="Edit24" />
                                                                                          </ui:Button.Icon>
                                                                                      </ui:Button>
                                                                                  </Grid>
                                                                                 
                                                                                 <!-- Horizontal Separator -->
                                                                                 <Border BorderBrush="#15FFFFFF" BorderThickness="0,0,0,1" Margin="0,0,0,10" />
                                                                                 
                                                                                 <!-- Categorized Items Host -->
                                                                                 <StackPanel IsItemsHost="True" Orientation="Horizontal" />
                                                                             </StackPanel>
                                                                         </Border>
                                                                     </ControlTemplate>
                                                                 </Setter.Value>
                                                             </Setter>
                                                         </Style>
                                                     </ContextMenu.Style>

                                                     <!-- Column 1: Events -->
                                                     <MenuItem Header="{DynamicResource Events}" BorderThickness="0,0,1,0">
                                                         <MenuItem.Style>
                                                             <Style TargetType="MenuItem">
                                                                 <Setter Property="Template">
                                                                     <Setter.Value>
                                                                         <ControlTemplate TargetType="MenuItem">
                                                                             <Border
                                                                                 BorderBrush="#15FFFFFF"
                                                                                 BorderThickness="{TemplateBinding BorderThickness}"
                                                                                 Margin="0,0,12,0"
                                                                                 Padding="0,0,12,0">
