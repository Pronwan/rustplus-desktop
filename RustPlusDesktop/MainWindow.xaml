                                                        Minimum="0.1"
                                                        Maximum="1"
                                                        ValueChanged="LayerMonumentVisual_ValueChanged" />
                                                    <TextBlock
                                                        Grid.Column="2"
                                                        Margin="8,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Foreground="{DynamicResource TextSubtle}"
                                                        Text="{Binding Value, ElementName=SliderLayerMonumentOpacity, StringFormat={}{0:0%}}" />
                                                </Grid>

                                                <TextBlock Margin="0,2,0,5" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextSubtle}" Text="EXTRA MONUMENT TYPES" />
                                                <Border Margin="0,0,0,10" Padding="10,6" Background="#0D1520" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="8">
                                                    <WrapPanel x:Name="PnlLayerExtraMonumentFilters" Orientation="Horizontal" />
                                                </Border>
                                                <ui:Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Click="BtnOpenMonumentList_Click">
