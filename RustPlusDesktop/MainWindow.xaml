<ui:FluentWindow
    x:Class="RustPlusDesk.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:RustPlusDesk.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:diag="clr-namespace:System.Diagnostics;assembly=WindowsBase"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:p="clr-namespace:RustPlusDesk.Properties"
    xmlns:services="clr-namespace:RustPlusDesk.Services"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:views="clr-namespace:RustPlusDesk.Views"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    Title="{DynamicResource AppTitle}"
    Width="1750"
    Height="814"
    MinWidth="1000"
    MinHeight="700"
    Background="{DynamicResource AppBg}"
    ExtendsContentIntoTitleBar="True"
    Foreground="{DynamicResource TextPrimary}"
    ResizeMode="CanResize"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    mc:Ignorable="d">
    <ui:FluentWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Views/MainWindow/SharedResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style TargetType="ui:Snackbar">
                <Setter Property="Background" Value="#E6101418"/>
                <Setter Property="BorderBrush" Value="#25FFFFFF"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ui:Snackbar">
                            <!-- Glassmorphic card container with shadow -->
                            <Border x:Name="SnackbarBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    Margin="0,0,0,10"
                                    MaxWidth="380"
                                    SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="15" Color="Black" Opacity="0.4" ShadowDepth="3"/>
                                </Border.Effect>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/> <!-- Colored Accent Bar -->
                                        <ColumnDefinition Width="*"/>    <!-- Main Content Area -->
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Left accent indicator bar -->
                                    <Border x:Name="AccentBar" 
                                            Grid.Column="0" 
                                            Width="5" 
                                            CornerRadius="8,0,0,8" 
                                            Background="{DynamicResource Accent}" 
                                            VerticalAlignment="Stretch"/>
                                    
                                    <Border Grid.Column="1" Padding="14,16,14,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/> <!-- Icon -->
                                                <ColumnDefinition Width="*"/>    <!-- Text & Content -->
                                                <ColumnDefinition Width="Auto"/> <!-- Close Button -->
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Icon on the Left -->
                                            <ContentPresenter Grid.Column="0" 
                                                              Content="{TemplateBinding Icon}" 
                                                              VerticalAlignment="Top" 
                                                              Margin="0,2,12,0" />
                                            
                                            <!-- Center Content -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{TemplateBinding Title}" 
                                                           FontWeight="Bold" 
                                                           FontSize="14" 
                                                           Margin="0,0,0,6" 
                                                           Foreground="{DynamicResource TextPrimary}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <Trigger Property="Text" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </Trigger>
                                                                <Trigger Property="Text" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                           
                                                <ContentPresenter Content="{TemplateBinding Content}"/>
                                            </StackPanel>
                                            
                                            <!-- Close Button -->
                                            <ui:Button Grid.Column="2" 
                                                       x:Name="PART_CloseButton" 
                                                       Command="{TemplateBinding TemplateButtonCommand}"
                                                       Visibility="{Binding IsCloseButtonEnabled, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVisibility}}"
                                                       Appearance="Transparent" 
                                                       Width="28" 
                                                       Height="28" 
                                                       Padding="0" 
                                                       VerticalAlignment="Top" 
                                                       Margin="8,-4,-4,0" 
                                                       ToolTip="Dismiss">
                                                <ui:SymbolIcon Symbol="Dismiss24" FontSize="14" Foreground="{DynamicResource TextSubtle}" />
                                            </ui:Button>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                            
                            <ControlTemplate.Triggers>
                                <!-- Appearance=Success: Green indicator -->
                                <Trigger Property="Appearance" Value="Success">
                                    <Setter TargetName="AccentBar" Property="Background" Value="#4CAF50"/>
                                </Trigger>
                                <!-- Appearance=Caution: Orange/Yellow indicator -->
                                <Trigger Property="Appearance" Value="Caution">
                                    <Setter TargetName="AccentBar" Property="Background" Value="#FFA500"/>
                                </Trigger>
                                <!-- Appearance=Danger: Red indicator -->
                                <Trigger Property="Appearance" Value="Danger">
                                    <Setter TargetName="AccentBar" Property="Background" Value="#F44336"/>
                                </Trigger>
                                <!-- Appearance=Info: Blue indicator -->
                                <Trigger Property="Appearance" Value="Info">
                                    <Setter TargetName="AccentBar" Property="Background" Value="{DynamicResource Accent}"/>
                                </Trigger>
                                <!-- Appearance=Primary: System Accent indicator -->
                                <Trigger Property="Appearance" Value="Primary">
                                    <Setter TargetName="AccentBar" Property="Background" Value="{DynamicResource Accent}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        <DataTemplate x:Key="TrackedPlayerTemplate" DataType="{x:Type services:TrackedPlayer}">
            <Grid
                x:Name="PlayerRow"
                Margin="0,2"
                Background="Transparent">
                <Grid.ContextMenu>
                    <ContextMenu Style="{StaticResource DarkContextMenu}">
                        <MenuItem
                            Click="BtnViewTracked_Click"
                            Header="{DynamicResource ViewProfile}"
                            Icon="{ui:SymbolIcon Symbol=Eye24}">
                            <MenuItem.Style>
                                <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBMOnly}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </MenuItem.Style>
                        </MenuItem>

                        <MenuItem
                            Click="BtnGroupTracked_Click"
                            Header="{DynamicResource ChangeGroup}"
                            Icon="{ui:SymbolIcon Symbol=Folder24}" />
                        <MenuItem
                            Click="BtnRenameTracked_Click"
                            Header="{DynamicResource Rename}"
                            Icon="{ui:SymbolIcon Symbol=Edit24}" />
                        <Separator />
                        <MenuItem
                            Click="BtnRemoveTracked_Click"
                            Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                            Header="{DynamicResource RemoveTracked}"
                            Icon="{ui:SymbolIcon Symbol=Delete24}" />
                    </ContextMenu>
                </Grid.ContextMenu>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Player Info  -->
                <StackPanel
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Ellipse
                        x:Name="StatusDot"
                        Width="8"
                        Height="8"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        Fill="#666666" />
                    <TextBlock
                        x:Name="TxtName"
                        VerticalAlignment="Center"
                        FontSize="13"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{Binding Name}"
                        TextTrimming="CharacterEllipsis"
                        ToolTip="{Binding Name}" />
                </StackPanel>

                <!--  Timestamp / Playtime  -->
                <TextBlock
                    x:Name="TxtPlayTime"
                    Grid.Column="1"
                    Margin="8,0,8,0"
                    VerticalAlignment="Center"
                    FontSize="10"
                    Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                    Text="{Binding PlayTimeStr}"
                    Visibility="Collapsed" />

                <!--  Actions  -->
                <StackPanel
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <ui:Button
                        x:Name="BtnViewAction"
                        Padding="8,2"
                        Appearance="Transparent"
                        Click="BtnViewTracked_Click"
                        Content="{DynamicResource View}"
                        FontSize="11"
                        Tag="{Binding BMId}" />

                    <ui:Button
                        x:Name="BtnMore"
                        Padding="4"
                        Appearance="Transparent"
                        Click="BtnMore_Click"
                        Icon="{ui:SymbolIcon Symbol=MoreHorizontal24}"
                        Opacity="0"
                        ToolTip="{DynamicResource MoreOptions}" />
                </StackPanel>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsOnline}" Value="True">
                    <Setter TargetName="StatusDot" Property="Fill" Value="#62D38B" />
                    <Setter TargetName="TxtName" Property="Foreground" Value="White" />
                    <Setter TargetName="TxtPlayTime" Property="Visibility" Value="Visible" />
                </DataTrigger>
                <Trigger SourceName="PlayerRow" Property="IsMouseOver" Value="True">
                    <Setter TargetName="BtnMore" Property="Opacity" Value="1" />
                </Trigger>
                <DataTrigger Binding="{Binding IsBMOnly}" Value="True">
                    <Setter TargetName="BtnViewAction" Property="Content" Value="View on BM" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <conv:BoolToVisibilityConverter x:Key="Vis" />
        </ResourceDictionary>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Custom TitleBar for Guaranteed Visibility in Mica/Dark Mode  -->
        <Border
            Grid.Row="0"
            Background="#0F1013"
            BorderBrush="#1AFFFFFF"
            BorderThickness="0,0,0,1">
            <ui:TitleBar
                x:Name="AppTitleBar"
                Height="48"
                Title="{DynamicResource AppTitle}"
                Background="Transparent"
                Foreground="White">
                <ui:TitleBar.Resources>
                    <Style BasedOn="{StaticResource {x:Type ui:TitleBarButton}}" TargetType="ui:TitleBarButton">
                        <Setter Property="Height" Value="48" />
                        <Setter Property="VerticalAlignment" Value="Stretch" />
                    </Style>
                </ui:TitleBar.Resources>
                <ui:TitleBar.Icon>
                    <ui:ImageIcon Source="pack://application:,,,/Assets/rustplus-desktop-icon.ico" />
                </ui:TitleBar.Icon>
                <ui:TitleBar.Header>
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <ui:Button
                        x:Name="BtnDiscord"
                        Width="36"
                        Height="36"
                        Margin="2,6"
                        Padding="0"
                        Appearance="Transparent"
                        Click="BtnDiscord_Click"
                        ToolTip="{DynamicResource JoinDiscord}">
                        <Image
                            Width="16"
                            Height="16"
                            RenderOptions.BitmapScalingMode="HighQuality"
                            Source="pack://application:,,,/Assets/icons/discord.png" />
                    </ui:Button>
                    <ui:Button
                        x:Name="BtnPatchNotes"
                        Width="36"
                        Height="36"
                        Margin="2,6"
                        Padding="0"
                        Appearance="Transparent"
                        Click="BtnPatchNotes_Click"
                        Icon="{ui:SymbolIcon Symbol=DocumentBulletList24}"
                        ToolTip="{DynamicResource PatchNotes}" />
                    <ui:Button
                        x:Name="BtnSettings"
                        Width="36"
                        Height="36"
                        Margin="2,6"
                        Padding="0"
                        Appearance="Transparent"
                        Click="BtnSettings_Click"
                        Icon="{ui:SymbolIcon Symbol=Settings24}"
                        ToolTip="{DynamicResource Settings}" />
                    <Border
                        Height="36"
                        Margin="6,6,8,6"
                        HorizontalAlignment="Right"
                        BorderThickness="1"
                        CornerRadius="8">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsUpdateStatusExpanded}" Value="True">
                                        <Setter Property="Background" Value="#181D22" />
                                        <Setter Property="BorderBrush" Value="#2AFFFFFF" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsUpdateAvailable}" Value="True">
                                        <Setter Property="Background" Value="#162F37" />
                                        <Setter Property="BorderBrush" Value="#6600CCFF" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsDownloadingUpdate}" Value="True">
                                        <Setter Property="Background" Value="#122A31" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:Button
                                x:Name="BtnCheckUpdates"
                                MinWidth="34"
                                Height="34"
                                Padding="7,3"
                                Appearance="Transparent"
                                Click="BtnCheckUpdates_Click"
                                ToolTip="{Binding UpdateStatusText}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0" VerticalAlignment="Center">
                                        <ui:SymbolIcon
                                            Foreground="{DynamicResource Accent}"
                                            Symbol="ArrowDownload24" />
                                        <Ellipse
                                            Width="5"
                                            Height="5"
                                            Margin="0,-3,-4,0"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Fill="#62D38B"
                                            Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVisibility}}" />
                                    </Grid>
                                    <Grid
                                        Grid.Column="1"
                                        MinWidth="210"
                                        Margin="9,0,0,0"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding IsUpdateStatusExpanded, Converter={StaticResource BoolToVisibility}}">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <DockPanel LastChildFill="True">
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                Foreground="White"
                                                Text="{Binding UpdateStatusText}" />
                                            <TextBlock
                                                Margin="8,0,0,0"
                                                HorizontalAlignment="Right"
                                                FontSize="10"
                                                Foreground="#CCFFFFFF"
                                                Text="{Binding UpdateDownloadPercentage}"
                                                Visibility="{Binding IsDownloadingUpdate, Converter={StaticResource BoolToVisibility}}" />
                                        </DockPanel>
                                        <TextBlock
                                            Grid.Row="1"
                                            HorizontalAlignment="Right"
                                            FontSize="8"
                                            Foreground="#99FFFFFF"
                                            Text="{Binding UpdateDownloadSpeed}"
                                            Visibility="{Binding IsDownloadingUpdate, Converter={StaticResource BoolToVisibility}}" />
                                        <ProgressBar
                                            Grid.Row="2"
                                            Height="3"
                                            Margin="0,1,0,0"
                                            IsIndeterminate="{Binding IsUpdateProcessing}"
                                            Value="{Binding UpdateDownloadProgress}"
                                            Visibility="{Binding IsDownloadingUpdate, Converter={StaticResource BoolToVisibility}}" />
                                    </Grid>
                                </Grid>
                            </ui:Button>
                            <ui:Button
                                Grid.Column="1"
                                Width="46"
                                Height="30"
                                Padding="0"
                                Appearance="Transparent"
                                Click="PauseResumeDownload_Click"
                                Content="{Binding PauseResumeButtonText}"
                                FontSize="9"
                                Visibility="{Binding CanControlUpdateDownload, Converter={StaticResource BoolToVisibility}}" />
                            <ui:Button
                                Grid.Column="2"
                                Width="30"
                                Height="30"
                                Padding="0"
                                Appearance="Transparent"
                                Click="CancelDownload_Click"
                                Icon="{ui:SymbolIcon Symbol=Dismiss24}"
                                ToolTip="Cancel download"
                                Visibility="{Binding CanControlUpdateDownload, Converter={StaticResource BoolToVisibility}}" />
                        </Grid>
                    </Border>
                    </StackPanel>
                </ui:TitleBar.Header>
            </ui:TitleBar>
        </Border>

        <Grid
            x:Name="Root"
            Grid.Row="1"
            Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition
                    x:Name="ColSidebar"
                    Width="72"
                    MinWidth="72"
                    MaxWidth="600" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" MinWidth="400" />
            </Grid.ColumnDefinitions>

            <GridSplitter
                x:Name="SidebarSplitter"
                Grid.Column="1"
                Width="8"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="Transparent"
                DragCompleted="SidebarSplitter_DragCompleted"
                MouseEnter="LeftPanelBorder_MouseEnter"
                MouseLeave="LeftPanelBorder_MouseLeave"
                ResizeBehavior="PreviousAndNext"
                ResizeDirection="Columns"
                ShowsPreview="False" />

            <!--  Left Panel  -->
            <Border
                x:Name="LeftPanelBorder"
                Grid.Column="0"
                MinWidth="72"
                MaxWidth="600"
                Margin="0,0,0,0"
                Padding="0"
                Background="{DynamicResource Surface}"
                BorderBrush="#1AFFFFFF"
                BorderThickness="0,0,1,0"
                ClipToBounds="True"
                CornerRadius="0"
                MouseEnter="LeftPanelBorder_MouseEnter"
                MouseLeave="LeftPanelBorder_MouseLeave"
                TextElement.FontFamily="Segoe UI Variable Display, Segoe UI">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="24"
                        Opacity="0.35"
                        ShadowDepth="0"
                        Color="#000000" />
                </Border.Effect>
                <Grid>
                    <DockPanel
                        x:Name="LeftPanelContent"
                        LastChildFill="True"
                        Visibility="Collapsed">

                    <!--  TOP: Account + Serverliste  -->
                    <StackPanel DockPanel.Dock="Top">
                        <!--  Header  -->
                        <Border
                            Margin="0,0,0,10"
                            Padding="9,7"
                            Background="{DynamicResource SurfaceAlt}"
                            BorderBrush="{DynamicResource CardBorder}"
                            BorderThickness="1"
                            CornerRadius="10">
                            <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!--  Profile Picture / Icon  -->
                                <Grid
                                    Grid.Column="0"
                                    Width="28"
                                    Height="28"
                                    Margin="0,0,8,0">
                                    <Border
                                        Background="#1AFFFFFF"
                                        ClipToBounds="True"
                                        CornerRadius="14">
                                        <Grid>
                                            <ui:SymbolIcon
                                                FontSize="16"
                                                Foreground="White"
                                                Opacity="0.4"
                                                Symbol="Person24" />
                                            <Image
                                                x:Name="ImgSteam"
                                                Source="{Binding MyAvatar}"
                                                Stretch="UniformToFill"
                                                RenderOptions.BitmapScalingMode="HighQuality">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding MyAvatar}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <!--  Identity  -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse
                                            Width="7"
                                            Height="7"
                                            Margin="0,0,6,0"
                                            VerticalAlignment="Center"
                                            ToolTip="Rust+ Companion connection">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#68717D" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRustCompanionConnected}" Value="True">
                                                            <Setter Property="Fill" Value="#57C979" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock
                                            FontSize="8"
                                            FontWeight="Bold"
                                            Foreground="#E8612C"
                                            Text="RUST+ COMPANION" />
                                    </StackPanel>
                                    <TextBlock
                                        x:Name="TxtSteamName"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="{DynamicResource SteamAccount}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        x:Name="TxtSteamId"
                                        FontSize="8"
                                        Foreground="White"
                                        Opacity="0.6"
                                        Text="{DynamicResource NotLoggedIn}" />
                                </StackPanel>

                                <!--  Action Buttons  -->
                                <StackPanel
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                                    <ui:Button
                                        x:Name="BtnPinSidebar"
                                        Width="32"
                                        Height="28"
                                        Margin="2,0,0,0"
                                        Padding="0"
                                        Appearance="Transparent"
                                        Click="BtnToggleSidebarPin_Click"
                                        Icon="{ui:SymbolIcon Symbol=Pin24}"
                                        ToolTip="Keep sidebar unfolded" />
                                </StackPanel>
                            </Grid>
                            <Border Margin="0,6,0,0" Padding="0,5,0,0" BorderBrush="#18FFFFFF" BorderThickness="0,1,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Width="28" Height="28">
                                        <ui:SymbolIcon FontSize="16" Foreground="{DynamicResource Accent}" Symbol="Cloud24" />
                                        <Ellipse
                                            Width="7"
                                            Height="7"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            Stroke="{DynamicResource SurfaceAlt}"
                                            StrokeThickness="1.5"
                                            ToolTip="{Binding CloudAccountStatusText}">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#68717D" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCloudConnected}" Value="True">
                                                            <Setter Property="Fill" Value="#57C979" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                    </Grid>
                                    <StackPanel
                                        Grid.Column="1"
                                        Margin="6,0"
                                        VerticalAlignment="Center">
                                        <TextBlock
                                            FontSize="8"
                                            FontWeight="Bold"
                                            Foreground="{DynamicResource Accent}"
                                            Text="CLOUD ACCOUNT" />
                                        <TextBlock
                                            FontSize="8"
                                            Foreground="#CCFFFFFF"
                                            Text="{Binding CloudAccountStatusText}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <ui:Button
                                        x:Name="BtnCloudAccount"
                                        Grid.Column="2"
                                        MinWidth="62"
                                        Height="26"
                                        Padding="8,2"
                                        VerticalAlignment="Center"
                                        Appearance="Secondary"
                                        AutomationProperties.Name="Open cloud account"
                                        Click="BtnCloudAccount_Click"
                                        Content="{Binding CloudAccountActionText}" />
                                </Grid>
                            </Border>
                            </StackPanel>
                        </Border>

                        <!--  FCM Token Expiry Badge  -->
                        <ui:InfoBar
                            x:Name="FcmExpiryInfoBar"
                            Title="Rust+ Companion session"
                            Margin="0,0,0,10"
                            IsClosable="False"
                            IsOpen="True"
                            Message="{Binding FcmExpiryText}"
                            Severity="Informational">
                            <ui:InfoBar.Style>
                                <Style TargetType="ui:InfoBar">
                                    <Setter Property="Severity" Value="Informational" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FcmExpiryDays, Converter={StaticResource LessThanConverter}, ConverterParameter=30}" Value="True">
                                            <Setter Property="Severity" Value="Warning" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding FcmExpiryDays}" Value="-1">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:InfoBar.Style>
                        </ui:InfoBar>

                        <Border
                            Height="1"
                            Margin="0,0,0,12"
                            Background="#12FFFFFF" />

                        <Grid Margin="0,4,0,6">
                            <TextBlock
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextBrushMuted}"
                                Text="{DynamicResource PairedServers}" />
                            <ToggleButton
                                x:Name="BtnToggleServerArea"
                                HorizontalAlignment="Right"
                                Padding="4,2"
                                IsChecked="False"
                                Click="BtnToggleServerArea_Click"
                                ToolTip="{DynamicResource ToggleServerArea}">
                                <ui:SymbolIcon x:Name="IconToggleServerArea" Symbol="ChevronUp20" />
                            </ToggleButton>
                        </Grid>

                        <StackPanel x:Name="PanelServerArea">

                        <Grid x:Name="ServerListGrid">
                            <ListBox
                                x:Name="ListServers"
                                MinHeight="60"
                                MaxHeight="100"
                                DisplayMemberPath="Name"
                                Foreground="White"
                                ItemsSource="{Binding Servers}"
                                SelectedItem="{Binding Selected, Mode=TwoWay}"
                                SelectionChanged="ListServers_SelectionChanged">

                                <ListBox.Resources>
                                    <conv:NotNullToBoolConverter x:Key="LocalNotNull" />
                                    <ContextMenu
                                        x:Key="ServerCtx"
                                        Foreground="White"
                                        Style="{StaticResource DarkContextMenu}">
                                        <MenuItem
                                            Click="Server_Delete_Click"
                                            Foreground="Black"
                                            Tag="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                            <MenuItem.Header>
                                                <TextBlock>
                                                    <Run Text="🗑️ " /><Run Text="{DynamicResource DeleteServerEllipsis}" />
                                                </TextBlock>
                                            </MenuItem.Header>
                                        </MenuItem>
                                        <MenuItem
                                            Click="Server_CopyMap_Click"
                                            Foreground="Black"
                                            Tag="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                            <MenuItem.Style>
                                                <Style TargetType="MenuItem">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PlacementTarget.DataContext.LocalMapFilePath, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource LocalNotNull}}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </MenuItem.Style>
                                            <MenuItem.Header>
                                                <TextBlock>
                                                    <Run Text="🗺️ " /><Run Text="Copy map to server..." />
                                                </TextBlock>
                                            </MenuItem.Header>
                                        </MenuItem>
                                    </ContextMenu>
                                </ListBox.Resources>

                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="ContextMenu" Value="{StaticResource ServerCtx}" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>

                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="12"
                                FontStyle="Italic"
                                Foreground="{StaticResource TextSubtle}"
                                IsHitTestVisible="False"
                                Text="{DynamicResource NoServersPaired}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Servers.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <!--  Compact Connection Card  -->
                        <Border
                            Margin="0,8,0,0"
                            Padding="12,10"
                            Background="{DynamicResource SurfaceAlt}"
                            BorderBrush="{DynamicResource CardBorder}"
                            BorderThickness="1"
                            CornerRadius="10">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Selected, Converter={StaticResource NotNull}}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <!--  Status Dot  -->
                                    <ColumnDefinition Width="*" />
                                    <!--  Name + Status  -->
                                    <ColumnDefinition Width="Auto" />
                                    <!--  Buttons  -->
                                </Grid.ColumnDefinitions>

                                <!--  Status Dot  -->
                                <Grid
                                    Width="10"
                                    Height="10"
                                    Margin="0,0,12,0"
                                    VerticalAlignment="Center">
                                    <Ellipse x:Name="StatusDot">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="#EF5350" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                        <Setter Property="Fill" Value="#FFCA28" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsInitializing}" Value="True">
                                                        <Setter Property="Fill" Value="#FFCA28" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Selected.IsConnected}" Value="True">
                                                        <Setter Property="Fill" Value="#66BB6A" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                </Grid>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="{Binding Selected.Name, FallbackValue='Select a Server'}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        FontSize="9"
                                        FontWeight="Bold"
                                        Opacity="0.7">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{DynamicResource StatusDisconnected}" />
                                                <Setter Property="Foreground" Value="#EF5350" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                        <Setter Property="Text" Value="{DynamicResource StatusConnecting}" />
                                                        <Setter Property="Foreground" Value="#FFCA28" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsInitializing}" Value="True">
                                                        <Setter Property="Text" Value="{DynamicResource StatusInitializing}" />
                                                        <Setter Property="Foreground" Value="#FFCA28" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Selected.IsConnected}" Value="True">
                                                        <Setter Property="Text" Value="{DynamicResource StatusDevicesActive}" />
                                                        <Setter Property="Foreground" Value="#66BB6A" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Selected.IsFullConnected}" Value="True">
                                                        <Setter Property="Text" Value="{DynamicResource StatusFullyConnected}" />
                                                        <Setter Property="Foreground" Value="#66BB6A" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                                    <!--  Connect  -->
                                    <ui:Button
                                        x:Name="UiBtnConnect"
                                        Margin="0,0,4,0"
                                        Padding="10,4"
                                        Appearance="Primary"
                                        Click="BtnConnect_Click"
                                        Content="{DynamicResource Connect}"
                                        Icon="{ui:SymbolIcon Symbol=PlugConnected20}"
                                        Visibility="{Binding Selected.IsConnected, Converter={StaticResource BoolToVisibilityInv}}" />

                                    <!--  Full Connect  -->
                                    <ui:Button
                                        x:Name="UiBtnFullConnect"
                                        Margin="0,0,4,0"
                                        Padding="10,4"
                                        Appearance="Primary"
                                        Click="BtnConnect_Click"
                                        Content="{DynamicResource FullConnect}"
                                        Icon="{ui:SymbolIcon Symbol=Play20}"
                                        ToolTip="{DynamicResource LoadMapTeam}">
                                        <ui:Button.Style>
                                            <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="ui:Button">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding Selected.IsConnected}" Value="True" />
                                                            <Condition Binding="{Binding Selected.IsFullConnected}" Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ui:Button.Style>
                                    </ui:Button>

                                    <!--  Disconnect  -->
                                    <ui:Button
                                        x:Name="UiBtnDisconnect"
                                        Padding="10,4"
                                        Appearance="Caution"
                                        Click="BtnDisconnect_Click"
                                        Icon="{ui:SymbolIcon Symbol=PlugDisconnected20}"
                                        ToolTip="{DynamicResource Disconnect}"
                                        Visibility="{Binding Selected.IsConnected, Converter={StaticResource BoolToVisibility}}" />

                                    <!--  Info  -->
                                    <ui:Button
                                        Margin="4,0,0,0"
                                        Padding="10,4"
                                        Appearance="Secondary"
                                        Click="BtnShowServerInfo_Click"
                                        Icon="{ui:SymbolIcon Symbol=Info20}"
                                        ToolTip="{DynamicResource ServerDetails}" />


                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel Margin="0,16,0,0">
                            <TextBlock
                                Margin="0,0,0,10"
                                FontSize="10"
                                FontWeight="Bold"
                                Foreground="White"
                                Opacity="0.6"
                                Text="RUST+ COMPANION &amp; PAIRING" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <ui:Button
                                        x:Name="BtnListenPairing"
                                        Padding="8,2"
                                        Appearance="Secondary"
                                        Click="BtnListenPairing_Click"
                                        Content="{DynamicResource Listen}"
                                        Icon="{ui:SymbolIcon Symbol=Bluetooth24}"
                                        IsEnabled="{Binding CanStartPairing}"
                                        Visibility="{Binding IsPairingBusy, Converter={StaticResource BoolToVisibilityInv}}">
                                        <ui:Button.ContextMenu>
                                            <ContextMenu Style="{StaticResource DarkContextMenu}">
                                                <MenuItem Click="BtnListenWithEdge_Click" Header="{DynamicResource TryPairingEdge}" />
                                                <Separator />
                                                <MenuItem Click="BtnResetPairing_Click" Header="{DynamicResource ResetPairingConfig}" />
                                                <MenuItem Click="BtnResetAndListen_Click" Header="{DynamicResource ResetListenPairing}" />
                                                <MenuItem Click="BtnResetAndListenEdge_Click" Header="{DynamicResource ResetListenEdge}" />
                                            </ContextMenu>
                                        </ui:Button.ContextMenu>
                                    </ui:Button>

                                    <ui:Button
                                        x:Name="BtnStopPairing"
                                        Padding="8,2"
                                        Appearance="Caution"
                                        Click="BtnStopPairing_Click"
                                        Content="{DynamicResource Stop}"
                                        Icon="{ui:SymbolIcon Symbol=Stop24}"
                                        Visibility="{Binding IsPairingBusy, Converter={StaticResource BoolToVisibility}}" />

                                    <ui:Button
                                        x:Name="BtnFcmInfo"
                                        Width="32"
                                        Height="30"
                                        Margin="6,0,0,0"
                                        Padding="0"
                                        Appearance="Transparent"
                                        Click="BtnFcmInfo_Click"
                                        Icon="{ui:SymbolIcon Symbol=Info24}"
                                        ToolTip="{DynamicResource FcmInfoToolTip}" />
                                </StackPanel>

                                <StackPanel
                                    Grid.Column="1"
                                    Margin="12,0"
                                    VerticalAlignment="Center">
                                    <TextBlock
                                        x:Name="TxtPairingState"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextSubtle}"
                                        Text="{DynamicResource PairingIdle}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPairingBusy}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Visibility="{Binding IsPairingBusy, Converter={StaticResource BoolToVisibility}}">
                                        <Ellipse
                                            Width="8"
                                            Height="8"
                                            VerticalAlignment="Center"
                                            Fill="#4CAF50">
                                            <Ellipse.Effect>
                                                <DropShadowEffect BlurRadius="6" ShadowDepth="0" Color="#4CAF50" Opacity="0.6" />
                                            </Ellipse.Effect>
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPairingBusy}" Value="True">
                                                            <DataTrigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation
                                                                            AutoReverse="True"
                                                                            RepeatBehavior="Forever"
                                                                            Storyboard.TargetProperty="Opacity"
                                                                            From="1"
                                                                            To="0.3"
                                                                            Duration="0:0:1" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.EnterActions>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock Text="Listening" FontSize="10" FontWeight="SemiBold" Foreground="#4CAF50" VerticalAlignment="Center" Margin="5,0,0,0" />
                                        <TextBlock Text="FCM" FontSize="10" FontWeight="SemiBold" Foreground="#4CAF50" VerticalAlignment="Center" Margin="5,0,0,0" />
                                    </StackPanel>
                                </StackPanel>

                                <TextBlock
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    FontSize="9"
                                    FontStyle="Italic"
                                    Foreground="White"
                                    Opacity="0.5"
                                    Text="{DynamicResource RightClickOptions}" />
                            </Grid>
                        </StackPanel>
                        </StackPanel>

                        <Border
                            Height="1"
                            Margin="0,4,0,4"
                            Background="#12FFFFFF" />

                        <Grid Margin="0,2,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse
                                    x:Name="TrackingPulse"
                                    Width="8"
                                    Height="8"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    Fill="#62D38B">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTrackingActive}" Value="True">
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard x:Name="Pulse">
                                                            <Storyboard>
                                                                <DoubleAnimation
                                                                    AutoReverse="True"
                                                                    RepeatBehavior="Forever"
                                                                    Storyboard.TargetProperty="Opacity"
                                                                    From="1"
                                                                    To="0.3"
                                                                    Duration="0:0:1" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <StopStoryboard BeginStoryboardName="Pulse" />
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock
                                    x:Name="TxtTrackingStatus"
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Text="{DynamicResource TrackingActive}" />
                            </StackPanel>
                            <TextBlock
                                x:Name="TxtLastPull"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                FontSize="10"
                                Foreground="{DynamicResource TextSubtle}"
                                Text="{DynamicResource LastPull}" />
                        </Grid>

                        <Border
                            Height="1"
                            Margin="0,8,0,8"
                            Background="#12FFFFFF" />
                    </StackPanel>

                    <!--  BOTTOM: Footer (Donate + Serverdaten) andocken  -->
                    <Grid Margin="0,8,0,0" DockPanel.Dock="Bottom">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!--  Donate  -->
                        <ui:Button
                            x:Name="BtnDonate"
                            Grid.Column="0"
                            Margin="0,0,10,0"
                            Background="#991A1A00"
                            BorderBrush="#80FFD166"
                            Click="BtnDonate_Click"
                            Content="{DynamicResource Donate}"
                            Foreground="#FFD166"
                            Icon="{ui:SymbolIcon Symbol=Heart24}"
                            ToolTip="{DynamicResource SupportDeveloper}" />

                        <!--  Language Settings -->
                        <Border Grid.Column="1" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <ui:Button
                                    x:Name="BtnLanguageSettings"
                                    Width="32"
                                    Height="32"
                                    Padding="0"
                                    Appearance="Secondary"
                                    Click="BtnLanguageSettings_Click"
                                    ToolTip="{DynamicResource SelectLanguage}">
                                    <Image
                                        x:Name="ImgLanguageFlag"
                                        Width="20"
                                        Height="15"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        RenderOptions.BitmapScalingMode="HighQuality"
                                        Source="pack://application:,,,/Assets/rustplus-desktop-icon.ico"
                                        Stretch="UniformToFill" />
                                </ui:Button>

                                <StackPanel Orientation="Horizontal" Margin="8,0,0,0" VerticalAlignment="Center" Visibility="{Binding IsDownloadingIcons, Converter={StaticResource BoolToVisibility}}">
                                    <ui:SymbolIcon Symbol="ArrowDownload24" Margin="0,0,4,0" VerticalAlignment="Center" FontSize="14" Foreground="{DynamicResource SystemAccentBrush}"/>
                                    <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                        <Run Text="Icons: "/>
                                        <Run Text="{Binding IconsDownloaded, Mode=OneWay}"/>
                                        <Run Text="/"/>
                                        <Run Text="{Binding IconsTotal, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </Grid>

                    <!--  CENTER: TabControl fÃ¼llt den Rest, mit MindesthÃ¶he  -->
            <TabControl
                x:Name="MainTabs"
                VerticalAlignment="Stretch"
                Style="{StaticResource PrettyTabControl}">
                <!--  ===== DEVICES =====  -->
                <TabItem Style="{StaticResource PrettyTabItem}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Connector24" Margin="0,0,6,0" VerticalAlignment="Center" FontSize="14" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}" />
                            <TextBlock VerticalAlignment="Center" Text="{DynamicResource DevicesTab}" />
                        </StackPanel>
                    </TabItem.Header>
                    <DockPanel LastChildFill="True">
                        <!--  Footer  -->
                        <StackPanel
                            Margin="0,10,0,0"
                            HorizontalAlignment="Right"
                            DockPanel.Dock="Bottom"
                            Orientation="Horizontal">
                            <ui:Button
                                x:Name="BtnHotkeys"
                                Appearance="Secondary"
                                MinWidth="135"
                                Height="36"
                                Margin="0,0,5,0"
                                Click="BtnHotkeys_Click"
                                MouseEnter="BtnHotkeys_MouseEnter"
                                MouseLeave="BtnHotkeys_MouseLeave">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Keyboard24" 
                                                   Margin="0,0,6,0" 
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ui:Button}}"
                                                   VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtBtnHotkeys" 
                                               Text="{DynamicResource Hotkeys}" 
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ui:Button}}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </ui:Button>

                            <ui:Button
                                x:Name="BtnPremiumInfoDevices"
                                Appearance="Transparent"
                                Width="32"
                                Margin="0,0,10,0"
                                Icon="{ui:SymbolIcon Symbol=Info24, Filled=True}"
                                Foreground="#e03131"
                                Visibility="Collapsed"
                                Click="BtnPremiumInfoDevices_Click"
                                ToolTip="{DynamicResource PremiumFeatures}" />

                            <ui:Button
                                x:Name="BtnDevicesImport"
                                Width="36"
                                Height="36"
                                Margin="0,0,8,0"
                                Padding="4"
                                Appearance="Secondary"
                                Click="BtnDevicesImport_Click"
                                Icon="{ui:SymbolIcon Symbol=ArrowDownload24}"
                                ToolTip="{DynamicResource ImportDevices}" />
                            <ui:Button
                                x:Name="BtnDevicesExport"
                                Width="36"
                                Height="36"
                                Margin="0,0,8,0"
                                Padding="4"
                                Appearance="Secondary"
                                Click="BtnDevicesExport_Click"
                                Icon="{ui:SymbolIcon Symbol=Cloud24}"
                                ToolTip="{DynamicResource ExportDevices}" />
                            <ui:Button
                                x:Name="BtnLogicEngine"
                                Width="36"
                                Height="36"
                                Margin="0,0,8,0"
                                Padding="4"
                                Appearance="Secondary"
                                Click="BtnLogicEngine_Click"
                                ToolTip="Logic Engine">
                                <ui:Button.Icon>
                                    <ui:SymbolIcon Symbol="DeveloperBoard24" />
                                </ui:Button.Icon>
                                <ui:Button.Style>
                                    <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Selected.IsLogicEngineActive}" Value="True">
                                                <Setter Property="BorderBrush" Value="#3b82f6"/>
                                                <Setter Property="Background" Value="#1a3b82f6"/>
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#3b82f6" BlurRadius="8" ShadowDepth="0" Opacity="0.8"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:Button.Style>
                            </ui:Button>
                            <ui:Button
                                x:Name="BtnDeviceRefresh"
                                Width="36"
                                Height="36"
                                Margin="0,0,8,0"
                                Padding="4"
                                Appearance="Secondary"
                                Click="BtnDeviceRefresh_Click"
                                Icon="{ui:SymbolIcon Symbol=ArrowClockwise24}"
                                ToolTip="{DynamicResource Refresh}" />
                            <ui:Button
                                x:Name="BtnDeleteDevice"
                                Width="36"
                                Height="36"
                                Margin="0,0,0,0"
                                Padding="4"
                                Appearance="Secondary"
                                Click="BtnDeleteDevice_Click"
                                Icon="{ui:SymbolIcon Symbol=Delete24}"
                                Foreground="IndianRed"
                                IsEnabled="{Binding ElementName=ListDevices, Path=SelectedItem.IsMissing, Converter={StaticResource NotNull}}"
                                ToolTip="{DynamicResource DeleteMissingOnly}" />
                        </StackPanel>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" MinWidth="0" />
                                            <ColumnDefinition Width="104" />
                                        </Grid.ColumnDefinitions>

                                        <ui:TextBox
                                            x:Name="TxtDeviceFilter"
                                            Grid.Column="0"
                                            Height="30"
                                            Margin="0,0,8,0"
                                            Padding="8,3"
                                            FontSize="11"
                                            PlaceholderText="Search devices..." />

                                        <ComboBox
                                            x:Name="CmbDeviceTypeFilter"
                                            Grid.Column="1"
                                            Height="30"
                                            FontSize="11"
                                            SelectedIndex="0">
                                            <ComboBoxItem Content="All" Tag="all" />
                                            <ComboBoxItem Content="Switch" Tag="switch" />
                                            <ComboBoxItem Content="Alarm" Tag="alarm" />
                                            <ComboBoxItem Content="Storage" Tag="storage" />
                                        </ComboBox>
                                    </Grid>

                                    <TreeView
                                        x:Name="ListDevices"
                                        Grid.Row="1"
                                        HorizontalContentAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        ItemsSource="{Binding CurrentDevices}"
                                        ScrollViewer.CanContentScroll="False"
                                        SelectedItemChanged="ListDevices_SelectedItemChanged"
                                        VirtualizingPanel.IsVirtualizing="False"
                                        VirtualizingPanel.ScrollUnit="Pixel">

                                        <TreeView.ItemContainerStyle>
                                            <Style TargetType="TreeViewItem">
                                                <Setter Property="AllowDrop" Value="True" />
                                                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="TreeViewItem_PreviewMouseLeftButtonDown" />
                                                <EventSetter Event="PreviewMouseMove" Handler="TreeViewItem_PreviewMouseMove" />
                                                <EventSetter Event="DragEnter" Handler="TreeViewItem_DragEnter" />
                                                <EventSetter Event="DragOver" Handler="TreeViewItem_DragOver" />
                                                <EventSetter Event="DragLeave" Handler="TreeViewItem_DragLeave" />
                                                <EventSetter Event="Drop" Handler="TreeViewItem_Drop" />
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderThickness" Value="0" />
                                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                                <Setter Property="Visibility">
                                                    <Setter.Value>
                                                        <MultiBinding Converter="{StaticResource DeviceFilterVisibilityConverter}">
                                                            <Binding />
                                                            <Binding ElementName="TxtDeviceFilter" Path="Text" />
                                                            <Binding ElementName="CmbDeviceTypeFilter" Path="SelectedItem.Tag" />
                                                        </MultiBinding>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Resources>
                                                    <!-- Nullify default highlight brushes so our card layout handles highlights -->
                                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent" />
                                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#F2F2F2" />
                                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent" />
                                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#F2F2F2" />
