                                                    <TextBlock
                                                        Grid.Column="2"
                                                        Margin="8,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Foreground="{DynamicResource TextSubtle}"
                                                        Text="{Binding Value, ElementName=SliderLayerMonumentScale, StringFormat={}{0:0.0}x}" />
                                                </Grid>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="70" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="48" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" Text="Opacity" />
