                                                    <DataTrigger Binding="{Binding ServerTime}" Value="-">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ServerTime}" Value="–">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
