                IsHitTestVisible="True"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
                <Border
                    Width="340"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource Surface}"
                    BorderBrush="{DynamicResource CardBorder}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel>
                        <ui:ProgressRing
                            Width="48"
                            Height="48"
                            Margin="0,0,0,20"
                            IsIndeterminate="True" />
                        <TextBlock
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextPrimary}"
                            Text="{Binding BusyText}"
                            TextAlignment="Center" />
                        <TextBlock
                            Margin="0,8,0,0"
                            FontSize="12"
                            Foreground="{DynamicResource TextSubtle}"
                            Text="{x:Static p:Resources.MayTakeAMoment}"
                            TextAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>

            <!--  Dedicated Login & Pairing Overlay  -->
            <Grid
                Panel.ZIndex="9998"
                Background="#DD0F1115"
                IsHitTestVisible="True"
                Visibility="{Binding ShowLoginOverlay, Converter={StaticResource BoolToVisibility}}">

                <Border
                    Width="450"
                    Padding="40"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource Surface}"
                    BorderBrush="{DynamicResource CardBorder}"
                    BorderThickness="1"
                    CornerRadius="20">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="50"
                            Opacity="0.5"
                            ShadowDepth="0"
                            Color="Black" />
                    </Border.Effect>

                    <StackPanel>
                        <!--  Icon / Brand  -->
                        <Border
                            Width="80"
                            Height="80"
                            Margin="0,0,0,24"
                            Background="{DynamicResource AccentDark}"
                            CornerRadius="40">
                            <ui:SymbolIcon
                                FontSize="40"
                                Foreground="{DynamicResource Accent}"
                                Symbol="ShieldLock24" />
                        </Border>

                        <TextBlock
                            Margin="0,0,0,12"
                            FontSize="28"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="{x:Static p:Resources.ReadyToDominate}"
                            TextAlignment="Center" />

                        <TextBlock
                            Margin="0,0,0,32"
                            FontSize="14"
                            Foreground="{DynamicResource TextSubtle}"
                            LineHeight="20"
                            Text="{x:Static p:Resources.PairAccountBenefits}"
                            TextAlignment="Center"
                            TextWrapping="Wrap" />

                        <ui:Button
                            x:Name="BtnOverlayPair"
                            Height="50"
                            HorizontalAlignment="Stretch"
                            Appearance="Primary"
                            Click="BtnListenPairing_Click"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Icon="{ui:SymbolIcon Symbol=BluetoothConnected24}">
                            <ui:Button.Content>
                                <TextBlock Margin="8,0,0,0" Text="{x:Static p:Resources.LoginPairAccount}" />
                            </ui:Button.Content>
                        </ui:Button>

                        <TextBlock
                            Margin="0,20,0,0"
                            FontSize="11"
                            Foreground="{DynamicResource TextCaption}"
                            Text="{x:Static p:Resources.RequiresSteamLogin}"
                            TextAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>

            <!--  Delete Confirmation Overlay  -->
            <Grid
                x:Name="DeleteConfirmationOverlay"
                Panel.ZIndex="10000"
                Background="#AA000000"
                IsHitTestVisible="True"
                Visibility="Collapsed">
                <Border
                    Width="400"
                    Padding="32"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource Surface}"
                    BorderBrush="{DynamicResource CardBorder}"
                    BorderThickness="1"
                    CornerRadius="16">
                    <StackPanel>
                        <!--  Header with Icon  -->
                        <Grid Margin="0,0,0,24">
                            <Ellipse
                                Width="64"
                                Height="64"
                                Fill="#26FF4B4B" />
                            <ui:SymbolIcon
                                FontSize="32"
                                Foreground="#FFFF4B4B"
                                Symbol="Delete24" />
                        </Grid>

                        <TextBlock
                            FontSize="20"
                            FontWeight="Bold"
                            Foreground="{DynamicResource TextPrimary}"
                            Text="{x:Static p:Resources.DeleteServerHeader}"
                            TextAlignment="Center" />

                        <TextBlock
                            x:Name="TxtDeleteConfirmation"
                            Margin="0,12,0,32"
                            FontSize="14"
                            LineHeight="20"
                            Foreground="{DynamicResource TextSubtle}"
                            Text="{x:Static p:Resources.DeleteServerConfirm}"
                            TextAlignment="Center"
                            TextWrapping="Wrap" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <ui:Button
                                Grid.Column="0"
                                Padding="12"
                                HorizontalAlignment="Stretch"
                                Click="BtnCancelDelete_Click"
                                Content="{x:Static p:Resources.Cancel}" />

                            <ui:Button
                                Grid.Column="2"
                                Padding="12"
                                HorizontalAlignment="Stretch"
                                Appearance="Primary"
                                Background="#FFFF4B4B"
                                BorderBrush="#FFFF4B4B"
                                Click="BtnConfirmDelete_Click"
                                Content="{x:Static p:Resources.DeleteAction}" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!--  Custom Smart Alarm Overlay  -->
            <Border
                x:Name="AlarmOverlayBorder"
                Grid.ColumnSpan="3"
                Margin="20,20,20,130"
                Padding="16"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Background="#EE660000"
                BorderBrush="#FFFF5555"
                BorderThickness="1"
                CornerRadius="8"
                Panel.ZIndex="9998"
                Visibility="Collapsed"
                Width="360">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Direction="270" Opacity="0.3" ShadowDepth="2" Color="Black" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Image Grid.Column="0" Width="18" Height="18" Margin="0,0,8,0" Source="pack://application:,,,/Assets/icons/smartalarm.png" Stretch="Uniform" />
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="{x:Static p:Resources.SmartAlarm}" />

                        <StackPanel Grid.Column="2" Margin="0,0,12,0" VerticalAlignment="Center" Orientation="Horizontal">
                            <ui:Button x:Name="AlarmOverlayPrevBtn" Padding="4" Appearance="Transparent" Click="AlarmOverlayPrev_Click" Icon="{ui:SymbolIcon Symbol=ChevronLeft24}" />
                            <TextBlock x:Name="AlarmOverlayPagingTxt" Margin="6,0" VerticalAlignment="Center" Text="1/1" />
                            <ui:Button x:Name="AlarmOverlayNextBtn" Padding="4" Appearance="Transparent" Click="AlarmOverlayNext_Click" Icon="{ui:SymbolIcon Symbol=ChevronRight24}" />
                        </StackPanel>

                        <ui:Button Grid.Column="3" Padding="4" Appearance="Transparent" Click="AlarmOverlayClose_Click" Icon="{ui:SymbolIcon Symbol=Dismiss24}" />
                    </Grid>

                    <TextBlock x:Name="AlarmOverlayServerTxt" Grid.Row="1" Margin="0,0,0,4" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Server Name - 14:30" />
                    <TextBlock x:Name="AlarmOverlayNameTxt" Grid.Row="2" Margin="0,0,0,2" FontSize="16" FontWeight="Bold" Text="Custom Alarm Name" TextWrapping="Wrap" />
                    <TextBlock x:Name="AlarmOverlayMsgTxt" Grid.Row="3" Margin="0,0,0,12" FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="{x:Static p:Resources.AlarmActivated}" TextWrapping="Wrap" />

                    <CheckBox x:Name="AlarmOverlayAutoHideChk" Grid.Row="4" Content="{x:Static p:Resources.AutoHideAfter3s}" FontSize="12" IsChecked="False" Checked="AlarmOverlayAutoHideChk_Changed" Unchecked="AlarmOverlayAutoHideChk_Changed"/>
                </Grid>
            </Border>

            <!--  Wpf.Ui: WinUI 3 Snackbar presenter (toast notifications)  -->
            <ui:SnackbarPresenter
                x:Name="RootSnackbar"
                Grid.ColumnSpan="3"
                Margin="20,0,20,20"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                MaxWidth="400"
                Panel.ZIndex="9999" />

        </Grid>
    </Grid>
</ui:FluentWindow>
