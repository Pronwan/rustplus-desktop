<Window x:Class="RustPlusDesk.Views.SettingsModal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:l="clr-namespace:RustPlusDesk.Localization"
        Title="{l:Loc settings.window_title}"
        Width="500" Height="540"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="True" 
        WindowStyle="None"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True">
    
    <Border Background="{DynamicResource SurfaceAlt}" 
            BorderBrush="{DynamicResource CardBorder}" 
            BorderThickness="2" 
            CornerRadius="12">
        <DockPanel Margin="20">
            <!-- Header -->
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,20">
                <DockPanel>
                    <TextBlock Text="{l:Loc settings.title}"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <Button Content="✕"
                            HorizontalAlignment="Right" 
                            Width="30" Height="30"
                            Style="{StaticResource GhostButton}"
                            Click="BtnClose_Click"
                            Cursor="Hand"
                            FontSize="18"
                            Foreground="{DynamicResource TextSubtle}"/>
                </DockPanel>
                <Separator Background="{DynamicResource CardBorder}" Margin="0,10,0,0"/>
            </StackPanel>

            <!-- Footer -->
            <Button DockPanel.Dock="Bottom"
                    Content="{l:Loc common.close}"
                    Width="100"
                    Height="35"
                    HorizontalAlignment="Right"
                    Style="{StaticResource PrimaryButton}"
                    Click="BtnClose_Click"
                    Margin="0,15,0,0"/>

            <!-- Content -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="{l:Loc settings.section.general}" Foreground="{DynamicResource Accent}" FontWeight="Bold" Margin="0,0,0,10"/>

                    <CheckBox x:Name="ChkAutoStart"
                               Content="{l:Loc settings.auto_start}"
                               Margin="0,0,0,12"
                               Style="{StaticResource DotCheckBox}"
                               Checked="OnSettingChanged" Unchecked="OnSettingChanged"/>

                    <CheckBox x:Name="ChkStartMinimized"
                               Content="{l:Loc settings.start_minimized}"
                               Margin="0,0,0,12"
                               Style="{StaticResource DotCheckBox}"
                               Checked="OnSettingChanged" Unchecked="OnSettingChanged"/>

                    <CheckBox x:Name="ChkAutoConnect"
                               Content="{l:Loc settings.auto_connect}"
                               Margin="0,0,0,12"
                               Style="{StaticResource DotCheckBox}"
                               Checked="OnSettingChanged" Unchecked="OnSettingChanged"
                               ToolTip="{l:Loc settings.auto_connect_tooltip}"/>

                    <TextBlock Text="{l:Loc settings.section.behavior}" Foreground="{DynamicResource Accent}" FontWeight="Bold" Margin="0,10,0,10"/>

                    <CheckBox x:Name="ChkCloseToTray"
                               Content="{l:Loc settings.close_to_tray}"
                               Margin="0,0,0,12"
                               Style="{StaticResource DotCheckBox}"
                               Checked="OnSettingChanged" Unchecked="OnSettingChanged"/>

                    <CheckBox x:Name="ChkBackgroundTracking"
                               Content="{l:Loc settings.background_tracking}"
                               Margin="0,0,0,12"
                               Style="{StaticResource DotCheckBox}"
                               Checked="OnSettingChanged" Unchecked="OnSettingChanged"
                               ToolTip="{l:Loc settings.background_tracking_tooltip}"/>

                    <CheckBox x:Name="ChkHideConsole"
                               Content="{l:Loc settings.hide_console}"
                               Margin="0,0,0,12"
                               Style="{StaticResource DotCheckBox}"
                               Checked="OnSettingChanged" Unchecked="OnSettingChanged"
                               ToolTip="{l:Loc settings.hide_console_tooltip}"/>

                    <TextBlock Text="{l:Loc settings.section.map}" Foreground="{DynamicResource Accent}" FontWeight="Bold" Margin="0,10,0,10"/>

                    <CheckBox x:Name="ChkAutoLoadShops"
                               Content="{l:Loc settings.auto_load_shops}"
                               Margin="0,0,0,12"
                               Style="{StaticResource DotCheckBox}"
                               Checked="OnSettingChanged" Unchecked="OnSettingChanged"
                               ToolTip="{l:Loc settings.auto_load_shops_tooltip}"/>

                    <TextBlock Text="{l:Loc settings.section.language}" Foreground="{DynamicResource Accent}" FontWeight="Bold" Margin="0,10,0,10"/>
                    <TextBlock Text="{l:Loc settings.language_hint}"
                               Foreground="{DynamicResource TextSubtle}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8"/>
                    <ComboBox x:Name="CboLanguage"
                              Margin="0,0,0,16"
                              Width="220"
                              HorizontalAlignment="Left"
                              SelectionChanged="OnLanguageChanged"/>

                    <TextBlock Text="{l:Loc settings.section.steam}" Foreground="{DynamicResource Accent}" FontWeight="Bold" Margin="0,10,0,10"/>
                    <TextBlock Text="{l:Loc settings.steam_hint}"
                               Foreground="{DynamicResource TextSubtle}"
                               FontSize="12"
                               FontStyle="Italic"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
