<Window x:Class="RustPlusDesk.Views.HotkeysWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hotkeys"
        Width="680" Height="460"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent"
        ShowInTaskbar="False">

    <Window.Resources>
        <!--
            DataGrid styles scoped to this window — the grid only exists here
            so it stays local. Inherits the global zinc palette from App.xaml
            for surfaces, borders, and text.
        -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#18181B"/>
            <Setter Property="Foreground" Value="#FAFAFA"/>
            <Setter Property="BorderBrush" Value="#27272A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="#18181B"/>
            <Setter Property="AlternationCount" Value="2"/>
            <Setter Property="AlternatingRowBackground" Value="#0F0F11"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="34"/>
            <Setter Property="ColumnHeaderHeight" Value="36"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#27272A"/>
            <Setter Property="VerticalGridLinesBrush" Value="#27272A"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#27272A"/>
            <Setter Property="Foreground" Value="#A1A1AA"/>
            <Setter Property="BorderBrush" Value="#27272A"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="BorderBrush" Value="#27272A"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3F3F46"/>
                    <Setter Property="Foreground" Value="#FAFAFA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#18181B"
            BorderBrush="#27272A"
            BorderThickness="1"
            CornerRadius="8">
        <DockPanel Margin="20">
            <!-- Header -->
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                <DockPanel>
                    <TextBlock Text="Hotkeys"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <Button Content="✕"
                            HorizontalAlignment="Right"
                            Width="30" Height="30"
                            Style="{StaticResource GhostButton}"
                            Click="BtnCloseDeactivate_Click"
                            Cursor="Hand"
                            FontSize="18"
                            Foreground="{DynamicResource TextSubtle}"/>
                </DockPanel>
                <TextBlock Text="Assign global hotkeys to Smart Switches. Multiple devices can share one hotkey (it'll toggle them sequentially)."
                           Foreground="{DynamicResource TextSubtle}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0,6,0,0"/>
                <Separator Background="{DynamicResource CardBorder}" Margin="0,12,0,0"/>
            </StackPanel>

            <!-- Footer -->
            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0">
                <Button Content="Close &amp; Deactivate"
                        Width="170" Height="36"
                        Margin="0,0,8,0"
                        Style="{StaticResource SecondaryButton}"
                        Click="BtnCloseDeactivate_Click"/>
                <Button Width="170" Height="36"
                        Style="{StaticResource PrimaryButton}"
                        IsDefault="True"
                        Click="BtnCloseActivate_Click">
                    <TextBlock Text="Close &amp; Activate" Foreground="#18181B"/>
                </Button>
            </StackPanel>

            <!-- Grid -->
            <DataGrid x:Name="GridDevices"
                      HeadersVisibility="Column"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      ItemsSource="{Binding}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Device"   Binding="{Binding Display}"  Width="2*"/>
                    <DataGridTextColumn Header="EntityId" Binding="{Binding EntityId}" Width="*"/>
                    <DataGridTextColumn Header="Hotkey"   Binding="{Binding Hotkey}"   Width="*"/>
                    <DataGridTemplateColumn Header="" Width="170">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="Set"   Width="70" Margin="0,0,6,0"
                                            Padding="6,3" FontSize="11"
                                            Style="{StaticResource SecondaryButton}"
                                            Click="BtnSet_Click"/>
                                    <Button Content="Clear" Width="70"
                                            Padding="6,3" FontSize="11"
                                            Style="{StaticResource SecondaryButton}"
                                            Click="BtnClear_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Border>
</Window>
