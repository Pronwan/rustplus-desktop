<Window x:Class="RustPlusDesk.Views.PatchNotesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:RustPlusDesk.Views"
        Title="Rust+ Desk – Patch Notes 3.5.0 – 22/04/26"
        Width="720"
        Height="620"
        Background="{DynamicResource AppBg}"
        Foreground="{DynamicResource TextPrimary}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        AllowsTransparency="False">

    <Border Background="{DynamicResource Surface}"
            BorderBrush="{DynamicResource CardBorder}"
            BorderThickness="1"
            CornerRadius="{DynamicResource Radius}"
            Padding="14"
            Margin="8">
        <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                <TextBlock Text="Patch Notes April 2026 | Activity Intelligence"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Margin="0,0,0,2"/>
                <TextBlock Text="Version 3.5.0"
                           Foreground="{DynamicResource Accent}"
                           FontSize="11"
                           Margin="0,0,0,4"/>
                <TextBlock Text="22.04.2026"
                           Foreground="{DynamicResource TextSubtle}"
                           FontSize="13"/>
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Disabled"
              CanContentScroll="False"
              ScrollViewer.PanningMode="VerticalOnly">
                <StackPanel Margin="0,0,0,12" Orientation="Vertical" >

                    <Border Background="{DynamicResource SurfaceAlt}"
                            BorderBrush="{DynamicResource CardBorder}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10"
                            Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="v3.5.0  |  Player Intelligence &amp; Background Operations"
                                       FontWeight="SemiBold"
                                       FontSize="15"
                                       Margin="0,0,0,8"/>

                            <TextBlock Margin="0,0,0,10" TextWrapping="Wrap">
    <Span Foreground="{DynamicResource TextSubtle}">Special thanks to </Span>
    <Hyperlink NavigateUri="https://github.com/JawadYzbk" 
               RequestNavigate="Hyperlink_RequestNavigate"
               Foreground="{DynamicResource Accent}">
        JawadYzbk
    </Hyperlink>
    <Span Foreground="{DynamicResource TextSubtle}"> for this massive contribution!</Span>
                            </TextBlock>

                            <TextBlock Text="• Advanced Activity Intelligence" 
                                       FontWeight="Bold" Margin="0,0,0,4"/>
                            <Image Source="pack://application:,,,/Screenshots/3_5A.png"
                                   Stretch="Uniform"
                                   MaxHeight="350"
                                   Margin="0,0,0,6"/>
                            <TextBlock Text="Introducing a comprehensive player tracking system! Monitor connections/disconnections to build a historical database. View 12-week GitHub-style heatmaps and 24-hour activity forecasts to predict sleep and play patterns of tracked players."
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>

                            <TextBlock Text="• System Tray &amp; Background Tracking" 
                                       FontWeight="Bold" Margin="0,0,0,4"/>
                            <Image Source="pack://application:,,,/Screenshots/3_5B.png"
                                   Stretch="Uniform"
                                   MaxHeight="150"
                                   Margin="0,0,0,6"/>
                            <TextBlock Text="The app can now reside in your system tray. Enable background tracking to keep collecting player data even when the main window is closed. Includes a new 'Start with Windows' option."
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>

                            <TextBlock Text="• Single Instance &amp; Protocol Handling" 
                                       FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="Improved reliability: The app now ensures only one instance is running. Launching the app again (or clicking a rustplus:// link) will automatically bring the existing window to the foreground."
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>

                            <TextBlock Text="• Fixed: Battlemetrics Server Lookup" 
                                       FontWeight="Bold" Margin="0,0,0,4" Foreground="{DynamicResource Accent}"/>
                            <TextBlock Text="Improved server identification logic. Fixed an issue where servers with shared IPs (like Rustoria) were sometimes incorrectly identified. Searching is now strictly IP-based for 100% accuracy."
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,4"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource SurfaceAlt}"
                            BorderBrush="{DynamicResource CardBorder}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10"
                            Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="v3.4.0  |  Hierarchical Grouping &amp; Advanced Alarms"
                                       FontWeight="SemiBold"
                                       FontSize="15"
                                       Margin="0,0,0,8"/>

                            <TextBlock Text="• Hierarchical Device Grouping" 
                                       FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="You can now organize your smart devices into nested groups! Simply drag one device onto another to create a folder. Groups allow you to toggle all contained switches at once with a single click."
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>

                            <TextBlock Text="• Persistent Smart Alarm Settings" 
                                       FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="You can now enable/disable popups and audio independently, and even select your own .wav/.mp3 files for specific alarms. Just right-click on the Audio toggle to select your own audio file!"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>

                            <TextBlock Text="• Recursive Team Sync" 
                                       FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="Exporting and importing device snapshots now fully supports your custom group structures. Your team members will see the exact same hierarchy you've organized."
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>