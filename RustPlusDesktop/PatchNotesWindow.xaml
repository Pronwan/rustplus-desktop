<Window x:Class="RustPlusDesk.Views.PatchNotesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rust+ Desk – Patch Notes"
        Width="720" Height="620"
        Background="{DynamicResource AppBg}"
        Foreground="{DynamicResource TextPrimary}"
        WindowStartupLocation="CenterOwner">

    <Border Background="{DynamicResource Surface}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="{DynamicResource Radius}" Padding="14" Margin="8">
        <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                <TextBlock Text="Patch Notes &amp; Version History" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,2"/>
                <!-- UPDATE VERSION NUMBER HERE -->
                <TextBlock Text="Current Version: 4.0.0" Foreground="{DynamicResource Accent}" FontSize="11" Margin="0,0,0,4"/>
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,0,0,12">

                    <!-- ============================================== -->
                    <!-- NEW v4.0.0 PATCH NOTES -->
                    <!-- ============================================== -->
                    <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="v4.0.0  |  The Map &amp; Stability Overhaul (Major Release)" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,4" Foreground="{DynamicResource Accent}"/>

                            <!-- Contributor Credit -->
                            <TextBlock Margin="0,0,0,10" TextWrapping="Wrap">
                                <Span Foreground="{DynamicResource TextSubtle}">This massive milestone update is entirely thanks to </Span>
                                <Hyperlink NavigateUri="https://github.com/JawadYzbk" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource Accent}">JawadYzbk</Hyperlink>
                                <Span Foreground="{DynamicResource TextSubtle}">! He rebuilt the core architecture of the app to be faster, smarter, and infinitely more stable.</Span>
                            </TextBlock>

                            <!-- Screenshots -->
                            <Image Source="pack://application:,,,/Screenshots/v4_map_overhaul.png" Stretch="Uniform" MaxHeight="350" Margin="0,0,0,6"/>
                            <Image Source="pack://application:,,,/Screenshots/v4_shop_hover.png" Stretch="Uniform" MaxHeight="350" Margin="0,0,0,12"/>

                            <!-- Features -->
                            <TextBlock Text="• 'Dead Reckoning' &amp; Connection Resilience" FontWeight="Bold" Margin="0,0,0,4" Foreground="{DynamicResource Accent}"/>
                            <TextBlock Text="Say goodbye to flickering markers! If a high-pop server (like Rustoria) delays data, the app now uses predictive interpolation to keep players and events moving smoothly. Shops will no longer disappear during brief connection drops." TextWrapping="Wrap" Margin="0,0,0,8"/>

                            <TextBlock Text="• Interactive Event Dock &amp; Auto-Follow" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="A brand new Event Dock tracks active map events (Patrol Heli, Cargo Ship, Chinook, Travelling Vendor, Deep Sea). Click an event to instantly lock the camera onto it and track it automatically across the map." TextWrapping="Wrap" Margin="0,0,0,8"/>

                            <TextBlock Text="• Smart Shop Clustering" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="Multiple vending machines in a single base are now clustered into one clean map icon. Hovering over the cluster reveals a beautifully redesigned, scrollable popup showing all items sold at that location." TextWrapping="Wrap" Margin="0,0,0,8"/>

                            <TextBlock Text="• Modern Shop Search &amp; Advanced Trades" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="The Shop Search is now an ultra-fast, modern embedded interface. The 'Profit Trades' (Arbitrage) and 'Buy X for Y' tools have been moved to their own dedicated windows. The app also introduces 'Suspicious Shop' detection to warn you about bait bases." TextWrapping="Wrap" Margin="0,0,0,8"/>

                            <TextBlock Text="• 60 FPS Animations &amp; Offline Icon Caching" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="Map zooming and panning now feature butter-smooth animations and a cinematic 'overview dip'. Item icons are securely cached offline using SHA1 hashes, making map loading near-instant and saving bandwidth." TextWrapping="Wrap" Margin="0,0,0,8"/>
                        </StackPanel>
                    </Border>


                    <!-- ============================================== -->
                    <!-- OLD PATCH NOTES (Unchanged) -->
                    <!-- ============================================== -->
                    <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="v3.5.4  |  Player Management &amp; Optimization" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,4"/>
                            <Image Source="https://github.com/user-attachments/assets/d6fad211-efb2-4c15-9ec3-29e65cb6c8dd" Stretch="Uniform" MaxHeight="350" Margin="0,0,0,6"/>
                            <Image Source="https://github.com/user-attachments/assets/ba63c2ec-1ee6-4d12-9da1-d06df26bcd7a" Stretch="Uniform" MaxHeight="350" Margin="0,0,0,6"/>
                            <Image Source="https://github.com/user-attachments/assets/9544f75e-d98b-4e6a-b9e1-9ef6d6ee00f6" Stretch="Uniform" MaxHeight="350" Margin="0,0,0,6"/>

                            <TextBlock Text="• Manual Player Tracking &amp; Renaming" FontWeight="Bold" Margin="0,0,0,4" Foreground="{DynamicResource Accent}"/>
                            <TextBlock Text="Manually add players to your trackers list using their BattleMetrics ID. The app fetches their last seen status and allows you to rename them for better organization." TextWrapping="Wrap" Margin="0,0,0,8"/>

                            <TextBlock Text="• Optimized Item Icon Downloads" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="Icons are now fetched from RustClash CDN in 40x40 size, reducing download size by 12.9x (totaling 151KB). Existing high-res icons remain cached; only missing ones are fetched in the new optimized format." TextWrapping="Wrap" Margin="0,0,0,8"/>

                            <TextBlock Text="• Progress Tracking" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="Added a download progress bar to show visual status when the app is fetching item icons or updates." TextWrapping="Wrap" Margin="0,0,0,8"/>

                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="v3.5.3  |  The Intelligence Update" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,4"/>

                            <TextBlock Margin="0,0,0,10" TextWrapping="Wrap">
                                <Span Foreground="{DynamicResource TextSubtle}">Special thanks to </Span>
                                <Hyperlink NavigateUri="https://github.com/JawadYzbk" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource Accent}">JawadYzbk</Hyperlink>
                                <Span Foreground="{DynamicResource TextSubtle}"> for this massive contribution!</Span>
                            </TextBlock>

                            <TextBlock Text="• Advanced Activity Intelligence" FontWeight="Bold" Margin="0,0,0,4"/>
                            <Image Source="pack://application:,,,/Screenshots/3_5A.png" Stretch="Uniform" MaxHeight="350" Margin="0,0,0,6"/>
                            <TextBlock Text="Full player tracking system with 12-week heatmaps and 24h forecasts. Predict when players are active or sleeping based on historical connection data." TextWrapping="Wrap" Margin="0,0,0,8"/>

                            <TextBlock Text="• Manual IP &amp; Protocol Support" FontWeight="Bold" Margin="0,0,0,4" Foreground="{DynamicResource Accent}"/>
                            <TextBlock Text="Added support for rustplus:// links! You can now manually add servers using 'rustplus://IP:PORT'—a workaround for some servers where the pairing button is disabled." TextWrapping="Wrap" Margin="0,0,0,8"/>

                            <TextBlock Text="• Centralized Settings &amp; Auto-Connect" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="New Settings Modal: Toggle Auto-Start with Windows, Minimize to Tray, and Auto-Connect to your last server on startup." TextWrapping="Wrap" Margin="0,0,0,8"/>

                            <TextBlock Text="• System Tray &amp; Background Ops" FontWeight="Bold" Margin="0,0,0,4"/>
                            <Image Source="pack://application:,,,/Screenshots/3_5B.png" Stretch="Uniform" MaxHeight="150" Margin="0,0,0,6"/>
                            <TextBlock Text="The app can now reside in your system tray to collect data 24/7. Improved single-instance handling ensures the window pops up when you need it." TextWrapping="Wrap" Margin="0,0,0,8"/>

                            <TextBlock Text="• Fixed: Battlemetrics Server Lookup" FontWeight="Bold" Margin="0,0,0,4" Foreground="{DynamicResource Accent}"/>
                            <TextBlock Text="Overhauled server identification. Searching is now strictly IP-based for 100% accuracy, fixing issues with shared IP ranges (e.g., Rustoria)." TextWrapping="Wrap" Margin="0,0,0,4"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="v3.4.0  |  Hierarchical Grouping &amp; Advanced Alarms" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,8"/>
                            <TextBlock Text="• Hierarchical Device Grouping" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="Organize smart devices into nested groups! Drag one onto another to create folders and toggle entire groups with one click." TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <TextBlock Text="• Persistent Smart Alarm Settings" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="Enable/disable popups and audio independently. Support for custom .wav/.mp3 alarm files via right-click." TextWrapping="Wrap" Margin="0,0,0,8"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="v3.3.1  |  Stability &amp; Event Awareness" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,8"/>
                            <TextBlock Text="• Deep Sea Event Notifications ~3 minutes ahead of actual Deep Sea Spawn" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="Team chat notifications for Deep Sea events (direction always West, not actual direction)." TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <TextBlock Text="• Chat Deduplication" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="Robust 100-message window check to prevent duplicate notifications during reconnects." TextWrapping="Wrap" Margin="0,0,0,8"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="v3.3.0  |  Oilrig Timer &amp; !leader Command" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,8"/>
                            <Image Source="pack://application:,,,/Screenshots/3.3.0_1.png" Stretch="Uniform" MaxHeight="250" Margin="0,0,0,4"/>
                            <TextBlock Text="Live countdown for Oilrig crates directly on the map. Teammates can use !leader in chat to request promotion." TextWrapping="Wrap" Margin="0,0,0,8"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource SurfaceAlt}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Core Features &amp; Older Updates" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,6"/>
                            <TextBlock Text="• v3.2.0: Smart Device Import/Export for teams." Margin="0,0,0,2"/>
                            <TextBlock Text="• v3.1.0: Full Storage Monitor &amp; Upkeep integration." Margin="0,0,0,2"/>
                            <TextBlock Text="• v3.0.0: Massive Shop Analytics overhaul &amp; Custom Map Overlays." Margin="0,0,0,2"/>
                            <TextBlock Text="• Camera monitoring, Team management, Death markers, and more." Margin="0,4,0,0" FontStyle="Italic"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>